private void GetMiscSectionData()
{
    Database db = new Database();
    DataReader dbRdr = new DataReader();
    SqlDataReader sqlRdr = null;

    try
    {
        if (db.Open() == false)
            return;

        dbRdr.Connection = db.Connection;
        dbRdr.StoredProcedure = SqlObjectsStaticClass.p_GetData_Maintenance;
        dbRdr.SqlIdentifier = "MISC_DATA";

        if (dbRdr.GetData(ref sqlRdr, new string[0]) == false)
            return;

        StringBuilder sb = new StringBuilder();
        sb.Append("{");
        bool isFirst = true;

        while (sqlRdr.Read())
        {
            string sectionKey = Convert.ToString(sqlRdr["ValueDesc"]).Trim();
            string sectionValue = Convert.ToString(sqlRdr["Value"]).Trim();

            if (!isFirst) sb.Append(",");
            sb.Append("\"").Append(sectionKey).Append("\":\"").Append(sectionValue).Append("\"");
            isFirst = false;
        }
        sb.Append("}");

        _MiscSectionDataJson = sb.ToString();
        _MiscSectionRoleName = pageTemplate.RoleName;
    }
    catch (Exception Exc)
    {
        Information clsInfo = new Information();
        clsInfo.ErrNum = 5000;
        clsInfo.ErrStr = Exc.Message;
        clsInfo.ErrStack = Exc.StackTrace;
        // Deliberately not Server.Transfer-ing here: a failure to fetch
        // section-visibility data shouldn't take down the whole page —
        // worst case, no sections get hidden for this request.
    }
    finally
    {
        if (sqlRdr != null && !sqlRdr.IsClosed)
            sqlRdr.Close();

        dbRdr.Dispose();
        db.Dispose();
    }
}








