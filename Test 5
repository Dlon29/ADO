    function IsAnySelected(datagridId, checkboxId, countDisabled) {
        /*
        Author: Edwin Stephenraj
        
        Description: 
            returns true if any checkbox are selected else false 
                
        Parameters:
            datagridId:		id of the datagrid
            checkboxId:		Id column of the checkbox in the grid
        */

        var grdControl;
        var divArray;
        var inpControls;
        var objControl;
        var arrCount1 = 0;
        var arrCount2 = 0;

        if (countDisabled == null)
            countDisabled = false;

        // find the grid.
        grdControl = document.getElementById(datagridId);
        if (grdControl == null) {
            alert('Error in finding table id');
            return false;
        }

        //get all the span tags
        var inpControls = grdControl.getElementsByTagName("input");
        arrCount2 = inpControls.length;

        //loop through all the span tag 	
        for (j = 0; j < arrCount2; j++) {
            objControl = inpControls[j];

            //proceed if the child is valid one
            if (objControl != null) {
                // check the id has both datagrid id and checkbox id (parameter passed)
                if (objControl.id.indexOf(checkboxId) != -1) {
                    // select or unselect only if control is enabled.
                    if (!objControl.disabled || countDisabled)
                        if (objControl.checked)
                            return true;
                }
            }
        }

        return false;
    }

    function CheckLoanNumberValue()
    {
        if (event.keyCode == 13)
        {
            return TextBox_KeyPress('btnSearch');
        }
        else
        {
            return fnIsNumberKey(event, false);
        }
    }

    function fnIsNumberKey(evt, isDecimal) {

        var charCode = (evt.which) ? evt.which : event.keyCode

        if (isDecimal) {
            if (charCode > 31 && (charCode < 48 || charCode > 57) && charCode != 46) 
                return false;
            else if (charCode == 46 && evt.srcElement.value.split('.').length > 1) {
                return false;
            }
        }
        else {
            if (charCode > 31 && (charCode < 48 || charCode > 57)) 
                return false;
        }

        return true;
    }

