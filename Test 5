                    batchRunDate = this.txtPensionTop5BorrowersBatchRunDate.Text;  
                    Session["_batchRunDate_PensionTopFiveBorrowers_miscReports"] = batchRunDate;
                    break;
            }

            if (_SelectedImgButtonId != commandArgument)
            {
                switch (_SelectedImgButtonId)
                {
                    case "REFRESH3":			//extract recon errors
                        batchRunDate = this.txtStartDate3.Text;
                        Session["_batchRunDate3_miscReports"] = batchRunDate;
