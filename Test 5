        static void CheckLogin()
        {
            //check for the login status
            string loginPage = @"/" + GlobalVariable.AppRoot + @"/Login.aspx";
            string IsAuthenticated;

            //FormsAuthentication.GetRedirectUrl
            //			if (FormsAuthentication.GetAuthCookie(_NTUserName,false))
            //			{
            //
            //			}

            if (HttpContext.Current.Session["IsAuthenticated"] != null)
                IsAuthenticated = HttpContext.Current.Session["IsAuthenticated"].ToString();
            else
                IsAuthenticated = "false";

            if (IsAuthenticated.ToString() == "false")
                HttpContext.Current.Response.Redirect(loginPage);
        }

        public void getAccessTypeCode()
        {
            _AccessTypeCode = Common.getAccessTypeCode(_ModuleName);
        }

        public Dictionary<string, string> GetUserModuleRights()
        {
            Dictionary<string, string> moduleRights = new Dictionary<string, string>();

            _logger.Info("Preparing to retrieve module role rights");
            try
            {
                moduleRights = Common.GetUserModuleRights();
            }
            catch (Exception ex)
            {
                _logger.Error(ex);
                throw ex;
            }

            return moduleRights;
        }

        public bool CheckAuthentication(string ModuleName)
        {
            try
            {
                //Bypass Active Directory and Database roles.
                if (!clsUI.IsSecurityEnabled)
                    return true;

                if (!IsAuthenticated)
                {
                    //Check LDAP GroupNames.
                    clsUI.checkADGroupUser(ModuleName);

                    _IsSuperUser = clsUI.IsSuperUser;
                    _RoleName = clsUI.RoleName.Replace(" ", "");
                    // _ReadWriteAccess = clsUI.ReadWriteAccess;

                    HttpContext.Current.Session["IsAuthenticated"] = true;
                    HttpContext.Current.Session["IsSuperUser"] = _IsSuperUser;
                    HttpContext.Current.Session["RoleName"] = _RoleName;
                }
                else
                {
                    _IsSuperUser = (bool)HttpContext.Current.Session["IsSuperUser"];
                    _RoleName = HttpContext.Current.Session["RoleName"].ToString();
                    _RoleName = _RoleName.Replace(" ", "");
                }

                if (_RoleName.ToLower().Equals("superuser"))  // Debug-Test SuperUser role.
                    _IsSuperUser = true;

                // store in session
                HttpContext.Current.Session["IsSuperUser"] = _IsSuperUser;
            }
            catch (Exception ex)
            {
                _logger.Error(ex);
                return false;
            }

            return true;
        }

