        private void GetIndemnityReport()
        {
            const int RPTID_SMTBUSA_INDEMNITY_DETAILS_REPORT = 158;
            const int RPTID_SMTBTOKYO_INDEMNITY_DETAILS_REPORT = 209;
            const int RPTID_SMTBTOKYO_INDEMNITY_SUMMARY_REPORT = 210;
            int reportID = 0;
            Int32.TryParse(this.cboIndemnityReports.SelectedValue, out reportID);

            if (reportID == 0) { return; }

            this.GetSelectedAccounts();
            Database db = new Database();
            _ErrorString = new StringBuilder();
            DataCommand dbCommand = new DataCommand();
            Hashtable htMain = null;
            string fileName;

            try
            {
                if (db.Open() == false)
                    return;

                dbCommand.Connection = db.Connection;
                dbCommand.StoredProcedure = SqlObjectsStaticClass.p_IndemnityReportCombine;

                htMain = new Hashtable();

                htMain.Add("@BatchRunDate", new Hashtable());
                ((Hashtable)htMain["@BatchRunDate"]).Add("Value", (cboDateRange8.SelectedValue == "r") ? ddlAsofDate.SelectedValue : txtBatchRunDate8.Text);
                ((Hashtable)htMain["@BatchRunDate"]).Add("IsReportParameter", true);

                htMain.Add("@ReportID", new Hashtable());
                ((Hashtable)htMain["@ReportID"]).Add("Value", this.cboIndemnityReports.SelectedValue);
                ((Hashtable)htMain["@ReportID"]).Add("IsReportParameter", true);

                htMain.Add("@AcctNbrList", new Hashtable());
                ((Hashtable)htMain["@AcctNbrList"]).Add("Value", _strXMLAcctSet);
                ((Hashtable)htMain["@AcctNbrList"]).Add("IsReportParameter", true);


                byte[] temp = null;
                fileName = string.Format("{0}_Indemnity.xls", System.DateTime.Now.ToString("yyyyMMdd"));

                if (dbCommand.ExecuteStoreProc(ref htMain) == true)
                {
                    switch (reportID)
                    {
                        case RPTID_SMTBTOKYO_INDEMNITY_SUMMARY_REPORT:
                            MOBETTER.ExcelTemplates.IndemnitySummaryReport indemnitySummaryReport = new MOBETTER.ExcelTemplates.IndemnitySummaryReport(htMain["SqlDataReader"])
                            {
                                AsOfDate = (this.cboDateRange8.SelectedValue == "r") ? Convert.ToDateTime(ddlAsofDate.SelectedValue) : Convert.ToDateTime(txtBatchRunDate8.Text),
                                ReportID = Convert.ToInt32(this.cboIndemnityReports.SelectedValue),
                                ReportType = cboReportType8.SelectedValue,

                            };

                            STBUSA.Excel.ExcelReportGenerator indemnitySummaryReportExtract = new STBUSA.Excel.ExcelReportGenerator(indemnitySummaryReport);
                            temp = indemnitySummaryReportExtract.Generate();
                            break;

                        case RPTID_SMTBTOKYO_INDEMNITY_DETAILS_REPORT:
                        case RPTID_SMTBUSA_INDEMNITY_DETAILS_REPORT:
                        default:
                            MOBETTER.ExcelTemplates.IndemnificationDetail indemnityDetailReport = new MOBETTER.ExcelTemplates.IndemnificationDetail(htMain["SqlDataReader"])
                            {
                                AsOfDate = (this.cboDateRange8.SelectedValue == "r") ? Convert.ToDateTime(ddlAsofDate.SelectedValue) : Convert.ToDateTime(txtBatchRunDate8.Text),
                                ReportID = Convert.ToInt32(this.cboIndemnityReports.SelectedValue),
                                ReportType = cboReportType8.SelectedValue,

                            };

                            STBUSA.Excel.ExcelReportGenerator indemnityDetailReportExtract = new STBUSA.Excel.ExcelReportGenerator(indemnityDetailReport);
                            temp = indemnityDetailReportExtract.Generate();                            
                            break;

                    }


                }

                if (temp != null)
                {
                    IsUI = false;
                    _show_error_row = "NONE";
                    Response.Clear();
                    Response.ClearContent();
                    Response.ClearHeaders();
                    Response.ContentType = "application/xls";
                    Response.AppendHeader("Content-Disposition", "attachment;filename=" + fileName);
                    Response.BinaryWrite(temp);
                    Response.Flush();
                }
                else
                {
                    IsUI = true;
                    _show_error_row = "";
