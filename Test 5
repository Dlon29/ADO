                    startDate = this.txtStartDate6.Text;
                    endDate = this.txtEndDate6.Text;
                    Session["_batchRunDate6_miscReports"] = batchRunDate;
                    break;

                case "REPORT7":			//Lending Earnings
                    IsReport = false;
                    batchRunDate = this.txtStartDate7.Text;
                    startDate = this.txtStartDate7.Text;
                    endDate = this.txtEndDate7.Text;
