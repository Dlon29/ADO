                STBUSA.Excel.ExcelReportGenerator excelGenerator = new STBUSA.Excel.ExcelReportGenerator(pensionTopFiveBorrowersReport);
                byte[] reportData = excelGenerator.Generate();

                if (reportData != null)
                {
                    IsUI = false;
                    _show_error_row = "NONE";
                    Response.Clear();
                    Response.ClearContent();
                    Response.ClearHeaders();
                    Response.ContentType = "application/xls";
                    Response.AppendHeader("Content-Disposition", "attachment;filename=" + batchRunDate.ToString("yyyyMMdd") + "PensionTopFiveReport.xls");
                    Response.BinaryWrite(reportData);
                    Response.Flush();
                }
                else
                {
                    IsUI = true;
                    _show_error_row = "";
                    _ErrorString.Append("<a href = \"#txtPensionTop5BorrowersBatchRunDate\"  OnClick='document.forms[0].txtPensionTop5BorrowersBatchRunDate.focus();'>\n");
                    _ErrorString.Append("\tNo data available for the given date, account and security type.\n");
                    _ErrorString.Append("</a> <br>\n");
                }
            }
            catch (Exception ex)
            {
                Response.ClearContent();
                Response.ContentType = "text/html";
                Information exceptionInfo = new Information();
                exceptionInfo.ErrNum = 5000;
                exceptionInfo.ErrStr = ex.Message;
                exceptionInfo.ErrStack = ex.StackTrace;
                Server.Transfer(errPage, true);
                return;
            }
            finally
            {
                if (!sqlRdr.IsClosed)
                    sqlRdr.Close();

                dbRdr.Dispose();
                db.Dispose();
            }
        }

        private void SynchronizeServerToClient(ref System.Web.UI.WebControls.ListBox lbUnreportedAccounts, ref System.Web.UI.WebControls.ListBox lbReportedAccounts)
        {
            char[] chArr = { ',' };

            if (Request[lbReportedAccounts.ID] != null)
            {
                string[] reportedAcctIDs = Request[lbReportedAccounts.ID].ToString().Split(chArr);

                // to syncronise reported accounts on server side
                foreach (string strID in reportedAcctIDs)
                {
                    if (lbUnreportedAccounts.Items.FindByValue(strID) != null)
                    {
                        lbUnreportedAccounts.Items.Remove(strID);
                    }

                    if (lbReportedAccounts.Items.FindByValue(strID) == null)
                    {
                        lbReportedAccounts.Items.Add(strID);
                    }
                }
                SortItems(lbReportedAccounts);
            }

            if (Request[lbUnreportedAccounts.ID] != null)
            {
                string[] unreportedAcctIDs  = Request[lbUnreportedAccounts.ID].ToString().Split(chArr);

                // to syncronise unreported accounts on server side
                foreach (string strID in unreportedAcctIDs)
                {
                    if (lbReportedAccounts.Items.FindByValue(strID) != null)
                {
                        lbReportedAccounts.Items.Remove(strID);
                    }
                    if (lbUnreportedAccounts.Items.FindByValue(strID) == null)
                    {
                        lbUnreportedAccounts.Items.Add(strID);
                    }
                }
                SortItems(lbUnreportedAccounts);
            }
        }


        private void SortItems(System.Web.UI.WebControls.ListBox lb)
        {
            ArrayList al = new ArrayList(lb.Items);

            al.Sort(new AccountListObject());

            lb.Items.Clear();
            lb.Items.AddRange((ListItem[])al.ToArray(typeof(ListItem)));
            lb.ClearSelection();
        }

        private string GetAcctSet(System.Web.UI.WebControls.ListBox lb)
        {
            StringBuilder sb = new StringBuilder();

            sb.Append("<root>");
            foreach (ListItem li in lb.Items)
            {
                sb.Append("<acct ID=\"" + li.Value + "\" />");
            }
            sb.Append("</root>");

            return sb.ToString();
        }

        [WebMethod]
        public static ArrayList GetAccounts(string startDate, string endDate, string acctGrpID)
        {
            Database db = new Database();
            DataReader dbRdr = new DataReader();
            SqlDataReader sqlRdr = null;
            string[] sqlParams = new string[6];
            string isActiveParam = "1";
            ArrayList arrAccounts = new ArrayList();
            try
            {
                if (db.Open() == false)
                    return arrAccounts;

                dbRdr.Connection = db.Connection;
                dbRdr.StoredProcedure = SqlObjectsStaticClass.p_GetData_Reports;
                dbRdr.SqlIdentifier = "GET_LENDABLE_ACCOUNT_LIST";

                sqlParams[0] = System.Convert.ToDateTime(startDate).ToShortDateString();
                sqlParams[1] = System.Convert.ToDateTime(endDate).ToShortDateString();
                sqlParams[2] = isActiveParam;
                sqlParams[3] = "";
                sqlParams[4] = "";
                sqlParams[5] = acctGrpID;
                dbRdr.GetData(ref sqlRdr, sqlParams);

                while (sqlRdr.Read())
                {
                    AccountsListItem accountListItem = new AccountsListItem();
                    accountListItem.AcccountID = Convert.ToInt32(sqlRdr["AcctID"]);
                    accountListItem.AccountName = Convert.ToString(sqlRdr["AcctDesc"]);

                    arrAccounts.Add(accountListItem);
                }

                sqlRdr.Close();

                return arrAccounts;
            }
            catch (Exception Exc)
            {
                Information clsInfo = new Information();
                clsInfo.ErrNum = 5000;
                clsInfo.ErrStr = Exc.Message;
                clsInfo.ErrStack = Exc.StackTrace;
                throw new ApplicationException("Invalid Gender ID");
            }
            finally
            {
                if (!sqlRdr.IsClosed)
                    sqlRdr.Close();

                dbRdr.Dispose();
                db.Dispose();
            }

        }

