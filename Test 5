public void LoadPaths(DataTable dataTable, ref string fileName, ref string templatefileFullName, ref string confFilePath, int? reportId = null)
{
    try
    {
        string incFilePath = Path.GetFullPath(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..\\"));
        string templateFilePath = System.Configuration.ConfigurationSettings.AppSettings["ReportTemplatePath"];

        //Get Template file name from DB
        string templatefileName = dataTable.Rows[0]["TemplateFileName"].ToString();

        //string templatefileFullName = Path.Combine(incFilePath, templateFilePath, "On_Loan_Balance_Report_Template.xlsx");
        templatefileFullName = Path.Combine(incFilePath, templateFilePath, templatefileName);

        //get File name from DB
        //string fileName = "OnLoanBalanceReport.xlsx";
        fileName = dataTable.Rows[0]["FileName"].ToString();
        DateTime toDate = DateTime.Now;
        if (dataTable.Columns.Contains("ToDate"))
        {
            toDate = Convert.ToDateTime(dataTable.Rows[0]["ToDate"].ToString());
        }
        fileName = GetFileNameNFormat(fileName, IsGeneric, FileType.ToLower(), toDate, reportId);

        confFilePath = GetReportConfirmationPath(Path.GetFileNameWithoutExtension(fileName));
    }
    catch (Exception)
    {

        throw;
    }
}






public virtual string GetFileNameNFormat(string fileName, bool isGeneric, string fileType, DateTime toDate, int? reportId = null)
{
    string fileNameNFormat = string.Empty;
    var date = string.Empty;
    var pattern = @"\[(.*?)\]";

    if (isGeneric == false && ReportSource == Source.Package)
    {
        /*
        var fileNDateFormat = fileName.Split('[', ']');

        if (fileNDateFormat.Length > 1)
        {
            if (string.IsNullOrWhiteSpace(fileNDateFormat[1]) == false)
            {
                if (!fileNDateFormat[1].Contains("F") && fileNDateFormat.Length > 3)
                {
                    fileNDateFormat[1] = fileNDateFormat[1].ToLower().Replace("m", "M");
                    date = toDate.ToString(fileNDateFormat[1]);
                    DateTime dateTime;
                    if (DateTime.TryParseExact(date, fileNDateFormat[1], CultureInfo.InvariantCulture, DateTimeStyles.None, out dateTime))
                        fileNameNFormat = date + fileNDateFormat[2] + fileType;
                }
                else
                    fileNameNFormat = fileNDateFormat[0] + fileType;
            }
            else
                fileNameNFormat = fileNDateFormat[2] + fileType;
        }
        else
            fileNameNFormat = fileNDateFormat[0] + "." + fileType;
            */
        if (Regex.IsMatch(Path.GetFileNameWithoutExtension(fileName), pattern))
        {
            var fileNDateFormat = Regex.Matches(Path.GetFileNameWithoutExtension(fileName), pattern)[0].Groups[1].Value.ToLower().Replace("m", "M");
            date = toDate.ToString(fileNDateFormat);
            DateTime dateTime;
            if (DateTime.TryParseExact(date, fileNDateFormat, CultureInfo.InvariantCulture, DateTimeStyles.None, out dateTime))
                fileNameNFormat = Regex.Replace(Path.GetFileNameWithoutExtension(fileName), pattern, date) + "." + fileType;
        }
        else
            fileNameNFormat = Path.GetFileNameWithoutExtension(fileName) + "." + fileType;
    }
    else if (isGeneric == false && ReportSource == Source.UI)
    {
        /*
        var fileNDateFormat = fileName.Split('[', ']');
        if (fileNDateFormat.Length > 1)
        {
            if (!fileNDateFormat[1].Contains("F") && fileNDateFormat.Length > 3)
                fileNameNFormat = toDate.ToString("yyyyMMdd") + fileNDateFormat[2].TrimStart() + fileType;
            else
                fileNameNFormat = toDate.ToString("yyyyMMdd") + fileNDateFormat[0].TrimStart() + fileType;
        }
        else
            fileNameNFormat = toDate.ToString("yyyyMMdd") + fileNDateFormat[0] + "." + fileType;
            */
        if (Regex.IsMatch(Path.GetFileNameWithoutExtension(fileName), pattern))
            fileNameNFormat = Regex.Replace(Path.GetFileNameWithoutExtension(fileName), pattern, toDate.ToString("yyyyMMdd")) + "." + fileType;
        else
            fileNameNFormat = toDate.ToString("yyyyMMdd") + Path.GetFileNameWithoutExtension(fileName) + "." + fileType;
    }
    else
    {
        //fileNameNFormat = "Mobetter_" + fileName + "_" + DateTime.Now.ToString("MMddyyyy") + "." + fileType;
        var appName = Globals.appInfo.Where(m => m.AppID == AppID).Select(m => m.AppName).ToList()[0];
        fileNameNFormat = (reportId == 237) ? toDate.ToString("yyyyMMdd") + "_" + fileName + "." + fileType : toDate.ToString("yyyyMMdd") + "_" + appName + "_" + fileName + "." + fileType;
    }

    return fileNameNFormat;
}
