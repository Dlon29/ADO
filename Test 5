        private DataTable GetTable(string sIdentifier, string[] sqlCondition)
        {
            Database db = new Database();
            DataReader dbRdr = new DataReader();
            DataTable dataTable = new DataTable("dt");

            try
            {
                if (db.Open() == false)
                    return (DataTable)null;

                dbRdr.Connection = db.Connection;
                dbRdr.StoredProcedure = SqlObjectsStaticClass.p_GetData_Reports;
                dbRdr.SqlIdentifier = sIdentifier;

                dbRdr.GetData(ref dataTable, sqlCondition);
                return dataTable;

            }
            catch (Exception Exc)
            {
                Information clsInfo = new Information();
                clsInfo.ErrNum = 5000;
                clsInfo.ErrStr = Exc.Message;
                clsInfo.ErrStack = Exc.StackTrace;
                Server.Transfer(errPage, true);
                return (DataTable)null;
            }
            finally
            {
                dataTable.Dispose();
                dbRdr.Dispose();
                db.Dispose();
            }
        }

