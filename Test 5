ReportPath IGenerateReportBLL.GenerateReport(int reportID, DateTime batchRunDate, string fileType, string source, SourceInfo sourceInfo, int appID, List<ReportRequestParams> requestParams)
{

    try
    {
        string ReportPath = string.Empty;
        ReportSource = (Source)Convert.ToInt32(source);
        FileType = fileType;
        if (ReportSource == Source.Package)
        { PackagePath = sourceInfo.SourceInformation; }
        AppID = appID;
        ReportID = reportID;
        DataSet ObjSqlDataSet = new DataSet();

        IsGeneric = true;
        if (fileType.ToUpper() == Filetype.pdf.ToString().ToUpper())
        {
            //Note: Getting template file name and package filene. Generic SP of any application will require SQL_IDENTIFIER (in order to get report details)
            if (_ObjGenericReportDAL.GetReportInformation(reportID, batchRunDate, ref ObjSqlDataSet, fileType.ToUpper(), source, appID, new List<ReportRequestParams> { new ReportRequestParams { ParamName = "SQL_IDENTIFIER", ParamType = "string", ParamValue = "GET_REPORT_DETAILS" } }))
            {
                ReportPath = BuildPDF(ObjSqlDataSet, reportID, batchRunDate, source, true, requestParams);
            }
        }
        else if (_ObjGenericReportDAL.GetReportData(reportID, batchRunDate, ref ObjSqlDataSet, fileType, source, appID, requestParams))
        {
            if ((fileType.ToUpper() == Filetype.xlsx.ToString().ToUpper()) || (fileType.ToUpper() == Filetype.xls.ToString().ToUpper()))
                ReportPath = BuildWorkBook(ObjSqlDataSet, reportID);
            else if (fileType.ToUpper() == Filetype.csv.ToString().ToUpper())
                ReportPath = BuildCSV(ObjSqlDataSet);

        }

        //return ReportPath;
        return new Shared.Infrastructure.ReportPath { ReportFile = ReportFileName, ReportFolderPath = ReportFolderPath };
    }
    catch (Exception ex)
    {
        _logger.ErrorFormat("Exception occured while generating Report. ReportSetupID: {0}. Error: " + ex, reportID.ToString());
        throw;
    }

}








