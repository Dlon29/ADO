        public static void WriteIncFiles(string Section, string Page)
        {
            string jsFile = "";
            string cssFile = "";
            string incFilePath = @"/" + _appRoot;
            //string incFilePath = @"\\" + _serverName + @"\stbusa app runtime files\Intra-Net\" + _appRoot ;
            //string incFilePath = @"C:\stbusa app runtime files\Intra-Net\" + _appRoot;

            try
            {
                //First, write out the common inc files
                cssFile = incFilePath + @"/StyleSheets/Common.css";
                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(cssFile)));

                cssFile = incFilePath + @"/StyleSheets/Menu.css";
                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(cssFile)));


                jsFile = incFilePath + @"/JavaScript/Common.js";
                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(jsFile)));


                //Now write section-specific inc files
                switch (Section)
                {
                    case "Home":
                        //cssFile = incFilePath + @"/StyleSheets/Reports.css";
                        //jsFile = incFilePath + @"/JavaScript/Reports.js";
                        switch (Page)
                        {
                            case "Welcome":
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/WebFormCallBackSuport.js")));
                                break;
                        }
                        break;

                    case "Reports":
                        cssFile = incFilePath + @"/StyleSheets/Reports.css";
                        jsFile = incFilePath + @"/JavaScript/Reports.js";
                        switch (Page)
                        {
                            case "Customer Reports":
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/WebFormCallBackSuport.js")));
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/CustReports.js")));
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/CustReportsNew.js")));
                                break;
                            case "Business Reports":
                            case "Misc Reports":
                            case "Management Reports":
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/WebFormCallBackSuport.js")));
                                break;
                            case "Report Packages":
                                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/CustReportsNew.js")));
                                break;
                        }
                        break;

                    case "Processed Data":
                        cssFile = incFilePath + @"/StyleSheets/ProcData.css";
                        jsFile = incFilePath + @"/JavaScript/ProcData.js";
                        break;

                    case "Maintenance":
                        cssFile = incFilePath + @"/StyleSheets/Maintenance.css";
                        jsFile = incFilePath + @"/JavaScript/Maintenance.js";
                        HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(incFilePath + @"/JavaScript/CustReportsNew.js")));
                        break;

                    case "Admin":
                        cssFile = incFilePath + @"/StyleSheets/Admin.css";
                        jsFile = incFilePath + @"/JavaScript/Admin.js";
                        break;

                    case "Manual Entry":
                        cssFile = incFilePath + @"/StyleSheets/MnlEntry.css";
                        jsFile = incFilePath + @"/JavaScript/MnlEntry.js";
                        break;

                    case "Portal":
                        cssFile = incFilePath + @"/StyleSheets/StyleSheet.css";
                        jsFile = incFilePath + @"/JavaScript/AllScript.js";
                        break;

                }

                HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(cssFile)));
                if (Page != "Report Parameters")
                    HttpContext.Current.Response.Write(ReadIncFiles(HttpContext.Current.Server.MapPath(jsFile)));
            }

            catch
            {
                HttpContext.Current.Response.Write("Error reading File<br>");
                return;
            }
        }

        public static string ReadIncFiles(string sFileName)
        {
            string s = "";
            StreamReader sr = null;

            try
            {
                sr = new StreamReader(sFileName);
                s = sr.ReadToEnd() + "\n";
                return s;
                //HttpContext.Current.Response.Write(s);				
            }

            catch (Exception e)
            {
                return e.Message.ToString();
            }
            finally
            {
                sr.Close();
            }

        }

