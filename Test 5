                        batchRunDate = this.txtStartDate3.Text;
                        Session["_batchRunDate8_miscReports"] = batchRunDate;
                        GetAccountList(8);
                        break;

                }

                return;
            }

            if (!IsReport)
            {
                ExtractReport();
                return;
            }

            //By default, each users have their own directory by their userid under 
            //\STBUSA APP FILES\INTRA-NET\MOBETTER\Temp\. Also, each day a directory will be
            //created by the MM-DD-YYYY format. All the reports will be under this directory. 

            FileSystem fs = new FileSystem();

            string datePart = Common.FormatDate(batchRunDate, "MM-dd-yyyy");
            string sPath = SaveLocRoot + clsUI.NTUserName + @"\" + datePart + @"\";

            if (fs.CreateDir(sPath) == false)
            {
                Information errorInfo = new Information();
                errorInfo.ErrNum = 5000;
                errorInfo.ErrStr = "Unable to create a report.";
                errorInfo.ErrStack = "Process Reports";
                Server.Transfer(errPage, true);
                return;
            }

            MOBETTER.ReportDriver reportDriver = new MOBETTER.ReportDriver();
            reportDriver.ExportPath = sPath;

            try
            {
                string sXportPath, rPath;
                bool reportSuccess = false;

                switch (_SelectedImgButtonId)
                {
                    case "REPORT1":			// recon status 
                        reportSuccess = reportDriver.ReconErrorList(_SelectedReportTitle, batchRunDate);
                        break;

                    case "REPORT2":			// report recon errors
                        reportSuccess = reportDriver.Reconciliation(_SelectedReportTitle, batchRunDate, _SelectedReportId);
                        break;

                    case "REPORT3":			// Lending Earnings
                        reportSuccess = reportDriver.LendingEarnings(_SelectedReportTitle, _strXMLAcctSet, startDate, endDate, cboRepType3.SelectedValue, Convert.ToInt16(cboTermRepo.SelectedValue), chkShowFICCAsBroker.Checked);
                        break;

                    case "REPORT4":			// Security On Loan
                        reportSuccess = reportDriver.SecurityOnLoan("", batchRunDate, 0, cboAcctNbr4.SelectedValue);
                        break;

                    case "REPORT5":			// Percent On Loan
                        reportSuccess = reportDriver.PercentOnLoan("", batchRunDate, 0, cboAcctNbr5.SelectedValue, cboSecType5.SelectedValue, chkIsExclusive5.Checked);
                        break;
                    case "REPORT6":
                        Hashtable htMain = new Hashtable();

                        htMain.Add("@FileName", new Hashtable());
                        ((Hashtable)htMain["@FileName"]).Add("Value", "BOJReport");
                        ((Hashtable)htMain["@FileName"]).Add("IsReportParameter", false);
                        htMain.Add("@ReportTemplateFileName", new Hashtable());
                        ((Hashtable)htMain["@ReportTemplateFileName"]).Add("Value", "BOJReport.rpt");
                        ((Hashtable)htMain["@ReportTemplateFileName"]).Add("IsReportParameter", false);
                        htMain.Add("@AcctNbr", new Hashtable());
                        ((Hashtable)htMain["@AcctNbr"]).Add("Value", cboAcctNbr6.SelectedValue);
                        ((Hashtable)htMain["@AcctNbr"]).Add("IsReportParameter", true);
                        htMain.Add("@AcctTypeBankTrust", new Hashtable());
                        ((Hashtable)htMain["@AcctTypeBankTrust"]).Add("Value", cboAcctType6.SelectedValue == "-1" ? null : cboAcctType6.SelectedValue);
                        ((Hashtable)htMain["@AcctTypeBankTrust"]).Add("IsReportParameter", true);
                        htMain.Add("@PeriodDateBegin", new Hashtable());
                        ((Hashtable)htMain["@PeriodDateBegin"]).Add("Value", System.Convert.ToDateTime(txtStartDate6.Text));
                        ((Hashtable)htMain["@PeriodDateBegin"]).Add("IsReportParameter", true);
                        htMain.Add("@PeriodDateEnd", new Hashtable());
                        ((Hashtable)htMain["@PeriodDateEnd"]).Add("Value", System.Convert.ToDateTime(txtEndDate6.Text));
                        ((Hashtable)htMain["@PeriodDateEnd"]).Add("IsReportParameter", true);
                        htMain.Add("@IsReconciliation", new Hashtable());
                        ((Hashtable)htMain["@IsReconciliation"]).Add("Value", this.chkReconcile6.Checked);
                        ((Hashtable)htMain["@IsReconciliation"]).Add("IsReportParameter", true);

                        reportSuccess = reportDriver.CreateReport(ref htMain);
                        break;
                }

                if (!reportSuccess)
                {
                    string ErrStr = null;
                    if (reportDriver.Errors.Count > 0)
                    {
                        ErrStr = reportDriver.Errors[0].Message;
                    }

                    throw new Exception(ErrStr); //"Error in creating report: " + ReportTitle) ;
                }

                sXportPath = reportDriver.ExportedFile;
                rPath = @"/" + GlobalVariable.AppRoot + "/DocumentViewer.aspx?docTitle=" + _SelectedReportTitle + "&docName=" + sXportPath + "&docType=pdf";

                GlobalVariable._gsReportsTab = "tabProcReports";
                _PrintUrl = rPath;
            }

            catch (Exception ex)
            {
                Information exceptionInfo = new Information();
                exceptionInfo.ErrNum = 5000;
                exceptionInfo.ErrStr = ex.Message + "<br>Error in creating report " + _SelectedReportTitle;
                exceptionInfo.ErrStack = ex.StackTrace;
                exceptionInfo.WindowStyle = "Popup";
                Server.Transfer(errPage, true);
                return;
            }
            finally
            {
                reportDriver.Dispose();
                reportDriver = null;
            }
        }

