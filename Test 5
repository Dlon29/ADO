        function OnChange_MTMAsOfDate(sender)
{
    if ( sender == null )  { return ; }
    
    
        var trf_outsource_reporting_overwrite_param = document.getElementById('trf_outsource_reporting_overwrite_param');
    if ( trf_outsource_reporting_overwrite_param == null )  { return ; }
    
        var parsedAsOfDate =  new Date(Date.parse(sender.value)) ;
        if ( parsedAsOfDate == 'NaN' )
    {
            trf_outsource_reporting_overwrite_param.disabled = true;
        return false;
    }

    var currentDate = new Date();
    trf_outsource_reporting_overwrite_param.disabled = !((parsedAsOfDate.getMonth() == currentDate.getMonth()) &&
                                                        (parsedAsOfDate.getDate() == currentDate.getDate())   &&
                                                        (parsedAsOfDate.getFullYear() == currentDate.getFullYear()));
}


function OnKeyDown_MTMAsOfDate(sender)
{
    if ( sender == null )  { return ; }
        OnChange_MTMAsOfDate(sender);
    }
    
    
    function ShowTradeConfirmReport(sender)
{
    try
        { 
        var reportTitle = 'TRADE CONFIRMATION REPORT';
        var reportType = 'TradeConfirmationReportSection';
        var batchRunDate = $("#txtBatchRunDate7").val();
        var reportID = $("#cboAcctNbr7").val();
        var acctNbr='';
        var brkGrpCode = $("#cboBrkGrpCode7").val();
        //var isExtract =  $("#rbRenderTradeConfirmationAsExtract").attr("checked");
        var isExtract =  false;

        $("input[type=hidden][name$='_reportType']").val(reportType);

        if (isDate(batchRunDate) == false){
            alert("Please enter the valid date. The format is mm/dd/yyyy") ;
        $("#txtBatchRunDate7").focus();
        return false;
    }
    
    switch (reportID)
        {
           
            case '201':
            reportTitle = 'TRADE CONFIRMATION REPORT - TRF';
            break;
        case '234':
            reportTitle = 'BP Loan Extract';
            isExtract = true;
            break;
        case '236':
            reportTitle = 'Trade Confirmation Report – Own Repo';
            break;
        case '561':
            reportID = 561;//Trade Confirmation Report – Reverse  Repo
            reportTitle = 'Trade Confirmation Report – Reverse  Repo';
            break;
        //default:
        //    reportID = 101;
        //    break;
    }

    if (isExtract)
        {
            $("input[type=hidden][name$='_IsExtract']").val('true');
        $("input[type=hidden][name$='_reportId']").val(reportID);
        $("input[type=hidden][name$='_reportTitle']").val(reportTitle);
        $("input[type=hidden][name$='_BatchRunDate']").val(batchRunDate);
        $("input[type=hidden][name$='_AcctNbr']").val(acctNbr);
        $("input[type=hidden][name$='_BrkGrpCode']").val(brkGrpCode);
        $("#Reports").submit();
        return;
    }
    else
        {
            $("input[type=hidden][name$='_IsExtract']").val('false');
        }

        var attribs = "width=800,height=600,scrollbars,resizable";
        var loc = "/MoBetter/Reports/CustReports.aspx?_openStyle=PopUp";
        loc += "&_reportId=" + reportID;
        loc += "&_reportType=" + reportType;
        loc += "&_reportTitle=" + reportTitle;
        loc += "&batchRunDate=" + batchRunDate;
        loc += "&acctNbr=" + acctNbr;
        loc += "&brkGrpCode=" + brkGrpCode;

        PopUpWindow(loc,'',attribs);
    }
    catch (ex)
    {
        throw ex;
    }
}



</script>






