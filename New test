CREATE PROCEDURE [dbo].[p_SaveData_CashPaymentApprovals]
(		
	@Command			VARCHAR(MAX),			
	@AsOfDate			DATETIME,
	@CashPaymentList	VARCHAR(MAX) = '',
	@ModifiedBy			VARCHAR(50),
	@DashboardIdentifier INT	= 1	       --1 - Cash Movement Dashboard, 2 - Euroclear Cash Movement Dashboard
)
AS
BEGIN
	
	SET NOCOUNT ON		

	DECLARE @hdoc INT
	DECLARE @DTC_SECTIONID AS INT
	DECLARE @COMMAND_MWINPUT_SIGN AS VARCHAR(MAX)
	DECLARE @COMMAND_MWINPUT_UNSIGN AS VARCHAR(MAX)
	DECLARE @COMMAND_MWAPPROVE_SIGN AS VARCHAR(MAX)
	DECLARE @COMMAND_MWAPPROVE_UNSIGN AS VARCHAR(MAX)
	DECLARE @COMMAND_PAYMENT_APPROVE AS VARCHAR(MAX)
	DECLARE @COMMAND_SEND_SPOCHARGE AS VARCHAR(MAX)
	DECLARE @Error_Msg AS VARCHAR(MAX)
	DECLARE @EUROCLEAR_IDENTIFIER INT = 2

	SET @COMMAND_MWINPUT_SIGN = 'MoneyWireInputSign'
	SET @COMMAND_MWINPUT_UNSIGN = 'MoneyWireInputUnSign'
	SET @COMMAND_MWAPPROVE_SIGN = 'MoneyWireApproveSign'
	SET @COMMAND_MWAPPROVE_UNSIGN = 'MoneyWireApproveUnSign'
	SET @COMMAND_PAYMENT_APPROVE = 'PaymentApprove'
	SET @COMMAND_SEND_SPOCHARGE = 'SendSPOCharge'

	SELECT @DTC_SECTIONID = dbo.f_GetDomainLookupValue('CashMovementSections', 'DTC')	

	EXEC SP_XML_PREPAREDOCUMENT @hdoc OUTPUT, @CashPaymentList			

	/* Insert selected cash payment(xml) for approvals into #TMP_CASH_PAYMENT*/						
	IF OBJECT_ID('tempdb..#TMP_CASH_PAYMENT') IS NULL 
	BEGIN
		SELECT *
		INTO #TMP_CASH_PAYMENT				
		FROM 			
			OPENXML(@hdoc, '/CashPaymentList/CashPayment', 1)
			WITH
			(	
				SectionID				INT,											
				[Description]			VARCHAR(MAX),
				ProductID				INT,
				BrkNbr					VARCHAR(6),
				CashWireCode			VARCHAR(10),
				DTCCode					VARCHAR(20),
				DebitAccount			VARCHAR(100),			
				ApprovedPayableFrom		DECIMAL(20,2),
				ApprovedPayableTo		DECIMAL(20,2),			
				IsApproved				BIT,			
				CashPaymentApprovedBy	VARCHAR(50),
				MoneyWireInputBy		VARCHAR(50),
				MoneyWireApprovedBy		VARCHAR(50),
				IsSPOEmailSent			BIT,
				EmailSentBy				VARCHAR(50),
				Remarks					VARCHAR(100),
				IsEuroclear				BIT
			)
	END
	EXEC SP_XML_REMOVEDOCUMENT @hdoc

	IF(@Command = @COMMAND_MWINPUT_SIGN)
	BEGIN
		IF EXISTS(SELECT 1 FROM CashMovementApprovals TBL_CMA 
				 WHERE EXISTS(
								SELECT ID 
								FROM #TMP_CASH_PAYMENT TMP_CP 
								WHERE 
								(TBL_CMA.SectionID = TMP_CP.SectionID)  AND		
								(
									( 
									     (LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TBL_CMA.Description))) AND
										(
											(TBL_CMA.ProductID <> 0 AND TBL_CMA.ProductID = TMP_CP.ProductID )	
											OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TBL_CMA.CashWireCode,'') )
											OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TBL_CMA.BrkNbr,'') ) )
										)
									)												 
									AND 								
									(TBL_CMA.BrkNbr = TMP_CP.BrkNbr)	 						
								) 
								AND
								(TBL_CMA.AsOfDate = @AsOfDate) AND
								(ISNULL(TBL_CMA.MoneyWireInputBy,'') <> '')
								AND
								(TBL_CMA.IsEuroclear = CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END) --OR NULL
							 )
					)
		BEGIN
			SET @Error_Msg = 'Money Wire Input already signed in by different user.Please refresh dashboard.'
			RAISERROR (@Error_Msg, 16, 1)
			RETURN 1
		END
	END
	
	IF(@Command = @COMMAND_MWINPUT_UNSIGN OR @Command = @COMMAND_MWAPPROVE_SIGN)
	BEGIN
		IF EXISTS(SELECT 1 FROM CashMovementApprovals TBL_CMA 
				 WHERE EXISTS(
								SELECT ID 
								FROM #TMP_CASH_PAYMENT TMP_CP 
								WHERE 
								(TBL_CMA.SectionID = TMP_CP.SectionID)  AND		
								(
									( LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TBL_CMA.Description))) AND
									(
										(TBL_CMA.ProductID <> 0 AND TBL_CMA.ProductID = TMP_CP.ProductID)
										OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TBL_CMA.CashWireCode,''))
										OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TBL_CMA.BrkNbr,'') ) )
									)			 
									AND 								
									(TBL_CMA.BrkNbr = TMP_CP.BrkNbr)	 						
								) 
								AND
								(TBL_CMA.AsOfDate = @AsOfDate) AND
								(ISNULL(TBL_CMA.MoneyWireApprovedBy,'') <> '')
								AND
								(TBL_CMA.IsEuroclear = CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END) --OR NULL
							 )
					)
		BEGIN
			SET @Error_Msg = 'Money Wire Input is already approved by different user.Please refresh dashboard.'
			RAISERROR (@Error_Msg, 16, 1)
			RETURN 1
		END
	END
	
	IF(@Command = @COMMAND_PAYMENT_APPROVE)
	BEGIN
		IF EXISTS(SELECT 1 FROM CashMovementApprovals TBL_CMA 
				 WHERE EXISTS(
								SELECT ID 
								FROM #TMP_CASH_PAYMENT TMP_CP 
								WHERE 
								(TBL_CMA.SectionID = TMP_CP.SectionID)  AND		
								(
								(  LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TBL_CMA.Description))) AND
									(
										(TBL_CMA.ProductID <> 0 AND TBL_CMA.ProductID = TMP_CP.ProductID)
										OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TBL_CMA.CashWireCode,'') )
										OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TBL_CMA.BrkNbr,'') ) )
									)		 
									AND 								
									(TBL_CMA.BrkNbr = TMP_CP.BrkNbr)	 						
								) 
								AND
								(TBL_CMA.AsOfDate = @AsOfDate) AND
								(ISNULL(TBL_CMA.IsApproved,'0') = 1)
								AND
								(TBL_CMA.IsEuroclear = CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END) --OR NULL
							 )
					)
		BEGIN
			SET @Error_Msg = 'For some of the selected transactions, cash payment is already approved.Please refresh dashboard.'
			RAISERROR (@Error_Msg, 16, 1)
			RETURN 1
		END
	END		

	IF(@Command = @COMMAND_SEND_SPOCHARGE) --TODO Need To Verify
	BEGIN
		IF EXISTS(SELECT 1 FROM CashMovementApprovals TBL_CMA 
				 WHERE EXISTS(
								SELECT ID 
								FROM #TMP_CASH_PAYMENT TMP_CP 
								WHERE 
								(TBL_CMA.SectionID = TMP_CP.SectionID)  AND		
								(
									(TBL_CMA.ProductID = TMP_CP.ProductID)			 
									AND 								
									(TBL_CMA.BrkNbr = TMP_CP.BrkNbr)	 						
								) AND
								(TBL_CMA.AsOfDate = @AsOfDate) AND
								(ISNULL(TBL_CMA.IsSPOEmailSent,'0') = 1)
							 )
					)
		BEGIN
			SET @Error_Msg = 'SPO Charge email is already sent for the selected transaction.Please refresh dashboard.'
			RAISERROR (@Error_Msg, 16, 1)
			RETURN 1
		END
	END	

	IF EXISTS ( SELECT TCMA.* 
				FROM CashMovementApprovals AS TCMA
				INNER JOIN #TMP_CASH_PAYMENT AS TMP_CP
				ON  (TCMA.SectionID = TMP_CP.SectionID)  AND		
					(
						( LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TCMA.Description))) AND
						(
							(TCMA.ProductID <> 0 AND TCMA.ProductID = TMP_CP.ProductID)
							OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TCMA.CashWireCode,''))
							OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TCMA.BrkNbr,'') ) )
						)		 
						AND 								
						(TCMA.BrkNbr = TMP_CP.BrkNbr)	 						
					) 
					AND	
				    (TCMA.AsOfDate = @AsOfDate)
					AND
					(TBL_CMA.IsEuroclear = CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END) ) --OR NULL
					
	BEGIN 

		/*If selected cash payments exists in CashMovementApproval table, Insert records into history table and delete/update the records */
		INSERT INTO dbo.CashMovementApprovalsHist
		(
			[ID],[AsOfDate],[SectionID],[Description],[ProductID],
			[BrkNbr],[CashWireCode],[DTCCode],[DebitAccount],[IsFICC],
			[ClearAgentNbr],[ApprovedPayableFrom],[ApprovedPayableTo],
			[IsApproved],[CashPaymentApprovedBy],
			[MoneyWireInputBy],[MoneyWireApprovedBy],
			[IsSPOEmailSent],[EmailSentBy],
			[Remarks],[ModifiedBy],[ModifiedDate],[IsEuroclear]
		)
		SELECT
			TCMA.[ID],TCMA.[AsOfDate],TCMA.[SectionID],TCMA.[Description],TCMA.[ProductID],
			TCMA.[BrkNbr],TCMA.[CashWireCode],TCMA.[DTCCode],TCMA.[DebitAccount],TCMA.[IsFICC],
			TCMA.[ClearAgentNbr],TCMA.[ApprovedPayableFrom],TCMA.[ApprovedPayableTo],
			TCMA.[IsApproved],TCMA.[CashPaymentApprovedBy],
			TCMA.[MoneyWireInputBy],TCMA.[MoneyWireApprovedBy],
			TCMA.[IsSPOEmailSent],TCMA.[EmailSentBy],
			TCMA.[Remarks],TCMA.[ModifiedBy],TCMA.[ModifiedDate],[IsEuroclear]
		FROM 
			dbo.CashMovementApprovals AS TCMA 
			INNER JOIN dbo.#TMP_CASH_PAYMENT AS TMP_CP
			ON  ( TCMA.SectionID = TMP_CP.SectionID ) AND		
				( 
					( LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TCMA.Description))) AND
					(
						(TCMA.ProductID <> 0 AND TCMA.ProductID = TMP_CP.ProductID)
						OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TCMA.CashWireCode,''))
						OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TCMA.BrkNbr,'') ) )
					)		 
					AND 								
					(TCMA.BrkNbr = TMP_CP.BrkNbr)	 						
				)
				AND	
				( TCMA.AsOfDate = @AsOfDate )
				AND
				( TBL_CMA.IsEuroclear = CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END ) --OR NULL


		/* Update existing records in CashMovementApprovals table. Update will be executed only if record exists. */
		UPDATE 
			TCMA
		SET
			TCMA.IsApproved = TMP_CP.IsApproved,
			TCMA.ApprovedPayableFrom = TMP_CP.ApprovedPayableFrom, 
			TCMA.ApprovedPayableTo = TMP_CP.ApprovedPayableTo, 		
			TCMA.CashPaymentApprovedBy = TMP_CP.CashPaymentApprovedBy,
			TCMA.MoneyWireInputBy = TMP_CP.MoneyWireInputBy,
			TCMA.MoneyWireApprovedBy = TMP_CP.MoneyWireApprovedBy,
			TCMA.EmailSentBy = (CASE WHEN 
										( TMP_CP.SectionID = @DTC_SECTIONID AND TMP_CP.IsSPOEmailSent =  1) 
									 THEN @ModifiedBy 
									 ELSE TCMA.EmailSentBy END),
			TCMA.IsSPOEmailSent = TMP_CP.IsSPOEmailSent,
			TCMA.ModifiedBy = @ModifiedBy,
			TCMA.ModifiedDate = GETDATE()
		FROM 
			dbo.CashMovementApprovals AS TCMA 		
			INNER JOIN dbo.#TMP_CASH_PAYMENT AS TMP_CP
			ON  ( TCMA.SectionID = TMP_CP.SectionID ) AND		
				(
				( LTRIM(RTRIM(TMP_CP.Description)) = LTRIM(RTRIM(TCMA.Description))) AND
					(
						(TCMA.ProductID <> 0 AND TCMA.ProductID = TMP_CP.ProductID)
						OR ( ISNULL(TMP_CP.BrkNbr,'') = '' AND  ISNULL(TMP_CP.CashWireCode,'') = ISNULL(TCMA.CashWireCode,''))	
						OR ((ISNULL(TMP_CP.BrkNbr,'') != '' ) AND (ISNULL(TMP_CP.BrkNbr,'') = ISNULL(TCMA.BrkNbr,'') ) )
					)		 
					AND 								
					(TCMA.BrkNbr = TMP_CP.BrkNbr)	 						
				) 
				AND	
				( TCMA.AsOfDate = @AsOfDate )
				AND
					(TBL_CMA.IsEuroclear = (CASE WHEN @DashboardIdentifier = @EUROCLEAR_IDENTIFIER THEN 1 ELSE 0 END)) --OR NULL
	END
	ELSE 
	BEGIN
		/* Insert cash payments into CashMovementApprovals table for new approvals*/
		INSERT INTO dbo.CashMovementApprovals
		(
			[AsOfDate],[SectionID],[Description],[ProductID],
			[BrkNbr],[CashWireCode],[DTCCode],[DebitAccount],
			[ApprovedPayableFrom],[ApprovedPayableTo],
			[IsApproved],[CashPaymentApprovedBy],
			[MoneyWireInputBy],[MoneyWireApprovedBy],
			[IsSPOEmailSent],[EmailSentBy],
			[Remarks],[ModifiedBy],[ModifiedDate],[IsEuroclear]
		)
		SELECT 
			@AsOfDate,[SectionID],[Description],[ProductID],
			[BrkNbr],[CashWireCode],[DTCCode],[DebitAccount],
			[ApprovedPayableFrom],[ApprovedPayableTo],
			[IsApproved],[CashPaymentApprovedBy],
			[MoneyWireInputBy],[MoneyWireApprovedBy],
			[IsSPOEmailSent],@ModifiedBy,
			[Remarks],@ModifiedBy,GETDATE(),[IsEuroclear]
		FROM 			
			#TMP_CASH_PAYMENT AS TMP_CP	
	END

	SET NOCOUNT OFF
END
