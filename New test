        /// <summary>
        /// Get record details
        /// </summary>
        /// <returns></returns>
        private bool GetRecords()
        {
            DataSet objDS = new DataSet();
            PagedDataSource objPagedDS = new PagedDataSource();


            STBUSA.Utility.IGlobalVariable gv = new GlobalVariable();
            STBUSA.Data.DataBase clsDB = null;
            STBUSA.Data.DataCommand clsCmd = null;
            MethodName = "GetRecords()";

            try
            {
                clsDB = new STBUSA.Data.DataBase(ref gv);
                clsCmd = new STBUSA.Data.DataCommand(ref clsDB);

                if (clsDB.Open() == false)
                    return false;

                DataReader clsReader = new DataReader();
                clsReader.Connection = clsDB.Connection;

                string[] SqlCondition = new string[13] { "", "", "", "", "", "", "", "", "", "", "", "", "" };

                SqlCondition[0] = parentScreen == "SecLendDashboard" ? _TxnRefNbrList : txtTxnRefNbr.Text;
                SqlCondition[1] = parentScreen == "SecLendDashboard" ? "0" : ddlBrokerCrGroup.SelectedValue;
                SqlCondition[2] = parentScreen == "SecLendDashboard" ? "0" : ddlBrokerGroup.SelectedValue;
                SqlCondition[3] = parentScreen == "SecLendDashboard" ? "0" : ddlBroker.SelectedValue;
                SqlCondition[4] = txtSecCode.Text;
                SqlCondition[5] = ddlBasketIdentifier.SelectedValue;
                SqlCondition[6] = ddlSecType.SelectedValue;
                SqlCondition[7] = ddlFinder.SelectedValue;
                SqlCondition[8] = ddlProductCategory.SelectedValue;
                SqlCondition[9] = parentScreen == "SecLendDashboard" ? "1" : (chkTermLoan2.Checked ? "1" : "0");
                SqlCondition[10] = parentScreen == "SecLendDashboard" ? "1" : (chkDivArbLoan2.Checked ? "1" : "0");
                SqlCondition[11] = parentScreen == "SecLendDashboard" ? "1" : (chkScripLoan2.Checked ? "1" : "0");
                SqlCondition[12] = cboSrchTransmitFlag.SelectedValue;

                if (clsReader.GetData(ref objDS, SqlObjects.p_GetData_ETI_CloseRebookLoansandCollaterals, SqlCondition) == false)
                {
                    return false;
                }

                objPagedDS.DataSource = objDS.Tables[0].DefaultView;
                objPagedDS.AllowPaging = true;

                if (objPagedDS.DataSourceCount < _PAGESIZE)
                    objPagedDS.PageSize = objPagedDS.DataSourceCount;
                else
                    objPagedDS.PageSize = _PAGESIZE;

                // delete the last page record contains only one record
                // will load pageN - 1
                if (_PageNo > objPagedDS.PageCount)
                    _PageNo = objPagedDS.PageCount;

                if (_PageNo <= 0)
                    _PageNo = 1;

                objPagedDS.CurrentPageIndex = _PageNo - 1;
                _TotPage = objPagedDS.PageCount;

                if (objPagedDS.Count == 0)
                {
                    _PageNo = 0;
                    _TotPage = 0;
                }

                PageNofM = _PageNo.ToString() + " of " + _TotPage.ToString();

                if (objPagedDS.Count > 0)
                {

                    grdCloseReBookLoanRecords.DataSource = objPagedDS;
                    grdCloseReBookLoanRecords.DataBind();
                    pnlMsg.Visible = false;

                    if (_AccessTypeCode == "F")
                    {
                        btnBookLoanFooter.Enabled = true;
                        btnBookLoan.Enabled = true;
                    }
                    else
                    {
                        btnBookLoanFooter.Enabled = false;
                        btnBookLoan.Enabled = false;
                    }
                }
                else
                {
                    pnlMsg.Visible = true;
                    grdCloseReBookLoanRecords.DataSource = null;
                    grdCloseReBookLoanRecords.DataBind();
                    btnBookLoanFooter.Enabled = false;
                    btnBookLoan.Enabled = false;
                }
            }
            catch (Exception Exc)
            {
                _ErrorString = new StringBuilder("");
                _ErrorString.Append(Exc.Message);
                _show_error_row = "";
                log.Debug(string.Format(ErrorMessageToLog, ModuleName, MethodName, Exc));
                return false;
            }
            finally
            {
                objPagedDS = null;
                objDS.Dispose();

                if (clsCmd != null)
                    clsCmd.Dispose();

                if (clsDB != null)
                    clsDB.Dispose();
            }
            return true;
        }

        /// <summary>
        /// This method will validate input
        /// </summary>
        /// <returns></returns>
        private bool ValidateInputs()
        {
            bool blnValidReq = false;
            bool InvalidSettlementDate = false;
            DataGridItem dgi = null;
            //Validation on Settlement Date
            MethodName = "ValidateInputs()";

            try
            {
                for (int iRowCount = 0; iRowCount < grdCloseReBookLoanRecords.Items.Count; iRowCount++)
                {
                    dgi = this.grdCloseReBookLoanRecords.Items[iRowCount];

                    TextBox txtSettlementDate = (TextBox)dgi.Cells[(int)grdMapping.SettleDate].FindControl("txtSettlementDate");
                    CheckBox chkInclude = (CheckBox)dgi.Cells[(int)grdMapping.chkInclude].FindControl("chkInclude");

                    if (chkInclude.Checked)
                    {
                        if (txtSettlementDate.Text.Trim() == string.Empty && InvalidSettlementDate == false)
                        {
                            _ErrorString.Append("<a href = \"javascript: document.forms[0].txtSetelmentDate.focus();\">\n");
                            _ErrorString.Append("\t" + Common.GetMessage("Common", "IncorrectSettlementDate") + "\n");
                            _ErrorString.Append("</a> <br>\n");
                            InvalidSettlementDate = true;
                        }
                        else if (InvalidSettlementDate == false && txtSettlementDate.Text.Trim().Length > 0 && Convert.ToDateTime(txtSettlementDate.Text.Trim()) < Convert.ToDateTime(_BussDate))
                        {
                            _ErrorString.Append("<a href = \"javascript: document.forms[0].txtSetelmentDate.focus();\">\n");
                            _ErrorString.Append("\t" + Common.GetMessage("Common", "SettlementDateLessThanBusDate") + "\n");
                            _ErrorString.Append("</a> <br>\n");
                            InvalidSettlementDate = true;
                        }

                        else if (InvalidSettlementDate == false && txtSettlementDate.Text != string.Empty)
                        {
                            if (Common.CheckHoliday(txtSettlementDate.Text))
                            {
                                _ErrorString.Append("\t" + Common.GetMessage("Common", "InvalidSettlementDate") + "\n");
                                _ErrorString.Append("</a> <br>\n");
                                InvalidSettlementDate = true;
                            }

                        }
                    }
                }
            }
            catch (Exception)
            {
                _ErrorString.Append("<a href = \"javascript: document.forms[0].txtSettleFromDate.focus();\">\n");
                _ErrorString.Append("\t" + Common.GetMessage("Common", "IncorrectSettlementDate") + "\n");
                _ErrorString.Append("</a> <br>\n");
            }


            if (_ErrorString.Length > 0)
            {                
                _show_error_row = "";               
                throw new Exception(_ErrorString.ToString());
            }
            else
            {                
                blnValidReq = true;
            }

            return blnValidReq;
        }

        /// <summary>
        /// This method will create loan xml
