    function ValidateOnSave() {

        var isError = false;
        var errorString = '';

        // Effective From Date
        var _MinEffectiveDateBegin = document.getElementById('hdnMinEffectiveDateBegin');
        var _OldEffectiveDateBegin = document.getElementById('hdnEffectiveDateBegin');
        var txtEffectiveDateBegin = document.getElementById('txtEffectiveDateBegin');

        if (txtEffectiveDateBegin != null && txtEffectiveDateBegin.value != '') {
            if (isDate(txtEffectiveDateBegin.value) == false) {// invalid date
                errorString += "\tPlease enter a valid 'Effective From Date'. The format is mm/dd/yyyy.</br>";
                txtEffectiveDateBegin.focus();
                isError = true;
            }

            // from date is controled by accountgroup, lendinglimitgroup
            if (_MinEffectiveDateBegin != null && _MinEffectiveDateBegin.value.length > 0) {
                if (toDate(txtEffectiveDateBegin.value) > toDate(_MinEffectiveDateBegin.value)) {
                    errorString += "\tEffective From Date' can not be less than " + _MinEffectiveDateBegin.value + "</br>";
                    isError = true;
                }
            }

            // from date is controled by accountgroup, lendinglimitgroup
            if (_OldEffectiveDateBegin != null && _OldEffectiveDateBegin.value.length > 0) {
                if (toDate(txtEffectiveDateBegin.value) < toDate(_OldEffectiveDateBegin.value)) {
                    errorString += "\t'Effective From Date' can not be less than " + _OldEffectiveDateBegin.value + "</br>";
                    isError = true;
                }
            }
        }
        else {
            errorString += "\tPlease enter 'Effective From Date'</br>";
            isError = true;
        }

        /* Effective To Date*/
        var txtEffectiveDateEnd = document.getElementById('txtEffectiveDateEnd');

        if (txtEffectiveDateEnd != null && txtEffectiveDateEnd.value != '') {
            if (txtEffectiveDateEnd.value != 'OPEN' && isDate(txtEffectiveDateEnd.value) == false) {// invalid date
                errorString += "\tPlease enter a valid 'Effective To Date'. The format is mm/dd/yyyy.</br>";
                txtEffectiveDateBegin.focus();
                isError = true;
            }
        }
        else {
            errorString += "\tPlease enter 'Effective To Date'</br>";
            isError = true;
        }

        // Effective From Date and To Date comparison
        if (_OldEffectiveDateBegin != null && _OldEffectiveDateBegin.value.length > 0) {
            if (toDate(txtEffectiveDateBegin.value) > toDate(txtEffectiveDateEnd.value)) {
                errorString += "\tThe Effective To Date should be later than Effective From Date.</br>";
                isError = true;
            }
        }

        // account number
        var txtAcctNbr = document.getElementById('txtAcctNbr');
        if (txtAcctNbr.value.length == 0) {
            errorString += "\tPlease enter a valid account number.</br>";
            isError = true;
        }
        else {
            if (isNaN(txtAcctNbr.value) || txtAcctNbr.value.length != 9) {
                errorString += "\tPlease enter a valid account number with 9 characters.</br>";
                isError = true;
            }
        }

        // group name
        var txtAcctName = document.getElementById('txtAcctName');
        if (txtAcctName.value.length == 0) {
            errorString += "\Please enter a valid account name.</br>";
            isError = true;
        }

        // EntrustedBySMTBTokyo
        var cboEntrustedBySMTBTokyo = document.getElementById('cboEntrustedBySMTBTokyo');
        if (cboEntrustedBySMTBTokyo.value == "") {
            errorString += "\Please select a Entrusted by SMTB Tokyo.</br>";
            isError = true;
        }

        // ReverseRepo
        var cboReverseRepo = document.getElementById('cboReverseRepo');
        if (cboReverseRepo.value == "") {
            errorString += "\Please select a Reverse Repo.</br>";
            isError = true;
        }

        // Indemnify SEC Lending
        var chkIndemnifiedFees = document.getElementById('chkIndemnifiedFees');
        var txtIndemnifySECLendingFeeEffectiveDate = document.getElementById('txtIndemnifySECLendingFeeEffectiveDate');

        if (chkIndemnifiedFees.checked) {
            // Indemnify SEC Lending Fee Effective From Date
            if (txtIndemnifySECLendingFeeEffectiveDate.value != "OPEN") {
                if (isDate(txtIndemnifySECLendingFeeEffectiveDate.value) == false) {// invalid date
                    errorString += "\tPlease enter a valid 'Indemnify SEC Lending Fee Effective From Date'. The format is mm/dd/yyyy.</br>";
                    isError = true;
                }
            }
        }


        /*Investment Manager Dates*/
        if ($('#divInvstMngrSection').is(":visible") == true) {
            var txtInvstMngrStartDate = document.getElementById('txtInvstMngrStartDate').value;
            var txtInvstMngrEndDate = document.getElementById('txtInvstMngrEndDate').value;

            var cboInvestmentManager = document.getElementById('cboInvestmentManager').value;

            if (cboInvestmentManager != 0) {
                var txtInvstMngrStartDate = document.getElementById('txtInvstMngrStartDate').value;
                var txtInvstMngrEndDate = document.getElementById('txtInvstMngrEndDate').value;

                if (txtInvstMngrStartDate != '') {
                    if (isDate(txtInvstMngrStartDate) == false) {
                        errorString += "\tPlease enter the valid 'Investment Manager Start Shwoing Date'. The format is mm/dd/yyyy</br>";
                        document.forms[0].txtInvstMngrStartDate.focus();
                        isError = true;
                    }
                }
                else {
                    errorString += "\tPlease enter Investment Manager 'Start Shwoing Date'.</br>";
                    isError = true;
                }

                if (txtInvstMngrEndDate != '') {
                    if (txtInvstMngrEndDate != 'OPEN' && isDate(txtInvstMngrEndDate) == false) {
                        errorString += "\tPlease enter the valid 'Investment Manager Stop Shwoing Date'. The format is mm/dd/yyyy</br>";
                        document.forms[0].txtInvstMngrEndDate.focus();
                        isError = true;
                    }
                }
                else {
                    errorString += "\tPlease enter Investment Manager 'Stop Shwoing Dates'</br>";
                    isError = true;
                }
            }

            // Start Shwoing Date and Stop Showing Date comparison
            if (toDate(txtInvstMngrStartDate) > toDate(txtInvstMngrEndDate)) {
                errorString += "\tThe Stop Shwoing Date should be later than Start Shwoing Date.</br>";

            }
            
            if (toDate(txtEffectiveDateBegin.value) > toDate(txtInvstMngrStartDate)) {
                errorString += "\t'Investment Manager Start Showing Date' can not be less than " + txtEffectiveDateBegin.value + ".</br>";
                //errorString += "<a href = \"#\" onClick = SetFocus('txtInvstMngrStartDate');>\n\t'Investment Manager Start Showing Date' can not be less than " + txtEffectiveDateBegin.value + ".</a></br>";
                isError = true;
            }

            if ((txtInvstMngrEndDate != 'OPEN' && txtEffectiveDateEnd.value != "OPEN") && (toDate(txtEffectiveDateEnd.value) < toDate(txtInvstMngrEndDate))) {
                errorString += "\t'Investment Manager Stop Showing Date' can not be greater than " + txtEffectiveDateEnd.value + ".</br>";
                //errorString += "<a href = \"#\" onClick = SetFocus('txtInvstMngrEndDate');>\n\t'Investment Manager Stop Showing Date' can not be greater than " + txtEffectiveDateEnd.value + ".</a></br>";
                isError = true;
            }
        }

        var errorRow = document.getElementById('error_row');
        var error = document.getElementById("errorMsgRow");

        if (isError) {
            errorRow.style.display = "";
            error.innerHTML = errorString;
            return false;
        }
        else {
            errorRow.style.display = "block";
            error.innerHTML = '';
            return true;
        }

        return true;
    }

