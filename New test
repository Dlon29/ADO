<script type="text/javascript">

    // initialize the form
    Init_Form();

    // Initialize form
    function Init_Form() {

        // on pressing the print button, the report will be openned if there is any url to the PDF file
        var printUrl = document.Reports.hdnPrintUrl.value;

        var lbUnreportedAccounts = document.getElementById('lbUnreportedAccounts');
        var lbReportedAccounts = document.getElementById('lbReportedAccounts');        
        var chkSecurityClass = document.getElementById('chkSecurityClass');
        var roleName = document.getElementById('hdnUserAppRole').value;
        unselectAll(lbUnreportedAccounts);
        unselectAll(lbReportedAccounts);

        if (printUrl.length > 0) {
            document.Reports.hdnPrintUrl.value = "";
            PopUpWindow(printUrl, '', 'width=screen.width,height=screen.height, scrollbars=no, resizable=yes, alwaysRaised, titlebar=no');
        }
        chkSecurityClass.disabled = true;
        InitializeIndemnityReportSection();
        
        if (roleName == 'CustodyUser') {
            ApplyCustodyUserSectionVisibility();
        }
        return;
    }

    function InitializeIndemnityReportSection() {
        RefreshIndemnityReportSection();
    }

    function ApplyCustodyUserSectionVisibility() {                
        var rawData = document.getElementById('hdnMiscSectionData').value;
        var sectionData = {};       

        var pairs = rawData.split(';');
        for (var p = 0; p < pairs.length; p++) {
            var pair = pairs[p].split('=');
            if (pair.length === 2) {
                sectionData[pair[0]] = pair[1];
            }
        }

        //try {
        //    sectionData = JSON.parse(document.getElementById('hdnMiscSectionData').value);
        //} catch (e) {
        //    return;
        //}

        //var sectionRows = document.querySelectorAll('[data-section]');            
        var sectionRows = document.getElementsByTagName('tr');
        for (var i = 0; i < sectionRows.length; i++) {
            var row = sectionRows[i];
            var key = row.getAttribute('data-section');
            if (key) {
                row.style.display = (sectionData[key] === 'Y') ? '' : 'none';
            }
        }                
    }

    function OnIndemnityReportSelectionChange() {
        RefreshIndemnityReportSection();
    }

    function ShowSecurityClassification() {        
        var chkIsPositionDetail = document.getElementById('chkIsPositionDetail7');
        var chkSecurityClass = document.getElementById('chkSecurityClass');
        if (!chkIsPositionDetail.checked) {
            chkSecurityClass.checked = chkIsPositionDetail.checked;         
        }        
        chkSecurityClass.disabled = !chkIsPositionDetail.checked;
    }

    function RefreshIndemnityReportSection() {

        var RPTID_SMTBUSA_INDEMNITY_REPORT = 158;
        var RPTID_SMTBTOKYO_INDEMNITY_REPORT_SUMMARY = 209;
        var RPTID_SMTBTOKYO_INDEMNITY_REPORT_DETAILS = 210;

        var cboIndemnityReports = document.getElementById('cboIndemnityReports');
        var tbIndemnityReportSMTBUSAFilter = document.getElementById('tbIndemnityReportSMTBUSAFilter');
        var tbIndemnityReportSMTBTokyoFilter = document.getElementById('tbIndemnityReportSMTBTokyoFilter');

        if (cboIndemnityReports.value == RPTID_SMTBUSA_INDEMNITY_REPORT) {
            tbIndemnityReportSMTBUSAFilter.style.display = '';
            tbIndemnityReportSMTBTokyoFilter.style.display = 'none';
            return;
        }
        tbIndemnityReportSMTBUSAFilter.style.display = 'none';
        tbIndemnityReportSMTBTokyoFilter.style.display = '';
    }

    function diableTermRepo(obj) {

        if (obj != null && obj.id == 'rbCSV3_2') {

            document.forms[0].cboTermRepo.options[3].selected = true;
            document.forms[0].cboTermRepo.disabled = true;
        }
        else {
            document.forms[0].cboTermRepo.disabled = false;
            if (obj.id == 'rbCSV3_1')
                document.forms[0].cboTermRepo.options[0].selected = true;
            else
                document.forms[0].cboTermRepo.options[3].selected = true;
        }

    }

    function getAccounts(startDate, endDate, acctGrpID, listID) {
        $("#" + listID + " option").remove();

        $.ajax({
            type: "POST",
            url: '../Reports/MiscReports.aspx/GetAccounts',
            data: "{startDate:'" + startDate +"', endDate:'" + endDate + "', acctGrpID:'" + acctGrpID + "'}",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (msg) {
                $("#" + listID + " option").remove();
                
                $.each(msg.d, function (index, item) {
                    $("#" + listID).append($('<option>').text(item.AccountName).val(item.AcccountID));
                });
            },
            error: function (xhr, textStatus, errorThrow) {
                $("#" + listID + " option").remove();
                alert(xhr.responseText);
            }
        });
    }


    $(document).ready(function () {

        //Lending Earnings
        $("#cboAcctGrpLE").bind("change", function () {
            var startDate = $.trim($('#txtStartDate3').val());
            var endDate = $.trim($('#txtEndDate3').val());
            getAccounts(startDate, endDate, $(this).val(), 'lbUnreportedAccounts');
        });

        //Security Lending Performance
        $("#cboAcctGrpSLP").bind("change", function () {
            var startDate = $.trim($('#txtStartDate7').val());
            var endDate = $.trim($('#txtEndDate7').val());
            getAccounts(startDate, endDate, $(this).val(), 'lbUnreportedAccounts7');
        });

    });


    function ShowReport() {
        debugger;
        var reportID, businessDate, fileType, reportName, errMsg;
        var webapirul = '<%=System.Configuration.ConfigurationManager.AppSettings["MoBetterWebApiUrl"].ToString() %>'
        var token = '<%=System.Configuration.ConfigurationManager.AppSettings["AuthToken"].ToString() %>'

        reportID = 237;
        businessDate = document.forms[0].txtAsOfDate.value;
        fileType = "xlsx";
        reportName = "All_Outstanding";

        error_row.style.display = 'None';
        //Date Validation
        if (isDate(businessDate) == false) {
            errMsg = "Please enter the valid date. The format is mm/dd/yyyy";
            document.forms[0].txtAsOfDate.focus();
            error_row.style.display = '';
            error.innerHTML = errMsg;
            return false;
        }

        var jsonParams = "[{\"ParamName\": \"SQL_CONDITION10\", \"ParamValue\": '" + 1 + "', \"ParamType\": \"Int\"}]";

        var params = {
            ReportID: reportID,
            BusinessDate: businessDate,
            Filetype: fileType,
            ReportName: reportName,
            AppID: 1,
            ReportParams: jsonParams
        };
        
        var url = webapirul + "v1/GenericReport/GetReport";
        
        ajaxCall(url, params, token, function (response) {

            if (response != null || response != undefined) {
                var parsedData = response;

                if (parsedData.status == "Failure" && parsedData.statusDetails.length > 0) {
                    errMsg = parsedData.statusDetails;
                    error_row.style.display = '';
                    error.innerHTML = errMsg;
                }
                else if (parsedData.status == "Success" && parsedData.reportPath.reportFolderPath != null && parsedData.reportPath.reportFolderPath.length > 0) {                    
                    var confURL = parsedData.reportPath.reportFolderPath + parsedData.reportPath.reportFile;
                    $("#lnkOpenReport").attr("href", "file:" + confURL);
                    $('#lnkOpenReport')[0].click();
                }
                else {
                    errMsg = "Please Contact Administrator."
                    error_row.style.display = '';
                    error.innerHTML = errMsg;
                }
            }
        });
    }

</script>
