        private string AddLoanNodeToXMLFile()
        {
            //create new instance of XmlDocument
            XmlDocument doc = new XmlDocument();
            bool blnFirstRowProcessed = false;
            string FilePath = string.Empty;

            FilePath = "/LAVA/XmlTemplates/CloseLoan.xml";

            //load from file
            XmlTextReader reader = new XmlTextReader(Server.MapPath(FilePath));
            doc.Load(reader);

            DataGridItem dgi = null;
            int iXmlRowCount = 1;
            int intRowCount = 0;
            int ValidationFail = 0;
            _ErrorString = new StringBuilder();

            XmlNode mainNode = doc.SelectSingleNode("CloseLoan");

            // this will loop thru all records of a data table
            for (int iRowCount = 0; iRowCount < grdCloseReBookLoanRecords.Items.Count; iRowCount++)
            {
                dgi = this.grdCloseReBookLoanRecords.Items[iRowCount];

                //create sub node
                XmlNode node = doc.CreateNode(XmlNodeType.Element, "FieldName", null);
                CheckBox chkInclude = (CheckBox)dgi.Cells[(int)grdMapping.chkInclude].FindControl("chkInclude");


                if (chkInclude.Checked)
