        /// <summary>
        /// Page navigation click
        /// </summary>
        /// <param name="sender"></param>
        /// <param name="e"></param>
        protected void PageNavigation_Click(object sender, System.Web.UI.WebControls.CommandEventArgs e)
        {
            // get the parameters from hidden controls. 
            _PageChange = "True";

            switch (e.CommandName.ToUpper())
            {
                case "FIRST":						//first
                    _PageNo = 1;
                    txtGoTo1.Text = txtGoTo2.Text = string.Empty;
                    break;

                case "PREVIOUS":					//prev
                    _PageNo--;
                    txtGoTo1.Text = txtGoTo2.Text = string.Empty;
                    if (_PageNo < 1)
                        _PageNo = 1;
                    break;

                case "NEXT":						//next
                    _PageNo++;
                    txtGoTo1.Text = txtGoTo2.Text = string.Empty;
                    if (_PageNo > _TotPage)
                        _PageNo = _TotPage;
                    break;

                case "LAST":
                    txtGoTo1.Text = txtGoTo2.Text = string.Empty;//last
                    _PageNo = _TotPage;
                    break;

                case "GOTO1":
                    _PageNo = Int32.Parse(this.txtGoTo1.Text);
                    break;

                case "GOTO2":
                    _PageNo = Int32.Parse(this.txtGoTo2.Text);
                    break;
            }

            // refresh the page based on the navigation
            GetRecords();
        }

