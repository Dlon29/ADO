	/* Now book all closed loans*/		
	IF EXISTS (SELECT 1 FROM @TempXMLTable WHERE IsCollateral = 0)
	BEGIN
		SET @RecordTypeID = 1
		SET @TOE = 'TSL'
		SET @StatusId = 999
		SET @ModifiedBy	= ISNULL(@ModifiedBy, SUSER_SNAME())
		SET @FinderLdnLoc  = 'LDN'
		SET @FinderNYLoc = 'NY'
		SET @BrkCrGrpID = 0
		SET	@BrkGrpID = 0
		SET	@BrkID = 0
		SET @RawDataID = NULL
		SET @Ret = 1
		SET @FileName = 'From LAVA'
		SET @ModifiedDate = GETDATE()
		SELECT @G1UserCode = dbo.f_GetG1LavaUserMapping (@ModifiedBy)

		SELECT TOP 1 @BatchDate = BatchDate FROM @TempXMLTable WHERE ISNULL(IsCollateral, 0) = 0


		/* Get all the accounts */
		INSERT INTO #AllocationTbl 
		(
			SecID,
			BGNREF,
			AcctId,
			AcctNbr,
			BrkNbr,
			FaceAmountFromAlloc,
			FaceAmountActual		
		)
		SELECT DISTINCT 
			TempLoan.SecID,
			TempLoan.BGNREF,
			Acc.AcctId,
			TempLoan.Acctnbr,
			TempLoan.BrkNbr,
			TempLoan.FaceAmount,
			TempLoan.FaceAmount
		FROM 
			@TempLoansandCollaterals TempLoan
		INNER JOIN
			Account Acc
		ON
			Acc.AcctNbr = TempLoan.AcctNbr
		WHERE
			IsStreetside = 0 AND
			ISNULL(IsCollateral, 0) = 0			

		UPDATE 
			@TempXMLTable
		SET 
			IsProcessed = 0
		WHERE ISNULL(IsCollateral, 0) = 0

		INSERT INTO ETITranUploadHistLog
		(
			[TemplateID],
			[BrkCrGrpID],
			[BrkGrpID],
			[BrkID],
			[RecordTypeID],
			[FileName],
			[AsOfDate],
			[IsSuccess],
			[ModifiedBy],
			[ModifiedDate]
		)
		SELECT 
			DISTINCT 0,
			@BrkCrGrpID,
			@BrkGrpID,
			@BrkID,
			@RecordTypeID,
			@FileName,
			@BatchDate,
			@Ret,
			@ModifiedBy,
			@ModifiedDate

		SET @SourceID = @@IDENTITY	
		SET @ERROR_NO = @@ERROR	

		/* Insert SourceId for selected broker in temp HistLogTbl for further processing*/
		INSERT INTO @HistLogTbl 
		(
			SourceId,
			BrkCrGrpId,
			BrkId,
			RecordTypeID
		)
		SELECT DISTINCT
			@SourceID,
			@BrkCrGrpId,
			@BrkID,
			@RecordTypeID


		/***** 2nd step : Insert into dbo.ETIRawData table ****/
		
		SET @Count = 1 
		SELECT @TotalCount = COUNT(*) FROM @TempXMLTable WHERE IsCollateral = 0
		WHILE (@Count <= @TotalCount)
		BEGIN
			SET @TxnRefNbr = NULL
			SET @BGNREF = NULL
			SET @RawDataID = NULL

			/* Get the values in variables */
			SELECT 
				@TxnRefNbr = TxnRefNbr,
				@BGNREF	= BGNREF
			FROM 
				@TempXMLTable 
			WHERE 
				RowID = @Count AND
				ISNULL(IsCollateral, 0) = 0

			INSERT INTO dbo.ETIRawData
			(
				[SourceID],
				[SecID],
				[BrkID],
				[TxnRefNbr],
				[BulkNbr],
				[RecordTypeID],
				[SecLocID],
				[SecLocCode],
				[SecCode],
				[FaceAmount],
				[Price],
				[PriceOverride],
				[Principal],
				[CCYCode],
				[CollCcyCode],
				[SettlementDate],
				[TermDate],
				[BrkNbr],
				[Depository],
				[LoanType],
				[DisclosureType],
				[RebateRate],
				[BatchDate],
				[AsOfDate],
				[IsValid],
				[ErorBitMap],
				[StatusID],
				[TransmitFlg],
				[BasketNbr],
				[ModifiedBy],
				[ModifiedDate]
			)
			SELECT 
				DISTINCT @SourceId,
				temp.SecId,
				b.BrkId,
				0,-- TxnRefNbr
				0, --BulkNbr
				@RecordTypeID,	
				NULL,
				temp.SecLocCode,
				temp.SecCode,
				temp.FaceAmount,
				temp.TradePrice, -- Price
				NULL, -- PriceOverride
				CASE b.BusinessInd
					WHEN 'FI' THEN
						ROUND((temp.FaceAmount * temp.TradePrice) / 100,2)
					ELSE ROUND((temp.FaceAmount * temp.TradePrice),2)
				END, -- Principal
				ISNULL(temp.CCYCode, ''),
				temp.CollCCYCode, -- CollateralCCY
				CASE temp.SettleDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.SettleDate  END,
				CASE temp.termDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.termDate END,
				temp.BrkNbr,
				temp.ClearAgentNbr,
				bs.LoanType,
				NULL, --DisclosureType
				temp.RepoRate, 
				@BatchDate,
				temp.AsOfDate,
				1, -- IsValid
				0, -- ErrorBitMap
				@StatusId,
				temp.Transmit,
				temp.BasketNbr,
				@ModifiedBy,
				@ModifiedDate
			FROM 
				@TempLoansandCollaterals temp
			INNER JOIN
				@TempXMLTable tempxml
			ON
				tempxml.BGNREF = temp.BGNREF AND
				temp.Isstreetside = 1 AND
				temp.BGNREF	= @BGNREF AND
				ISNULL(tempxml.IsCollateral, 0) = 0
			INNER JOIN
			(
				SELECT SecID,SUM(FaceAmountActual) FaceAmount ,BGNREF
				FROM #AllocationTbl
				GROUP BY SecID,BGNREF
				
			) Acc
			ON
				Acc.SecID = temp.SecID AND
				Acc.BGNREF = temp.BGNREF AND
				temp.IsStreetside = 1
			INNER JOIN 
				MOBETTER.dbo.Broker b 
			ON 
				b.BrkNbr = temp.BrkNbr AND
				@BatchDate BETWEEN b.EffectiveDateBegin AND b.EffectiveDateEnd AND
				ISNULL(b.IsDeleted,0) = 0
			LEFT JOIN 
				MOBETTER.DBO.Broker bs
			ON	
				bs.BrkID = b.BrkID	AND
				@BatchDate BETWEEN bs.EffectiveDateBegin AND bs.EffectiveDateEnd AND
				ISNULL(bs.IsDeleted,0) = 0

			SELECT @RawDataID = @@IDENTITY
		
			/***** 3rd step : Insert into dbo.ETIAllocation table ****/
			INSERT INTO dbo.ETIAllocation
			(
				[RawDataID],
				[SourceID],
				[SecID],
				[BrkID],
				[AcctId],
				[AcctNbr],
				[RecordTypeID],
				[SecLocID],
				[SecCode],
				[FaceAmount],
				[Price],
				[Principal],
				[CCYCode],
				[CollCCYCode],
				[SettlementDate],
				[BrkNbr],
				[SecLocCode],
				[Depository],
				[LoanType],
				[RebateRate],
				[TxnRefNbr],
				[StatusID]
			)
			SELECT	
				DISTINCT rd.ID,
					rd.SourceID,
					rd.SecId,
					rd.BrkID,
					acc.AcctId,
					acc.AcctNbr,
					(@RecordTypeID + 1),
					NULL, --SecLocID
					rd.SecCode,
					temp.FaceAmount,
					CASE WHEN rd.PriceOverride IS NOT NULL THEN rd.PriceOverride ELSE rd.Price END,
					(temp.FaceAmount * rd.Price),
					rd.CCYCode,
					rd.CollCCYCode,
					rd.SettlementDate,
					rd.BrkNbr,
					rd.SecLocCode,
					temp.ClearAgentNbr,
					rd.LoanType,
					rd.RebateRate,
					0,--TxnRefNbr,
					999--dbo.f_GetETIProcessFlowStatus (@RecordTypeID, 'Verified') --TODO
			FROM 
				@TempLoansandCollaterals temp 		
			INNER JOIN 
				dbo.ETIRawData rd 
			ON	
				rd.SecId = temp.SecId AND
				rd.BrkNbr = temp.BrkNbr AND
				rd.Depository = temp.ClearAgentNbr AND
				rd.ID = @RawDataID AND
				temp.BGNREF = @BGNREF
			INNER JOIN   
				#AllocationTbl acc 
			ON 
				acc.BGNREF = temp.BGNREF AND
				acc.SecID = temp.SecID AND
				acc.BrkNbr = temp.BrkNbr AND
				acc.AcctNbr = temp.AcctNbr AND
				temp.FaceAmount > 0
			INNER JOIN 
				@HistLogTbl hist 
			ON 
				hist.SourceID = rd.SourceID
			WHERE 
				temp.FaceAmount > 0 --insert only account allocated records

			/* Isner one OMNI and other Accounts record into temp ETIDetailRecord table*/
			INSERT INTO @ETIDetailRecordNewLoan 
			(
				RawDataID,
				ExternalRefNbr,
				LoanType,
				AcctNbr,
				WLDepository,
				SecCode,
				SettlementDate,
				TermDate,
				BrkNbr,
				FaceAmount,
				RawPrice,
				TradePrice,
				CCYCode,
				Principal,
				CollCCYCode,
				RebateRate,
				SecLocCode,
				SecID,
				BrkID,		
				RecordTypeID,
				BatchDate,
				AsOfDate,
				CollateralDate,
				GoodFundsDate,
				FinderNbr,
				PoolNbr,
				Comments,
				SettlementInstr,
				SettlementCCY,
				CleanUpFlg,
				TransmitFlg,
				DisclosureType,
				TriPartyGrpID,
				CollSchedID,
				ProductCategory,
				LowDivRate,
				STTLevel,
				STTEndDate,
				STTDivRate,
				BulkNbr,
				ScripEndDate,
				ProductCategoryLoanType,	
				ProductCategoryLoanDuration,
				LoanCategory,
				BasketNbr,				
				LIBORRate,			  
				ResetDate,			
				GotoRepoRate,	
				GotoTermDate,
				GotoRemarks,		  		
				GotoSTTLevel,
				GotoSTTDivRate,  		  
				GotoSTTEndDate,
				GotoScripEndDate,
				GotoProductCategory,
				GotoProductCategoryLoanType, 
				GotoProductCategoryLoanDuration,
				DesiredSTTLevel,
				IsProjectedDividend,
				ProjectedDividendAmount,
				BgnRef,  
				GCIRecordType,
				GCIStatus,
				GCITransactionType,
				GCIPostingType,
				GCILenderModuleTrade,
				GCIAutoAuthorised,
				GPTransmit,		
				SFTRCancelledLoanRefNbr,
				ExecutionTimestamp,
				IsPrePay,
				TPUID			
			)		
			SELECT DISTINCT
				a.RawDataID,
				a.ExternalRefNbr,
				a.LoanType,
				a.AcctNbr,
				a.Depository,
				a.SecCode,
				a.SettlementDate,
				a.TermDate,
				a.BrkNbr,
				a.FaceAmount,
				a.Price,
				a.TradePrice,
				a.CCYCode,
				a.Principal,
				a.CollCCYCode,
				a.RebateRate,
				a.SecLocCode,
				a.SecID,
				a.BrkID,		
				a.RecordTypeID,
				a.BatchDate,
				a.AsOfDate,
				a.CollateralDate,
				a.GoodFundsDate,
				a.FinderNbr,
				a.PoolNbr,
				a.Comments,
				a.SettlementInstr, 
				NULL, --SettlementCCY
				a.CleanUpFlg,
				a.TransmitFlg,
				a.DisclosureType,
				a.TriPartyGrpID,
				a.CollSchedID,
				a.ProductCategory,
				a.LowDivRate,
				CASE LEN(a.STTLevel) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(5,2),a.STTLevel) END,
				a.STTEndDate,
				CASE LEN(a.STTDivRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(13,6),a.STTDivRate) END,
				a.BulkNbr,
				a.ScripEndDate,
				a.ProductCategoryLoanType,	--LoanType
				a.ProductCategoryLoanDuration,
				a.LoanCategory,
				CASE LEN(a.BasketNbr) WHEN 0 THEN NULL ELSE a.BasketNbr END,	    
				CASE LEN(a.LIBORRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(20,10),a.LIBORRate) END,	    
				a.ResetDate,			
				CASE LEN(a.GotoRepoRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(20,7),a.GotoRepoRate) END,	    
				a.GotoTermDate,
				a.GotoRemarks,		  		
				NULL, --GotoSTTLevel
				NULL, --GotoSTTDivRate		  
				NULL, --GotoSTTEndDate
				NULL, --GotoScripEndDate
				a.GotoProductCategory,
				a.GotoProductCategoryLoanType, 
				a.GotoProductCategoryLoanDuration,
				a.DesiredSTTLevel,
				a.IsProjectedDividend,
				a.ProjectedDividendAmount,
				a.BgnRef,
				a.GCIRecordType,
				a.GCIStatus,
				a.GCITransactionType,
				a.GCIPostingType,
				a.GCILenderModuleTrade,
				a.GCIAutoAuthorised,
				a.GPTransmit,
				a.SFTRCancelledLoanRefNbr,
				a.ExecutionTimestamp,
				a.IsPrePay,
				a.TPUID
				FROM
				(	
					SELECT 
						DISTINCT RawDataID	= rd.[ID],
						ExternalRefNbr	= NULL,
						RecordTypeID	= rd.RecordTypeID,
						BrkId			= rd.BrkID,
						SecID			= rd.SecID,
						AcctNbr			= NULL,
						LoanType		= rd.LoanType,
						Depository		= temp.ClearAgentNbr,
						SecCode			= rd.SecCode,
						SettlementDate	= temp.SettleDate,
						TermDate		= CASE temp.TermDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.TermDate END,
						BrkNbr			= rd.BrkNbr,
						FaceAmount		= rd.FaceAmount,
						Price			= rd.Price,
						PriceOverride	= rd.PriceOverride,
						TradePrice		= rd.Price,
						CCYCode			= rd.CCYCode,
						Principal		= rd.Principal,
						CollCCYCode		= rd.CollCCYCode,
						RebateRate		= rd.RebateRate,
						SecLocCode		= rd.SecLocCode,
						TxnRefNbr		= rd.TxnRefNbr,
						BatchDate		= rd.BatchDate,
						AsOfDate		= rd.AsOfDate,
						CollateralDate	= temp.SettleDate,
						GoodFundsDate	= temp.SettleDate,
						FinderNbr		= temp.FinderNbr,
						PoolNbr			= NULL,
						Comments		= tempxml.Comments,
						SettlementInstr = temp.SMODE, 
						SettlementCCY	= NULL,
						CleanUpFlg		= NULL,
						TransmitFlg		= rd.TransmitFlg,
						DisclosureType	= rd.DisclosureType,
						TriPartyGrpID	= temp.TriPartyGrpID,
						CollSchedID		= temp.CollSchedID,
						ProductCategory	= temp.ProductCategory,
						LowDivRate		= NULL,
