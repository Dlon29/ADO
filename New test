        /// <summary>
        /// Book laon redirection
        /// </summary>
        /// <param name="sender"></param>
        /// <param name="e"></param>
        protected void btnBookLoan_Click(object sender, EventArgs e)
        {
            Hashtable htMain = new Hashtable();
            Database clsDB = new Database();
            DataCommand clsCmd = new DataCommand();
            MethodName = "btnBookLoan_Click()";

            try
            {
                if (ValidateInputs())
                {

                    string loanXml = AddLoanNodeToXMLFile();
                    string collateralXml = AddCollateralNodeToXMLFile();

                    DataReader clsReader = new DataReader();
                    DataSet ds = new DataSet();
                    bool blnStatus = false;
                    string[] SqlCondition = new string[2] { "" };
                    string Identifier = "";

                    if (clsDB.Open() == false)
                    {
                        log.Debug(Common.GetMessage("Common", "ErrorCantOpenDB"));
                        throw new Exception(Common.GetMessage("Common", "ErrorCantOpenDB"));
                    }

                    clsReader.Connection = clsDB.Connection;
                    clsReader.StoredProcedure = SqlObjectsStaticClass.p_SaveData_ETI_CloseRebookLoansandCollaterals;

                    SqlCondition[0] = loanXml;
                    SqlCondition[1] = collateralXml;
                    Identifier = "LAVA";

                    clsReader.SqlIdentifier = Identifier;

                    if (clsReader.GetData(ref ds, SqlCondition) == false)
                    {
                        blnStatus = false;
                        log.Debug(Common.GetMessage("Common", "ErrorExecSP") + clsCmd.StoredProcedure);
                        throw new Exception(Common.GetMessage("Common", "ErrorExecSP") + clsCmd.StoredProcedure);
                    }
                    else
                    {
                        blnStatus = true;
                    }

                    if (blnStatus)
                    {
                        ConfirmBatch();                        
                    }
                }

            }
            catch (Exception Exc)
            {
                _ErrorString = new StringBuilder("");
                _ErrorString.Append(Exc.Message);
                _show_error_row = "";
                log.Debug(string.Format(ErrorMessageToLog, ModuleName, MethodName, Exc));

            }
        }

