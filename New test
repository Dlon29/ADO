            }

            if (adlProductID == "9") {
                productActivationForADLNonIndem = $(this).find("input[type=hidden][id*='hdnActivationStatus']").val();
            }
        });

        if ($.trim(productActivationForADLIndem) != "A" && $.trim(productActivationForADLNonIndem) != "A") {
            $('#chkAgentDirectLending').attr('checked', false);
            return false;
        }

    }


    function CheckUncheckIsFeedToWeb(element) {
        var grdProductLine = document.getElementById('<%= grdAcctProdPrinRiskMapping.ClientID %>');

        if (grdProductLine) {
            var chkBoxIsFeedToWebList = grdProductLine.getElementsByTagName("input");

            for (var i = 0; i < chkBoxIsFeedToWebList.length; i++) {
                var chkBoxIsFeedToWeb = chkBoxIsFeedToWebList[i];

                if (chkBoxIsFeedToWeb.type === "checkbox" && chkBoxIsFeedToWeb.id !== element.id) {
                    chkBoxIsFeedToWeb.checked = false;
                }
            }
        }
    }


    function EnableDisableIsFeedToWeb(element) {        
        var grdProductLine = document.getElementById('<%= grdAcctProdPrinRiskMapping.ClientID %>');

        if (grdProductLine) {
            var isFeedToWeb = document.getElementById(element.id.replace("ddlStatus", "chkFeedtoWeb"));
            var isFeedToWebProductId = document.getElementById(element.id.replace("ddlStatus", "HdnProductId")).value;
            var isFeedToWebPrincipalRiskId = document.getElementById(element.id.replace("ddlStatus", "hdnPrincipalRiskId")).value;
            var _CBJProductId = document.getElementById('hdnCBJProductId').value;
            var _SMTBUSAUncollPrinRiskId = document.getElementById('hdnSMTBUSAUncollPrinRiskId').value;

            if (element.value == 0 && !(isFeedToWebProductId == _CBJProductId && isFeedToWebPrincipalRiskId == _SMTBUSAUncollPrinRiskId)) {
                isFeedToWeb.disabled = false;
                isFeedToWeb.parentElement.disabled = false;
            }
            else {
                isFeedToWeb.checked = false;
                isFeedToWeb.disabled = true;
            }
        }
    }


    function ShowReport() {

        var reportID, businessDate, fileType, reportName, acctGrpID, includeALD, isDeleted, acctNbr, productLine, repoSecLendType, businessLine, principal, internalAcctGroup, errMsg;
        var webapirul = '<%=System.Configuration.ConfigurationManager.AppSettings["MoBetterWebApiUrl"].ToString() %>'
        var token = '<%=System.Configuration.ConfigurationManager.AppSettings["AuthToken"].ToString() %>'

        reportID = 237;
        businessDate = document.forms[0].txtBatchRunDate.value;
        fileType = "xlsx";
        reportName = "Account_List";

        if ($('#chkShowIsDeleted').is(":checked"))
            isDeleted = 1;
        else
            isDeleted = 0;

        if ($('#chkShowALD').is(":checked"))
            includeALD = 1;
        else
            includeALD = 0;

        acctGrpID = $('#cboAcctGrpId2').val();
        acctNbr = $('#txtAcctNbr2').val();

        productLine = $('#ddlProductLine').val();
        repoSecLendType = $('#ddlProductType').val();
        businessLine = $('#ddlBusinessLine').val();
        principal = $('#ddlPrincipal').val();
        internalAcctGroup = $('#ddlInternalAcctGroup').val();

        error_row.style.display = 'None';
        //Date Validation
        if (isDate(businessDate) == false) {
            errMsg = "Please enter the valid date. The format is mm/dd/yyyy";
            document.forms[0].txtBatchRunDate.focus();
            error_row.style.display = '';
            error.innerHTML = errMsg;
            return false;
        }

        var jsonParams = "[{\"ParamName\": \"SQL_CONDITION1\", \"ParamValue\": '" + acctGrpID + "', \"ParamType\": \"Int\"}, " +
            "{\"ParamName\": \"SQL_CONDITION2\", \"ParamValue\": '" + includeALD + "', \"ParamType\": \"Int\"}," +
            "{\"ParamName\": \"SQL_CONDITION3\", \"ParamValue\": '" + isDeleted + "', \"ParamType\": \"Int\"}," +
            "{\"ParamName\": \"SQL_CONDITION4\", \"ParamValue\": '" + acctNbr + "', \"ParamType\": \"String\"}," +
            "{\"ParamName\": \"SQL_CONDITION5\", \"ParamValue\": '" + productLine + "', \"ParamType\": \"String\"}," +
            "{\"ParamName\": \"SQL_CONDITION6\", \"ParamValue\": '" + repoSecLendType + "', \"ParamType\": \"String\"}," +
            "{\"ParamName\": \"SQL_CONDITION7\", \"ParamValue\": '" + businessLine + "', \"ParamType\": \"String\"}," +
            "{\"ParamName\": \"SQL_CONDITION8\", \"ParamValue\": '" + principal + "', \"ParamType\": \"String\"}," +
            "{\"ParamName\": \"SQL_CONDITION9\", \"ParamValue\": '" + internalAcctGroup + "', \"ParamType\": \"Int\"}," +
            "{\"ParamName\": \"SQL_CONDITION10\", \"ParamValue\": '" + 1 + "', \"ParamType\": \"Int\"}]";

        var params = {
            ReportID: reportID,
            BusinessDate: businessDate,
            Filetype: fileType,
            ReportName: reportName,
            AppID: 1,
            ReportParams: jsonParams
        };

        var url = webapirul + "v1/GenericReport/GetReport";

        ajaxCall(url, params, token, function (response) {

            if (response != null || response != undefined) {
                var parsedData = response;

                if (parsedData.status == "Failure" && parsedData.statusDetails.length > 0) {
                    errMsg = parsedData.statusDetails;
                    error_row.style.display = '';
                    error.innerHTML = errMsg;
                }
                else if (parsedData.status == "Success" && parsedData.reportPath.reportFolderPath != null && parsedData.reportPath.reportFolderPath.length > 0) {
                    //  $("[id$=lblInfoMsg]").text(parsedData.messages[0]);
                    var confURL = parsedData.reportPath.reportFolderPath + parsedData.reportPath.reportFile;
                    $("#lnkOpenReport").attr("href", "file:" + confURL);
                    $('#lnkOpenReport')[0].click();
                }
                else {
                    errMsg = "Please Contact Administrtor."
                    error_row.style.display = '';
                    error.innerHTML = errMsg;
                }
            }
        });
    }

</script>
