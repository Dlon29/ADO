		[BrkCrGrpID],
		[BrkGrpID],
		[BrkID],
		[RecordTypeID],
		[FileName],
		[AsOfDate],
		[IsSuccess],
		[ModifiedBy],
		[ModifiedDate]
	)
	SELECT 
		DISTINCT 0,
		@BrkCrGrpID,
		@BrkGrpID,
		@BrkID,--b.BrkId,
		@RecordTypeID,
		@FileName,
		@BatchDate,
		@Ret,
		@ModifiedBy,
		@ModifiedDate

	SET @SourceID = @@IDENTITY	
	SET @ERROR_NO = @@ERROR	

	/* Insert SourceId for selected broker in temp HistLogTbl for further processing*/
	INSERT INTO @HistLogTbl 
	(
		SourceId,
		BrkCrGrpId,
		BrkId,
		RecordTypeID
	)
	SELECT DISTINCT
		@SourceID,
		@BrkCrGrpId,
		@BrkID,
		@RecordTypeID


	/***** 2nd step : Insert into dbo.ETIRawData table ****/
	
	SET @Count = 1 
	SELECT @TotalCount = COUNT(*) FROM @TempXMLTable
	WHILE (@Count <= @TotalCount)
	BEGIN
		SET @TxnRefNbr = NULL
		SET @BGNREF = NULL
		SET @RawDataID = NULL

		/* Get the values in variables */
		SELECT 
			@TxnRefNbr = TxnRefNbr,
			@BGNREF	= BGNREF
		FROM 
			@TempXMLTable 
		WHERE 
			RowID = @Count

		INSERT INTO dbo.ETIRawData
		(
			[SourceID],
			[SecID],
			[BrkID],
			[TxnRefNbr],
			[BulkNbr],
			[RecordTypeID],
			[SecLocID],
			[SecLocCode],
			[SecCode],
			[FaceAmount],
			[Price],
			[PriceOverride],
			[Principal],
			[CCYCode],
			[CollCcyCode],
			[SettlementDate],
			[TermDate],
			[BrkNbr],
			[Depository],
			[LoanType],
			[DisclosureType],
			[RebateRate],
			[BatchDate],
			[AsOfDate],
			[IsValid],
			[ErorBitMap],
			[StatusID],
			[TransmitFlg],
			[BasketNbr],
			[ModifiedBy],
			[ModifiedDate]
		)
		SELECT 
			DISTINCT @SourceId,
			temp.SecId,
			b.BrkId,
			0,-- TxnRefNbr
			0, --BulkNbr
			@RecordTypeID,	
			NULL,
			temp.SecLocCode,
			temp.SecCode,
			temp.FaceAmount,
			temp.TradePrice, -- Price
			NULL, -- PriceOverride
			CASE b.BusinessInd
				WHEN 'FI' THEN
					ROUND((temp.FaceAmount * temp.TradePrice) / 100,2)
				ELSE ROUND((temp.FaceAmount * temp.TradePrice),2)
			END, -- Principal
			ISNULL(temp.CCYCode, ''),
			temp.CollCCYCode, -- CollateralCCY
			CASE temp.SettleDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.SettleDate  END,
			CASE temp.termDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.termDate END,
			temp.BrkNbr,
			temp.ClearAgentNbr,
			bs.LoanType,
			NULL,--temp.Disclosure, --need to check
			temp.RepoRate, -- need to check
			@BatchDate,
			temp.AsOfDate,
			1, -- IsValid
			0, -- ErrorBitMap
			@StatusId,
			temp.Transmit,
			temp.BasketNbr,
			@ModifiedBy,
			@ModifiedDate
		FROM 
			@TempLoan temp
		INNER JOIN
			@TempXMLTable tempxml
		ON
			tempxml.BGNREF = temp.BGNREF AND
			temp.Isstreetside = 1 AND
			temp.BGNREF	= @BGNREF
		INNER JOIN
		(
			SELECT SecID,SUM(FaceAmountActual) FaceAmount ,BGNREF
			FROM #AllocationTbl
			GROUP BY SecID,BGNREF
			
		) Acc
		ON
			Acc.SecID = temp.SecID AND
			Acc.BGNREF = temp.BGNREF AND
			temp.IsStreetside = 1
		INNER JOIN 
			MOBETTER.dbo.Broker b 
		ON 
			b.BrkNbr = temp.BrkNbr AND
			@BatchDate BETWEEN b.EffectiveDateBegin AND b.EffectiveDateEnd AND
			ISNULL(b.IsDeleted,0) = 0
		LEFT JOIN 
			MOBETTER.DBO.Broker bs
		ON	
			bs.BrkID = b.BrkID	AND
			@BatchDate BETWEEN bs.EffectiveDateBegin AND bs.EffectiveDateEnd AND
			ISNULL(bs.IsDeleted,0) = 0

		SELECT @RawDataID = @@IDENTITY
	
		/***** 3rd step : Insert into dbo.ETIAllocation table ****/
		INSERT INTO dbo.ETIAllocation
		(
			[RawDataID],
			[SourceID],
			[SecID],
			[BrkID],
			[AcctId],
			[AcctNbr],
			[RecordTypeID],
			[SecLocID],
			[SecCode],
			[FaceAmount],
			[Price],
			[Principal],
			[CCYCode],
			[CollCCYCode],
			[SettlementDate],
			[BrkNbr],
			[SecLocCode],
			[Depository],
			[LoanType],
			[RebateRate],
			[TxnRefNbr],
			[StatusID]
		)
		SELECT	
			DISTINCT rd.ID,
				rd.SourceID,
				rd.SecId,
				rd.BrkID,
				acc.AcctId,
				acc.AcctNbr,
				(@RecordTypeID + 1),
				NULL,
				rd.SecCode,
				temp.FaceAmount,
				CASE WHEN rd.PriceOverride IS NOT NULL THEN rd.PriceOverride ELSE rd.Price END,
				(temp.FaceAmount * rd.Price),
				rd.CCYCode,
				rd.CollCCYCode,
				rd.SettlementDate,
				rd.BrkNbr,
				rd.SecLocCode,
				temp.ClearAgentNbr,
				rd.LoanType,
				rd.RebateRate,
				0,--a.TxnRefNbr,
				0--dbo.f_GetETIProcessFlowStatus (@RecordTypeID, 'Verified')
		FROM 
			@TempLoan temp 		
		INNER JOIN 
			dbo.ETIRawData rd 
		ON	
			rd.SecId = temp.SecId AND
			rd.BrkNbr = temp.BrkNbr AND
			rd.Depository = temp.ClearAgentNbr AND
			rd.ID = @RawDataID AND
			temp.BGNREF = @BGNREF
		INNER JOIN   
			#AllocationTbl acc 
		ON 
			acc.BGNREF = temp.BGNREF AND
			acc.SecID = temp.SecID AND
			acc.BrkNbr = temp.BrkNbr AND
			acc.AcctNbr = temp.AcctNbr AND
			temp.FaceAmount > 0
		INNER JOIN 
			@HistLogTbl hist 
		ON 
			hist.SourceID = rd.SourceID /*AND
			hist.BrkId = rd.BrkId*/
		WHERE 
			temp.FaceAmount > 0 --insert only account allocated records

		/* Isner one OMNI and other Accounts record into temp ETIDetailRecord table*/
		INSERT INTO @ETIDetailRecordNewLoan 
		(
			RawDataID,
			ExternalRefNbr,
			LoanType,
			AcctNbr,
			WLDepository,
			SecCode,
			SettlementDate,
			TermDate,
			BrkNbr,
			FaceAmount,
			RawPrice,
			TradePrice,
			CCYCode,
			Principal,
			CollCCYCode,
			RebateRate,
			SecLocCode,
			SecID,
			BrkID,
	--			TxnRefNbr,
			RecordTypeID,
			BatchDate,
			AsOfDate,
			CollateralDate,
			GoodFundsDate,
			FinderNbr,
			PoolNbr,
			Comments,
			SettlementInstr,
			SettlementCCY,
			CleanUpFlg,
			TransmitFlg,
			DisclosureType,
			TriPartyGrpID,
			CollSchedID,
			ProductCategory,
			LowDivRate,
			STTLevel,
			STTEndDate,
			STTDivRate,
			BulkNbr,
			ScripEndDate,
			ProductCategoryLoanType,	--LoanType
			ProductCategoryLoanDuration,
			LoanCategory,
			BasketNbr,
	--LIBOR AND Goto Columns
			LIBORRate,			  
			ResetDate,			
			GotoRepoRate,	
			GotoTermDate,
			GotoRemarks,		  		
			GotoSTTLevel,
			GotoSTTDivRate,  		  
			GotoSTTEndDate,
			GotoScripEndDate,
			GotoProductCategory,
			GotoProductCategoryLoanType, 
			GotoProductCategoryLoanDuration,
			DesiredSTTLevel,
			IsProjectedDividend,
			ProjectedDividendAmount,
			BgnRef,  
			GCIRecordType,
			GCIStatus,
			GCITransactionType,
			GCIPostingType,
			GCILenderModuleTrade,
			GCIAutoAuthorised,
			GPTransmit,			
			ExecutionTimestamp,
			IsPrePay,
			TPUID,
			SFTRClosedLoanRefNbr --TODO
		)		
		SELECT DISTINCT
			a.RawDataID,
			a.ExternalRefNbr,
			a.LoanType,
			a.AcctNbr,
			a.Depository,
			a.SecCode,
			a.SettlementDate,
			a.TermDate,
			a.BrkNbr,
			a.FaceAmount,
			a.Price,
			a.TradePrice,
			a.CCYCode,
			a.Principal,
			a.CollCCYCode,
			a.RebateRate,
			a.SecLocCode,
			a.SecID,
			a.BrkID,
	--			a.TxnRefNbr,
			a.RecordTypeID,
			a.BatchDate,
			a.AsOfDate,
			a.CollateralDate,
			a.GoodFundsDate,
			a.FinderNbr,
			a.PoolNbr,
			a.Comments,
			a.SettlementInstr, --a.SettlementInstr, -- M466 – "FI loan booking for cross-currency (European clearing through CEDEL) doesn't work"  --> Pass 2 char SettlementCCY in 'SettlementInstr' Column and NULL in 'SettlementCCY'
			null,			 --a.SettlementCCY,   -- M466 – "FI loan booking for cross-currency (European clearing through CEDEL) doesn't work"  --> Pass 2 char SettlementCCY in 'SettlementInstr' Column and NULL in 'SettlementCCY'
			a.CleanUpFlg,
			a.TransmitFlg,
			a.DisclosureType,
			a.TriPartyGrpID,
			a.CollSchedID,
			a.ProductCategory,
			a.LowDivRate,
			CASE LEN(a.STTLevel) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(5,2),a.STTLevel) END,
			a.STTEndDate,
			CASE LEN(a.STTDivRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(13,6),a.STTDivRate) END,
			a.BulkNbr,
			a.ScripEndDate,
			a.ProductCategoryLoanType,	--LoanType
			a.ProductCategoryLoanDuration,
			a.LoanCategory,
			CASE LEN(a.BasketNbr) WHEN 0 THEN NULL ELSE a.BasketNbr END,	    
	--LIBOR AND Goto Columns
			CASE LEN(a.LIBORRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(20,10),a.LIBORRate) END,	    
			a.ResetDate,			
			CASE LEN(a.GotoRepoRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(20,7),a.GotoRepoRate) END,	    
			a.GotoTermDate,
			a.GotoRemarks,		  		
			NULL, -- CASE LEN(a.GotoSTTLevel) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(5,2),a.GotoSTTLevel) END,
			NULL, -- CASE LEN(a.GotoSTTDivRate) WHEN 0 THEN NULL ELSE CONVERT(DECIMAL(13,6),a.GotoSTTDivRate) END,  		  
			NULL, -- a.GotoSTTEndDate,
			NULL, -- a.GotoScripEndDate,
			a.GotoProductCategory,
			a.GotoProductCategoryLoanType, 
			a.GotoProductCategoryLoanDuration,
			a.DesiredSTTLevel,
			a.IsProjectedDividend,
			a.ProjectedDividendAmount,
			a.BgnRef,
			a.GCIRecordType,
			a.GCIStatus,
			a.GCITransactionType,
			a.GCIPostingType,
			a.GCILenderModuleTrade,
			a.GCIAutoAuthorised,
			a.GPTransmit,			
			a.ExecutionTimestamp,
			a.IsPrePay,
			a.TPUID,
			a.SFTRClosedLoanRefNbr --TODO
			FROM
			(	
				SELECT 
					DISTINCT RawDataID	= rd.[ID],
					ExternalRefNbr	= NULL,
					RecordTypeID	= rd.RecordTypeID,
					BrkId			= rd.BrkID,
					SecID			= rd.SecID,
					AcctNbr			= NULL,
					LoanType		= rd.LoanType,
					Depository		= temp.ClearAgentNbr,
					SecCode			= rd.SecCode,
					SettlementDate	= temp.SettleDate,
					TermDate		= CASE temp.TermDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.TermDate END,
					BrkNbr			= rd.BrkNbr,
					FaceAmount		= rd.FaceAmount,
					Price			= rd.Price,
					PriceOverride	= rd.PriceOverride,
					TradePrice		= rd.Price,
					CCYCode			= rd.CCYCode,
					Principal		= rd.Principal,
					CollCCYCode		= rd.CollCCYCode,
					RebateRate		= rd.RebateRate,
					SecLocCode		= rd.SecLocCode,
					TxnRefNbr		= rd.TxnRefNbr,
					BatchDate		= rd.BatchDate,
					AsOfDate		= rd.AsOfDate,
					CollateralDate	= temp.SettleDate,--CASE temp.CollateralDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.CollateralDate END, --need to confirm
					GoodFundsDate	= temp.SettleDate,--CASE temp.GoodFundDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.GoodFundDate END,
					FinderNbr		= temp.FinderNbr,
					PoolNbr			= NULL,--temp.CMPool, -- need to confirm
					Comments		= tempxml.Comments,
					SettlementInstr = temp.SMODE, -- need to confirm
					SettlementCCY	= NULL,--temp.CCYCode, -- need to confirm
					CleanUpFlg		= NULL,--temp.CleanUpFlg,
					TransmitFlg		= rd.TransmitFlg,
					DisclosureType	= rd.DisclosureType,
					TriPartyGrpID	= temp.TriPartyGrpID,
					CollSchedID		= temp.CollSchedID,
					ProductCategory	= temp.ProductCategory	,
					LowDivRate		= NULL,--temp.LowDivRate,
					STTLevel	= temp.STTLevel,
					STTEndDate	= temp.STTEndDate,
					STTDivRate	= temp.STTDivRate,
					BulkNbr			= rd.BulkNbr,
					ScripEndDate	= temp.ScripEndDate,
					ProductCategoryLoanType = temp.ProductCategoryLoanType,	--LoanType
					ProductCategoryLoanDuration = temp.ProductCategoryLoanDuration,
					LoanCategory					= temp.LoanCategory,
					BasketNbr					    = rd.BasketNbr,		
					LIBORRate						= temp.LIBORRate,			  
					ResetDate						= temp.ResetDate,		
					GotoRepoRate					= temp.GotoRepoRate,	
					GotoTermDate					= temp.GotoTermDate,		
					GotoRemarks						= temp.GotoRemarks,		  		
					GotoSTTLevel				= NULL, --CASE temp.GotoProductCategory WHEN 'DA' THEN temp.GotoSTTLevel ELSE NULL END,
					GotoSTTDivRate				= NULL, --CASE temp.GotoProductCategory WHEN 'DA' THEN (CASE temp.GotoSTTEndDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.GotoSTTEndDate END) ELSE NULL END,  		  
					GotoSTTEndDate				= NULL, --CASE temp.GotoProductCategory WHEN 'DA' THEN temp.GotoSTTDivRate ELSE NULL END,
					GotoScripEndDate				= NULL, --CASE temp.GotoProductCategory WHEN 'ST' THEN (CASE temp.GotoScripEndDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.GotoScripEndDate END) ELSE NULL END,
					GotoProductCategory				= temp.GotoProductCategory,
					GotoProductCategoryLoanType		= temp.GotoProductCategoryLoanType, 
					GotoProductCategoryLoanDuration = temp.GotoProductCategoryLoanDuration,
					DesiredSTTLevel				= temp.DesiredSTTLevel,
					IsProjectedDividend				= temp.IsProjectedDividend,
					ProjectedDividendAmount			= temp.ProjectedDividendAmount,
					BgnRef							= temp.BgnRef,  
					GCIRecordType					= GCIParam.GCIRecordType,
					GCIStatus						= GCIParam.GCIStatus,
					GCITransactionType				= GCIParam.GCITransactionType,
					GCIPostingType					= GCIParam.GCIPostingType,
					GCILenderModuleTrade			= GCIParam.GCILenderModuleTrade,
					GCIAutoAuthorised				= GCIParam.GCIAutoAuthorised,
					GPTransmit						= temp.GPTransmit,					
					ExecutionTimestamp				=  CASE WHEN tempxml.SettlementDate <> tempxml.LoanSettlementDate THEN GETDATE()         -----------If Settlement Date changes then generate new timestamp
															WHEN tempxml.TransmitFlg <> tempxml.GPTransmit THEN temp.CreatedDate			 -----------If Transmit changes then use the same timestamp as Closed loan
															ELSE temp.CreatedDate END,														 -----------If None of the above condiitons then use the same timestamp as Closed loan
					IsPrePay						= temp.IsPrePay,
					TPUID							= temp.TPUID,
					SFTRClosedLoanRefNbr			=  CASE WHEN tempxml.SettlementDate <> tempxml.LoanSettlementDate THEN NULL         -----------If Settlement Date changes then send new UTI i.e SFTRClosedLoanRefNbr should be NULL,
															WHEN tempxml.TransmitFlg <> tempxml.GPTransmit THEN tempxml.TxnRefNbr		-----------If Transmit changes then use then keep the same UTI i.e. SFTRClosedLoanRefNbr should be the TxnRefNbr of closed loan
															ELSE tempxml.TxnRefNbr END													-----------If None of the above condiitons then keep the same UTI i.e. SFTRClosedLoanRefNbr should be the TxnRefNbr of closed loan
				FROM 
					@TempLoan temp
				INNER JOIN
					@TempXMLTable tempxml
				ON
					tempxml.BGNREF = temp.BGNREF AND
					temp.Isstreetside = 1 AND
					temp.BGNREF = @BGNREF				
				INNER JOIN 
					dbo.ETIRawData rd 
				ON	
					rd.SecId = temp.SecId AND
					rd.BrkNbr = temp.BrkNbr AND
					rd.Depository = temp.ClearAgentNbr AND
					rd.ID = @RawDataID AND
					rd.RecordTypeId = @RecordTypeId
				INNER JOIN
					dbo.f_GetGCIParameter(@RecordTypeId,'L',NULL) GCIParam
				ON
					GCIParam.RecordTypeID = rd.RecordTypeID
				INNER JOIN 
					@HistLogTbl hist 
				ON 
					hist.SourceID = rd.SourceID
				WHERE 
					temp.FaceAmount > 0 --insert only account allocated records.
				UNION
				SELECT 
					DISTINCT RawDataID	= rd.[ID],
					ExternalRefNbr	= NULL,
					RecordTypeID	= alloc.RecordTypeID,
					BrkId			= alloc.BrkID,
					SecID			= alloc.SecID,
					AcctNbr			= alloc.AcctNbr,
					LoanType		= alloc.LoanType,
					Depository		= temp.ClearAgentNbr,
					SecCode			= alloc.SecCode,
					SettlementDate	= temp.SettleDate,--NULL,
					TermDate		= CASE temp.TermDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.TermDate END,
					BrkNbr			= alloc.BrkNbr,
					FaceAmount		= alloc.FaceAmount,
					Price			= alloc.Price,
					PriceOverride	= rd.PriceOverride,
					TradePrice		= alloc.Price,
					CCYCode			= alloc.CCYCode,
					Principal		= alloc.Principal,
					CollCCYCode		= alloc.CollCCYCode,
					RebateRate		= alloc.RebateRate,
					SecLocCode		= alloc.SecLocCode,
					TxnRefNbr		= alloc.TxnRefNbr,
					BatchDate		= rd.BatchDate,
					AsOfDate		= rd.AsOfDate,
					CollateralDate	= temp.SettleDate,
					GoodFundsDate	= temp.SettleDate,
					FinderNbr		= temp.FinderNbr,
					PoolNbr			= NULL,--temp.CMPool,
					Comments		= tempxml.Comments,
					SettlementInstr = temp.SMODE,
					SettlementCCY	= NULL,--temp.CCYCode,
					CleanUpFlg		= NULL,--temp.CleanUpFlg,	
					TransmitFlg		= rd.TransmitFlg,
					DisclosureType	= rd.DisclosureType,
					TriPartyGrpID	= temp.TriPartyGrpID,
					CollSchedID		= temp.CollSchedID,
					ProductCategory	= temp.ProductCategory,
					LowDivRate		= NULL,--temp.LowDivRate,
					STTLevel	= temp.STTLevel,
					STTEndDate	= temp.STTEndDate,
					STTDivRate	= temp.STTDivRate,
					BulkNbr			= rd.BulkNbr,
					ScripEndDate	= temp.ScripEndDate,
					ProductCategoryLoanType = temp.ProductCategoryLoanType,	--LoanType
					ProductCategoryLoanDuration = temp.ProductCategoryLoanDuration,
					LoanCategory					= temp.LoanCategory,
					BasketNbr						= rd.BasketNbr,
					LIBORRate						= temp.LIBORRate,
					ResetDate						= temp.ResetDate,		
					GotoRepoRate					= temp.GotoRepoRate,	
					GotoTermDate					= temp.GotoTermDate,		
					GotoRemarks						= temp.GotoRemarks,		  		
					GotoSTTLevel				= NULL,--CASE temp.GotoProductCategory WHEN 'DA' THEN temp.GotoSTTLevel ELSE NULL END,
					GotoSTTDivRate				= NULL,--CASE temp.GotoProductCategory WHEN 'DA' THEN (CASE temp.GotoSTTEndDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.GotoSTTEndDate END) ELSE NULL END,  		  
					GotoSTTEndDate				= NULL,--CASE temp.GotoProductCategory WHEN 'DA' THEN temp.GotoSTTDivRate ELSE NULL END,
					GotoScripEndDate				= NULL,--CASE temp.GotoProductCategory WHEN 'ST' THEN (CASE temp.GotoScripEndDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.GotoScripEndDate END) ELSE NULL END,
					GotoProductCategory				= temp.GotoProductCategory,
					GotoProductCategoryLoanType		= temp.GotoProductCategoryLoanType, 
					GotoProductCategoryLoanDuration = temp.GotoProductCategoryLoanDuration,
					DesiredSTTLevel				= temp.DesiredSTTLevel,
					IsProjectedDividend				= temp.IsProjectedDividend,
					ProjectedDividendAmount			= temp.ProjectedDividendAmount,
					BgnRef							= temp.BgnRef,  
					GCIRecordType					= GCIParam.GCIRecordType,
					GCIStatus						= GCIParam.GCIStatus,
					GCITransactionType				= GCIParam.GCITransactionType,
					GCIPostingType					= GCIParam.GCIPostingType,
					GCILenderModuleTrade			= GCIParam.GCILenderModuleTrade,
					GCIAutoAuthorised				= GCIParam.GCIAutoAuthorised,
					GPTransmit						= NULL,					
					ExecutionTimestamp				=  CASE WHEN tempxml.SettlementDate <> tempxml.LoanSettlementDate THEN GETDATE()        -----------If Settlement Date changes then generate new timestamp
															WHEN tempxml.TransmitFlg <> tempxml.GPTransmit THEN temp.CreatedDate					-----------If Transmit changes then use the same timestamp as Closed loan
															ELSE temp.CreatedDate END,																-----------If None of the above condiitons then use the same timestamp as Closed loan
					IsPrePay						= temp.IsPrePay,
					TPUID							= temp.TPUID,
					SFTRClosedLoanRefNbr			=  CASE WHEN tempxml.SettlementDate <> tempxml.LoanSettlementDate THEN NULL         -----------If Settlement Date changes then send new UTI i.e SFTRClosedLoanRefNbr should be NULL,
															WHEN tempxml.TransmitFlg <> tempxml.GPTransmit THEN tempxml.TxnRefNbr		-----------If Transmit changes then use then keep the same UTI i.e. SFTRClosedLoanRefNbr should be the TxnRefNbr of closed loan
															ELSE tempxml.TxnRefNbr END																-----------If None of the above condiitons then keep the same UTI i.e. SFTRClosedLoanRefNbr should be the TxnRefNbr of closed loan
				FROM 
					@TempLoan temp
				INNER JOIN
					@TempXMLTable tempxml
				ON
					tempxml.BGNREF = temp.BGNREF AND
					temp.Isstreetside = 0 AND
					temp.BGNREF = @BGNREF				
				INNER JOIN 
					dbo.ETIRawData rd 
				ON	
					rd.SecId = temp.SecId AND
					rd.BrkNbr = temp.BrkNbr AND
					rd.Depository = temp.ClearAgentNbr AND
					rd.ID = @RawDataID AND
					rd.RecordTypeId = @RecordTypeId	
				INNER JOIN 
					dbo.ETIAllocation alloc 
				ON 
					alloc.[RawDataID] = rd.[ID] AND
					alloc.SecId = rd.SecId AND
					alloc.BrkNbr = rd.BrkNbr AND
					alloc.AcctNbr = temp.AcctNbr AND
					alloc.Depository = temp.ClearAgentNbr AND
					alloc.RawDataID = @RawDataID
				INNER JOIN
					dbo.f_GetGCIParameter(@RecordTypeId + 1,NULL,NULL) GCIParam
				ON
					GCIParam.RecordTypeID = alloc.RecordTypeID
				INNER JOIN 
					@HistLogTbl hist 
				ON 
					hist.SourceID = rd.SourceID
				WHERE 
					temp.FaceAmount > 0 --insert only account allocated records.
			) a

