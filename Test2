		INNER JOIN
		(
			SELECT SecId,ClearAgentNbr, MIN(NetDividendPercentage) NetDividendPercentage FROM @TempLoan GROUP BY SecID,ClearAgentNbr
		)Temp
		ON
			Temp.SecID = Dtl.SecID AND
			Temp.ClearAgentNbr = Dtl.WLDepository AND
			Dtl.RecordTypeId = 1

		UPDATE 
			@ETIDetailRecordNewLoan
		SET 		
			NetDividendPercentage = NULL
		WHERE
