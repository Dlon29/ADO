			  )  
			  SELECT   
				   DISTINCT @SourceId,	
				   temp.EquilendId,		   	  
				   temp.SecId,  
				   @BrkId,  
				   NULL,    
				   @RecordTypeID,   
				   NULL,  
				   temp.SecLocCode,  
				   temp.SecCode,  
				   temp.FaceAmount,  
				   temp.Price, -- Price  
				   NULL, -- PriceOverride  
	--			   CASE b.BusinessInd  
	--				WHEN 'FI' THEN  
	--					ROUND((temp.FaceAmount * temp.Price) / 100,2)			 
	--				ELSE 			 
	--					ROUND((temp.FaceAmount * temp.Price),2)
	--			   END, 
				   temp.Principal,  
				   ISNULL(temp.PriceCurr, ''),  
				   temp.CollCCY, -- CollateralCCY  
				   CASE temp.SettlementDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.SettlementDate END,  
				   CASE temp.termDate WHEN '1900-01-01 00:00:00.000' THEN NULL ELSE temp.termDate END,  
				   temp.BrkNbr,  
				   temp.WLDepository,  
				   temp.FinderNbr,	
				   temp.CollType,  
				   CASE @CollateralType WHEN 'CD' THEN NULL ELSE temp.Disclosure END,--temp.Disclosure,  
				   temp.RebateRate,  
				   @BatchDate,  
				   temp.AsOfDate,  
				   1, -- IsValid  
				   0, -- ErrorBitMap  
				   @StatusId,  
				   temp.TransmitFlg,  
				   1,	
				   @ModifiedBy,  
				   @ModifiedDate
			  FROM   
				   @TempXMLTable temp   
			  INNER JOIN   
				   dbo.Broker b   
			  ON   
				   b.BrkID = @BrkID AND  
				   @BatchDate BETWEEN b.EffectiveDateBegin AND b.EffectiveDateEnd  
			  LEFT JOIN   
				   MOBETTER.DBO.Broker bs
			  ON   
				   bs.BrkID = b.BrkID    AND
				   @BatchDate BETWEEN bs.EffectiveDateBegin AND bs.EffectiveDateEnd AND
				   ISNULL(bs.IsDeleted,0) = 0     
			  WHERE 
				  temp.BrkNbr = @BrkNbr AND
				  temp.SecID = @SecId  AND   
				  temp.FaceAmount > 0   
		  	  
				  SET @ERROR_NO = @@ERROR  

			 SELECT @RawDataID = @@IDENTITY
	  
			 /***** 3rd step : Insert into dbo.ETIAllocation table ****/  
			 INSERT INTO dbo.ETIAllocation  
			 (  
				  [RawDataID],  
				  [SourceID],  
				  [SecID],  
				  [BrkID],  
				  [AcctId],  
				  [AcctNbr],  
				  [RecordTypeID],  
				  [SecLocID],  
				  [SecCode],  
				  [FaceAmount],  
				  [Price],  
				  [Principal],  
				  [CCYCode],  
				  [CollCCYCode],  
				  [SettlementDate],  
				  [BrkNbr],  
				  [SecLocCode],  
				  [Depository],  
				  [LoanType],  
				  [RebateRate],  
				  [TxnRefNbr],  
				  [StatusID]		
			 )  
			 SELECT   
				  DISTINCT rd.ID,  
				   rd.SourceID,  
				   rd.SecId,  
				   rd.BrkID,  
				   Acc.AcctId,  
				   Acc.AcctNbr,  
				   (@RecordTypeID + 1),  
				   NULL,  
				   rd.SecCode,  
				   rd.FaceAmount,  
				   CASE WHEN rd.PriceOverride IS NOT NULL THEN rd.PriceOverride ELSE rd.Price END,  
				   rd.Principal,   
				   rd.CCYCode,  
				   rd.CollCCYCode,  
				   rd.SettlementDate,  
				   rd.BrkNbr,  
				   rd.SecLocCode,  
				   temp.WLDepository,  
				   rd.LoanType,  
				   rd.RebateRate,  
				   rd.TxnRefNbr,  
				   @StatusID		   
			 FROM   
				  @TempXMLTable temp   
			 INNER JOIN   
				  dbo.ETIRawData rd   
			 ON   
				  rd.SourceID = @SourceId  AND   
				  rd.RecordTypeId = @RecordTypeId AND  
				  rd.SecId = temp.SecId AND  		
				  rd.BrkNbr = temp.BrkNbr  	 
			 INNER JOIN   
				  MOBETTER.dbo.Account Acc  
			 ON   
				  Acc.AcctNbr = temp.AcctNbr AND   
				  @BatchDate BETWEEN Acc.EffectiveDateBegin AND Acc.EffectiveDateEnd AND  
				  Acc.IsDeleted = CONVERT(BIT, 0)        
			 WHERE 
				  temp.BrkNbr = @BrkNbr AND
				  temp.SecID = @SecId  AND
				  rd.FaceAmount > 0 AND --insert only account allocated records. 
				  ((@IsRevRepoLoan = 0) OR (@IsRevRepoLoan = 1 AND rd.ID = @RawDataID)) 	
	  
			 /***** 4th step : Insert into dbo.ETIDetailRecord table ****/  
			 DELETE FROM @ETIDetailRecord  
	  
			 /***** 4th step : Insert into dbo.ETIDetailRecord table ****/  
			 /* Insert one OMNI and other Accounts record into temp ETIDetailRecord table*/  
			 INSERT INTO @ETIDetailRecord   
			 (  
				  RawDataID,  
				  EquilendId,
				  ExternalRefNbr,  
				  LoanType,  
				  AcctNbr,  
				  WLDepository,  
				  SecCode,  
