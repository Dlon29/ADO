				  a.Depository,  
				  a.SecCode,  
				  a.SettlementDate,  
				  a.TermDate,  
				  a.BrkNbr,  
				  a.FaceAmount,  
				  a.Price,  
				  a.TradePrice,  
				  a.CCYCode,  
				  a.Principal,  
				  a.CollCCYCode,  
				  a.RebateRate,  
				  a.SecLocCode,  
				  a.SecID,  
				  a.BrkID,  
				  a.TxnRefNbr,  
				  a.RecordTypeID,  
				  a.BatchDate,  
				  a.AsOfDate,  	
				  a.FinderNbr,  
				  a.Comments,  
				  a.SettlementInstr,  
				  a.SettlementCCY,  
				  a.CleanUpFlg,  
				  a.TransmitFlg,  
				  a.DisclosureType,  
				  a.TriPartyGrpID,  
				  a.CollSchedID,
				  a.CollateralNo,
				  a.GCIRecordType,
				  a.GCIStatus,
				  a.GCITransactionType,
				  a.GCIPostingType,
				  a.GCILenderModuleTrade,
				  a.GCIAutoAuthorised,
				  a.RRLinkRefNbr,
				  a.RepoTicketID	  	
			 FROM  
			  (   
				   SELECT   
						DISTINCT RawDataID = rd.[ID],  				
						EquilendId = rd.EqlEquiLendID,
						ExternalRefNbr = NULL,  				
						RecordTypeID = rd.RecordTypeID,  
