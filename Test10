						hist.SourceID = rd.SourceID AND  
						hist.RecordTypeID = rd.RecordTypeID  
				   WHERE 
						temp.SecID = @SecId AND
						temp.BrkNbr = @BrkNbr AND  
						temp.FaceAmount > 0 AND--insert only account allocated records.
						((@IsRevRepoLoan = 0) OR (@IsRevRepoLoan = 1 AND rd.ID = @RawDataID)) 	  
