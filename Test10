							RRLinkRefNbr = temp.RRLinkRefNbr,
							RepoTicketID = temp.RepoTicketID
					   FROM   
							@TempXMLTable temp   
					   INNER JOIN   
							dbo.ETIRawData rd   
					   ON       
							rd.SecId = temp.SecId AND  
							rd.BrkNbr = temp.BrkNbr 
					   INNER JOIN   
							dbo.ETIAllocation alloc   
					   ON   
							alloc.[RawDataID] = rd.[ID] AND  
							alloc.SecId = rd.SecId  
						INNER JOIN
							dbo.f_GetGCIParameter(@RecordTypeID + 1,@CollateralType,NULL) GCIParam
						ON
							GCIParam.RecordTypeID = alloc.RecordTypeID
					   INNER JOIN   
							@HistLogTbl hist   
					   ON   
							hist.SourceID = rd.SourceID AND  
							hist.RecordTypeID = rd.RecordTypeID    
					   WHERE 
							temp.SecID = @SecId AND
							temp.BrkNbr = @BrkNbr AND    
							alloc.FaceAmount > 0 AND--insert only account allocated records. 
							((@IsRevRepoLoan = 0) OR (@IsRevRepoLoan = 1 AND rd.ID = @RawDataID)) 	 			  
			  
			  ) a  
