ALTER PROCEDURE [dbo].[p_ETIBookNewCollateral_Test]
(
	@SQL_IDENTIFIER		VARCHAR(10),
	@SQL_CONDITION1		VARCHAR(MAX),
	@SQL_CONDITION2		VARCHAR(10)
)
AS
BEGIN  
   
	 SET NOCOUNT ON  
	 SET ARITHABORT ON -- Need to set this option else proc throws exception  
	  
	 DECLARE @SourceID INT,  
	   @ModifiedDate DATETIME, @Ret SMALLINT, @BrkCrGrpID INT,@BrkGrpID INT, @BrkID INT, @SecId INT,  
	   @LastPriceDate DATETIME, @ERROR_NO INT,@BatchID INT,@RecordIndicator VARCHAR(3),@TOE VARCHAR(3),@hXmlDoc INT,  
	   @hdoc INT, @StatusId INT,@Count INT, @TotalCount INT,@RawDataID INT,   
	   @hdoc1 INT,@TxnRefNbr INT,@SettlementDate DATETIME,@SecCode VARCHAR(12),  
	   @AcctID INT,@AcctNbr VARCHAR(12),@BrkNbr VARCHAR(50),@Quantity BIGINT,@RecordTypeID INT,  
	   @FileName VARCHAR(50),@BatchDate DATETIME,@TradePrice NUMERIC(20,7),@TransmitFlg VARCHAR(1),@ModifiedBy VARCHAR(50),  
	   @LoanType VARCHAR(1),@CCYCode VARCHAR(3),@CollCCYCode VARCHAR(3),@SecLocCode VARCHAR(2),  
	   @WLDepository VARCHAR(10) , @BatchNbr INT, @IsLoanBreak BIT,@MaxLoanAmount BIGINT, @RemFaceAmount BIGINT,@RowCount INT,@AcctCount INT,
	   @TotalAcctCount INT, @TempFaceAmount BIGINT, @TempAcctAvail BIGINT, @TempUnUsedUnits BIGINT,@NeedFaceAmount BIGINT, @AcctFaceAmountSum BIGINT,
	   @TempFaceAmountFromAlloc BIGINT,@TempAvailRestOverriden BIT,@LoanNbr INT, @FaceAmount BIGINT,@GPTransmit VARCHAR(1), @CollateralType VARCHAR(2), 
	   @CollRemedyCode VARCHAR(1), @BucketSecType CHAR(2), @RepoTicketID INT, @CurrentRecLendingProcessTypeID INT, 
	   @RevRepoLendingProcessID INT, @RevRepoLendingProcess VARCHAR(10), @IsRevRepoLoan BIT,
	   @SecIdCurrentRow INT, @BrkNbrCurrentRow VARCHAR(50), @SecCodeCurrentRow VARCHAR(12),
	   @LoanStatus_NotChecked INT, @LoanStatus_InputChecked_UnVerified INT, @LoanStatus INT, @G1UserCode Varchar(8)

	 IF (@SQL_CONDITION1 = '')  
	 BEGIN
		SELECT @SQL_CONDITION1 = convert(varchar(8000), NULLIF(@SQL_CONDITION1, ''))  
	 END

	 IF NULLIF(@SQL_CONDITION1, '') IS NULL RETURN 
	 
	 SET @IsRevRepoLoan = 0 
	 
	 SET @RevRepoLendingProcess = 'RevRepo'
	 SELECT @RevRepoLendingProcessID = LendingProcessTypeID FROM LendingProcessType WHERE LendingProcessName = @RevRepoLendingProcess	  
	 
	 ----Set the Loan Stauses------
	SET @LoanStatus_NotChecked = 0
	SET @LoanStatus_InputChecked_UnVerified = 9

	 DECLARE @TempXMLTable TABLE   
	 (  
			RowID    INT IDENTITY(1,1), 		  
			AsOfDate   DATETIME,  
			SettlementDate  DATETIME,  
			SecCode    VARCHAR(12),  
			SecID    INT,  
			BucketSecType  CHAR(2),   
			WLDepository  VARCHAR(12),       
			BrkID    INT,  
			BrkNbr    VARCHAR(12),  
			AcctId    INT,  
			Acctnbr    VARCHAR(12),  
			FaceAmount   BIGINT,    
			Price    DECIMAL(20,6),  
			PriceCurr   VARCHAR(3), 
			Principal DECIMAL(17,2),	 
			RecordTypeID  INT,  
			BatchDate   DATETIME,  
			TransmitFlg   VARCHAR(1),  
			FinderNbr   VARCHAR(10),  
			TermDate   DATETIME,  
			SecLocCode   VARCHAR(12),  		 
			CollCCY    VARCHAR(3),  
			Disclosure   VARCHAR(1),  
			RebateRate   DECIMAL(9,6),  
			CleanUpFlg   VARCHAR(1),  
			CollateralNo  VARCHAR(12),    
			Comments   VARCHAR(20),  
			SettlementInstr  VARCHAR(30),  
			SettlementCCY  VARCHAR(6),  
			ModifiedBy   VARCHAR(50),  
			TriPartyGrpID  INT,   
			CollSchedID   INT,  		
			IsProcessed   BIT, 
			EquilendId  BIGINT,
			CollType CHAR(1),
			IsCollateral INT,
			GPTransmit	VARCHAR(1),
			CollateralType VARCHAR(2),
			RepoTicketID INT,
			RRLinkRefNbr VARCHAR(8)
	 )  

	  DECLARE @TempXMLSecBrkTable TABLE   
	 (  
		  RowID    INT IDENTITY(1,1), 		  
		  SecID    INT, 
		  SecCode   VARCHAR(12),  
		  BrkNbr    VARCHAR(12) 
	 )

	 DECLARE @ETIDetailRecord TABLE   
	 (  
		  ID    INT IDENTITY(1,1),  
		  RawDataID  INT,  
		  TxnRefNbr	 INT,
		  ExternalRefNbr VARCHAR(12),  
		  LoanType  CHAR(1),  
		  AcctNbr   VARCHAR(12),  
		  WLDepository VARCHAR(10),  
		  SecCode   VARCHAR(12),  
		  SettlementDate DATETIME,  
		  TermDate  DATETIME,  
		  BrkNbr   VARCHAR(6),  
		  FaceAmount  NUMERIC(13, 0),  
		  RawPrice  DECIMAL(14, 7),  
		  TradePrice  DECIMAL(14, 7),  
		  CCYCode   VARCHAR(3),  
		  Principal  DECIMAL(17, 2),  
		  CollCCYCode  VARCHAR(3),  
		  RebateRate  DECIMAL(9, 6),  
		  SecLocCode  VARCHAR(2),  
		  SecID   INT,  
		  BrkID   INT,  
		  RecordTypeID SMALLINT,  
		  BatchDate  DATETIME,  
		  AsOfDate  DATETIME,   		
		  FinderNbr  VARCHAR(6),  
		  PoolNbr   VARCHAR(6),  
		  CollateralNbr VARCHAR(12),
		  Comments  VARCHAR(20),  		  	
		  SettlementInstr VARCHAR(30),  
		  SettlementCCY VARCHAR(6),  
		  CleanUpFlg  VARCHAR(1),  
		  TransmitFlg  VARCHAR(1),  
		  DisclosureType VARCHAR(1),  
		  TriPartyGrpID INT,   
		  CollSchedID  INT,  		
		  EquilendId  BIGINT NULL,
		  GCIRecordType	VARCHAR(1),
		  GCIStatus		VARCHAR(1),
	      GCITransactionType	VARCHAR(1),
		  GCIPostingType	VARCHAR(3),
		  GCILenderModuleTrade	 VARCHAR(1),
		  GCIAutoAuthorised	VARCHAR(1),
		  RepoTicketID INT,
		  RRLinkRefNbr VARCHAR(8)
	 )  	   
	
	  
	 DECLARE @HistLogTbl TABLE   
	 (  
		  RowId INT IDENTITY(1,1),  
		  SourceId INT,   
		  BrkCrGrpId INT,  
		  BrkId INT,  
		  RecordTypeID INT  
	 )

	 CREATE TABLE #AcctTbl 
	(
		RowId INT IDENTITY(1,1),
		RawDataId INT,
		SourceID INT,
		RecordTypeID INT,
		BatchDate DATETIME,
		SecID INT,
		AcctId	INT,
		AcctNbr VARCHAR(12),
		BrkNbr  VARCHAR(12),
		FaceAmountFromAlloc BIGINT,
		FaceAmountActual BIGINT,
		AccountAllocationChanged BIT,
		AvailRestOverriden BIT,
		ModifiedBy VARCHAR(50),
		ModifiedDate DATETIME,
		IsProcessed BIT
	)

	CREATE TABLE #TempAcctTbl 
	(
		RowId INT IDENTITY(1,1),
		RawDataId INT,
		SourceID INT,
		RecordTypeID INT,
		BatchDate DATETIME,
		SecID INT,
		AcctId	INT,
		AcctNbr VARCHAR(12),
		BrkNbr  VARCHAR(12),
		FaceAmountFromAlloc BIGINT,
		FaceAmountActual BIGINT,
		AccountAllocationChanged BIT,
		AvailRestOverriden BIT,
		ModifiedBy VARCHAR(50),
		ModifiedDate DATETIME,
		LoanNbr INT,
		IsProcessed BIT
	)
	  
	 EXEC SP_XML_PREPAREDOCUMENT @hdoc output, @SQL_CONDITION1   
	  
	 /** Insert data into temp table for processing **/  
	 INSERT INTO @TempXMLTable  
	 (  		  
		  AsOfDate,  
		  SettlementDate,  
		  SecCode,  
		  SecID,  
		  BucketSecType,   
		  WLDepository,       
		  BrkID,  
		  BrkNbr,  
		  AcctId,  
		  AcctNbr,  
		  FaceAmount,    
		  Price,  
		  PriceCurr,  
		  Principal,
		  RecordTypeID,  
		  BatchDate,  
		  TransmitFlg,  
		  FinderNbr,  
		  TermDate,  
		  SecLocCode,  		
		  CollCCY,  
		  Disclosure,  
		  RebateRate,  
		  CleanUpFlg,  
		  CollateralNo,    
		  Comments,  
		  SettlementInstr,  
		  SettlementCCY,  
		  ModifiedBy,    
		  TriPartyGrpID,  
		  CollSchedID,  		   
		  IsProcessed,  
		  EquilendId,
		  CollType,
		  GPTransmit,
		  CollateralType,
		  RRLinkRefNbr,
		  RepoTicketID
	 )  
	 SELECT
		  AsOfDate,  
		  SettlementDate,  
		  SecCode,  
		  SecID,  
		  BucketSecType,   
		  WLDepository,       
		  BrkID,	
		  UPPER(BrkNbr),  
		  AcctId,  
		  AcctNbr,  
		  Quantity,    
		  Price,  
		  PriceCurr,  
		  Principal,
		  RecordTypeID,  
		  BatchDate,  
		  TransmitFlg,  
		  FinderNbr,  
		  TermDate,  
		  SecLocCode,  		  
		  CollCCY,  
		  Disclosure,  
		  RebateRate,  
		  CleanUpFlg,  
		  CASE WHEN LEN(CollateralNo) = 0 THEN NULL ELSE CollateralNo END,    
		  Comments,  
		  SettlementInstr,  
		  SettlementCCY,  
		  ModifiedBy,    
		  TriPartyGrpID,  
		  CollSchedID,  		  
		  0,  
		  EquilendId,
		  CollType,
		  GPTransmit,
		  CollateralType,
		  CASE WHEN RRLinkRefNbr = '' THEN NULL ELSE RRLinkRefNbr END,
		  RepoTicketID
	 FROM   
	 OPENXML(@hdoc, '/NewCollateral/FieldName', 1)  
	 WITH  
		 (  			  
			  AsOfDate   DATETIME,  
			  SettlementDate  DATETIME,  
			  SecCode    VARCHAR(12),  
			  SecID    INT,  
			  BucketSecType  CHAR(2),   
			  WLDepository  VARCHAR(12),         
			  BrkID    INT,   
			  BrkNbr    VARCHAR(12),  
			  AcctId    INT,  
			  AcctNbr    VARCHAR(12),  
			  Quantity   BIGINT,    
			  Price    NUMERIC(20,6),  
			  PriceCurr   VARCHAR(3),  
			  Principal   NUMERIC(17,2),	
			  RecordTypeID  INT,  
			  BatchDate   DATETIME,  
			  TransmitFlg   VARCHAR(1),  
			  FinderNbr   VARCHAR(10),  
			  TermDate   DATETIME,  
			  SecLocCode   VARCHAR(12),  			
			  CollCCY    VARCHAR(3),  
			  Disclosure   VARCHAR(1),  
			  RebateRate   DECIMAL(9,6),  
			  CleanUpFlg   VARCHAR(1),  
			  CollateralNo  VARCHAR(12),    
			  Comments   VARCHAR(20),  
			  SettlementInstr  VARCHAR(30),  
			  SettlementCCY  VARCHAR(6),  
			  ModifiedBy   VARCHAR(50),    
			  TriPartyGrpID  INT,   
			  CollSchedID   INT,  			
			  EquilendId    INT ,
			  CollType      CHAR(1),
			  GPTransmit	VARCHAR(1),
			  CollateralType VARCHAR(2),
			  RRLinkRefNbr VARCHAR(8),
			  RepoTicketID INT
		 )  

	  
	 EXEC SP_XML_REMOVEDOCUMENT @hdoc  	 

	 --SELECT * FROM @TempXMLTable

	 --RETURN
	
	 --Batch date from LAVA single loan request/Bulk loan screen may be incorrect. So use it from G1  
	 /** Get G1 batch date **/  
	  
	 SELECT   
		@BatchDate = CurrentBatchDate   
	 FROM   
		GlobalOne.dbo.vw_G1_System

	SET @IsLoanBreak = CONVERT(BIT,@SQL_CONDITION2)
	SET @MaxLoanAmount = 50000000
	  
	SET @Count = 1 
	SELECT @TotalCount = COUNT(*) FROM @TempXMLTable

	--For Reverse Repo Collateral booking, we need to process only 1 row from temp table. For that remainng row's SecID and BrkNbr will be set to NULL
	--Keep a backup of original SecID and BrkNbr combination in a backup table
	INSERT INTO 
		@TempXMLSecBrkTable
	SELECT 		  
		SecID, 
		SecCode,  
		BrkNbr
	FROM
		@TempXMLTable
	ORDER BY
		RowID

	SELECT TOP 1
		 @RepoTicketID = RepoTicketID
	 FROM   
		@TempXMLTable 

	SELECT @CurrentRecLendingProcessTypeID = LendingProcessType FROM RepoTicket WHERE RepoTicketID = @RepoTicketID

	IF (@CurrentRecLendingProcessTypeID = @RevRepoLendingProcessID)
	BEGIN
		SET @IsRevRepoLoan = 1
	END 
	
	WHILE (@Count <= @TotalCount)
	BEGIN
	----------For booking Reverse Repo Collaterals, we need to consider all the rows in XML as differnt Collaterals hence we will update the SecID and BrkNbr of other records(other than that is being processed) to NULL--------------------- 
	----------If we have 2 records for 1 security 50MM and 25MM then duplicate records should not be inserted --------------------- 
		IF (@IsRevRepoLoan = 1)
		BEGIN
			SELECT
				@SecIdCurrentRow = SecID,
				@SecCodeCurrentRow = SecCode,
				@BrkNbrCurrentRow = BrkNbr
			FROM
				@TempXMLSecBrkTable
			WHERE 
				RowID = @Count

			UPDATE
				@TempXMLTable 
			SET
				SecID = CASE WHEN RowID = @Count THEN @SecIdCurrentRow ELSE NULL END,
				SecCode = CASE WHEN RowID = @Count THEN @SecCodeCurrentRow ELSE NULL END,
				BrkNbr = CASE WHEN RowID = @Count THEN @BrkNbrCurrentRow ELSE NULL END
		END

	 /* Get the common values in variables */  
	 SELECT 
		 @SecCode = SecCode,  
		 @BrkNbr = BrkNbr,  	
		 @RecordTypeID = RecordTypeID,
		 @ModifiedBy = ModifiedBy,
		 @GPTransmit = GPTransmit,
		 @CollateralType = CollateralType,
		 @AcctNbr = AcctNbr,
		 @FaceAmount = FaceAmount,
		 @LoanType = CollType,
		 @BucketSecType = BucketSectype
	 FROM   
		@TempXMLTable 
	WHERE
		RowID = @Count
	  
	

	 SELECT   
	--	  @BusinessInd = b.BusinessInd,  
		  @BrkID = b.BrkID,  
		  @BrkGrpID = bg.BrkGrpID,   
		  @BrkCrGrpID = bg.BrkCrGrpID  
	 FROM  
		  dbo.Broker b  
	 INNER JOIN   
		  dbo.BrokerGroup bg  
	 ON  
		  bg.BrkGrpID = b.BrkGrpID and  
		  (b.EffectiveDateBegin BETWEEN bg.EffectiveDateBegin AND bg.EffectiveDateEnd) AND   
		  ISNULL(bg.IsDeleted,0) = 0  
	 WHERE  
		  BrkNbr = @BrkNbr AND  
		  @BatchDate BETWEEN b.EffectiveDateBegin AND b.EffectiveDateEnd AND   
		  ISNULL(b.IsDeleted,0) = 0    
	 
	 SELECT @G1UserCode = dbo.f_GetG1LavaUserMapping (@ModifiedBy) 
	 
	 /* Set default values to be inserted*/  
	 SELECT   
		  @ModifiedDate  = GETDATE(),  
		  @RecordIndicator = 'DTL',  
		  @TOE    = 'GPL',  
		  @ModifiedBy   = ISNULL(@ModifiedBy, SUSER_SNAME())  
	 
	
	----------------If Collateral is for Reverse Repo then status should be 35 i.e. Pending Approval-----------------
	IF (@IsRevRepoLoan = 1)
	BEGIN
		SET @StatusId = 999 
		SET @LoanStatus = @LoanStatus_InputChecked_UnVerified       ---Only for Reverse Repo Collaterals , LoanStatus should be 9
	END
	ELSE
	BEGIN
		SET @StatusId = 999 
		SET @LoanStatus = @LoanStatus_NotChecked					----For other Collaterals, LoanStatus should be 0
	END 

	 -- If Temporary Table exists and Data exists in Temporary Table then only set StatusID from  Temporary Table.
	 -- This Table is created in BDAS Bulk Collatateral Booking SP - p_SaveData_BDASBookORReturnCollateral
	 -- This we are doing to keep Same batchId, for Multiple Collateral booking senario.
	 IF OBJECT_ID('tempdb.dbo.#TempBDASCollateralStatusID') IS NOT NULL
	 BEGIN
		 IF EXISTS( SELECT 1 FROM #TempBDASCollateralStatusID)
		 BEGIN
			SELECT TOP 1  @StatusId = StatusID FROM #TempBDASCollateralStatusID
		 END
	 END
	
  
	 TRUNCATE TABLE #AcctTbl
	 TRUNCATE TABLE #TempAcctTbl
	  
	 /* Get SecId based on SecCode */  
	 SELECT    
		  @SecId = SecId,  
		  @CCYCode = CCYCode  
	 FROM    
		  dbo.f_GetSecurityDetail (@SecCode, NULL)  
	  
	 UPDATE  
		 @TempXMLTable  
	 SET   
		SecID = @SecID  
	 WHERE
		RowID = @Count

	--- WL ETI accepts only CUSIP
	SELECT 
		@SecCode = CUSIP
	FROM
		GLOBALONE.dbo.vw_G1_Security
	WHERE 
		SecID = @SecId

	 IF (@SecCode IS NULL OR @SecCode = '')
	 BEGIN
			RAISERROR (N'This Security does not exist in G1.', 16, 1)
			RETURN 1
	 END
	   
	--- WL ETI accepts only CUSIP  	  
	 UPDATE   
		@TempXMLTable  
	 SET   
		SecCode = Sec.CUSIP  
	 FROM   
		@TempXMLTable temp  
	 INNER JOIN   
		GlobalOne.dbo.vw_G1_Security Sec  
	 ON   
		temp.SecID = Sec.SecID 
	WHERE
		temp.RowID = @Count
		
	/* Get all the accounts */
	INSERT INTO #AcctTbl 
	(
		SecID,			
		AcctId,
		AcctNbr,
		BrkNbr,
		FaceAmountFromAlloc,
		FaceAmountActual,
		IsProcessed
	)
	SELECT DISTINCT 
		temp.SecID,	
		temp.AcctId,
		temp.Acctnbr,
		temp.BrkNbr,
		temp.FaceAmount,
		temp.FaceAmount,		
		0 --IsProcessed
	FROM 
		@TempXMLTable temp
	WHERE	
		BrkNbr = @BrkNbr AND
		SecID = @SecId AND
		RowID = @Count
	ORDER BY 
		temp.FaceAmount DESC


	IF ((@CollateralType = 'CD') AND ( @LoanType != 'C'))
	BEGIN
		IF NOT EXISTS(SELECT AcctNbr FROM CtrIntradayLoanRequestAvailability WHERE SecID = @SecId AND UnitsLendableRem >= @FaceAmount aNd AcctNbr = @AcctNbr)
		BEGIN
			RAISERROR ( 'Insufficient availability in the account.', 16, 1 )
			RETURN
		END
		ELSE
		BEGIN
			UPDATE 
				@TempXMLTable
			SET 
				WLDepository = ISNULL(LTRIM(RTRIM(GLOBALONE.dbo.f_RemoveHeaderZero(Depo.CM_ACCT_NO))), '')--ctrAval.WLDepository
			FROM 
				@TempXMLTable Temp
			INNER JOIN 
				CtrIntradayLoanRequestAvailability ctrAval
			ON 
				temp.SecID = ctrAval.SecID AND
				temp.AcctNbr = ctrAval.AcctNbr	
			INNER JOIN
				GLOBALONE.dbo.DEPOT Depo
			ON
				Depo.SMODE = temp.SettlementInstr AND
				ctrAval.WLDepository = ISNULL(LTRIM(RTRIM(GLOBALONE.dbo.f_RemoveHeaderZero(Depo.CM_ACCT_NO))), '')
			WHERE
				RowID = @Count					
		END

	
	END

	IF ( @CollateralType = 'CD') AND ( @LoanType = 'C')
	BEGIN
		-- For Collateral Out, TripartyGrpId and CollSchedId will be NULL [ LoanType 'C' , WLDepository = 'FED'
		--UPDATE 
		--	@TempXMLTable
		--SET
		--	WLDepository = CASE @LoanType WHEN 'C' THEN 'FED' ELSE WLDepository END,
		--	TriPartyGrpID = NULL,
		--	CollSchedId = NULL

		--Fixed for following : Unable to book Delivered collateral from LAVA for FICC
		UPDATE
			@TempXMLTable
		SET
			WLDepository = LTRIM(RTRIM(GLOBALONE.dbo.f_RemoveHeaderZero(Depot.CM_ACCT_NO))),
			TriPartyGrpID = NULL,
			CollSchedId = NULL
		FROM 
			@TempXMLTable tmp
		INNER JOIN
			GLOBALONE.dbo.DEPOT Depot
		ON  
			Depot.SMODE = tmp.SettlementInstr
		WHERE
			RowID = @Count
	END

		
	SET @RemFaceAmount = 0 

	IF 
	(
		@IsLoanBreak = 1
	)
	BEGIN
		SET @RowCount  = 1
		SET @AcctCount = 1
			SELECT @TotalAcctCount = MAX(RowId) FROM #AcctTbl WHERE secID = @SecId AND FaceAmountActual > 0 --COUNT(*) FROM #AcctTbl
			
			WHILE (@AcctCount <= @TotalAcctCount OR ((SELECT COUNT(*) FROM #AcctTbl WHERE IsProcessed = 0  AND secID = @SecId AND FaceAmountActual > 0) > 0))
		BEGIN

			SET @NeedFaceAmount = @MaxLoanAmount	
			SET @RemFaceAmount = 0
			SET @AcctFaceAmountSum = 0
			SET @Acctnbr = NULL

			SELECT TOP 1 
					@Acctnbr = Acctnbr, 
					@AcctId = AcctId ,
					@TempFaceAmount = FaceAmountActual,
					@TempFaceAmountFromAlloc = FaceAmountFromAlloc, 
					@TempAvailRestOverriden = AvailRestOverriden
			FROM 
				#AcctTbl 
			WHERE 
				IsProcessed = 0 AND 
					secID = @SecId AND 
					FaceAmountActual > 0 
			ORDER BY 
				Acctnbr


				WHILE (@NeedFaceAmount > 0  AND ISNULL(@AcctFaceAmountSum,0) < @MaxLoanAmount AND ((SELECT COUNT(*) FROM #AcctTbl WHERE IsProcessed = 0 AND secID = @SecId AND FaceAmountActual > 0) > 0))
			BEGIN
				SELECT @AcctFaceAmountSum = SUM(FaceAmountActual) FROM #TempAcctTbl WHERE LoanNbr = @RowCount  AND secID = @SecId  

				IF (@TempFaceAmount > @MaxLoanAmount AND ISNULL(@AcctFaceAmountSum,0) = 0)
				BEGIN
					INSERT INTO #TempAcctTbl (AcctId,secID,AcctNbr,BrkNbr,FaceAmountFromAlloc,FaceAmountActual,AvailRestOverriden,LoanNbr,IsProcessed)
					VALUES (@AcctId,@SecId,@Acctnbr,@BrkNbr,@TempFaceAmountFromAlloc,@MaxLoanAmount,@TempAvailRestOverriden,@RowCount,0)

					UPDATE #AcctTbl SET IsProcessed = 1 WHERE Acctnbr = @Acctnbr AND secID = @SecId
					SET @RemFaceAmount = @TempFaceAmount - @MaxLoanAmount--0

					INSERT INTO #AcctTbl (AcctId,secID,AcctNbr,BrkNbr,FaceAmountFromAlloc,FaceAmountActual,AvailRestOverriden,IsProcessed)
					VALUES (@AcctId,@SecId,@Acctnbr,@BrkNbr,@TempFaceAmountFromAlloc,@RemFaceAmount,@TempAvailRestOverriden,0)
				END
				ELSE 
				BEGIN
					IF ((ISNULL(@AcctFaceAmountSum,0) + @TempFaceAmount) > @MaxLoanAmount)
					BEGIN
						INSERT INTO #TempAcctTbl (AcctId,secID,AcctNbr,BrkNbr,FaceAmountFromAlloc,FaceAmountActual,AvailRestOverriden,LoanNbr,IsProcessed)
						VALUES (@AcctId,@SecId,@Acctnbr,@BrkNbr,@TempFaceAmountFromAlloc,
							CASE WHEN @TempFaceAmount < @NeedFaceAmount THEN @TempFaceAmount ELSE @NeedFaceAmount END ,@TempAvailRestOverriden,@RowCount,0)

						SET @RemFaceAmount = @TempFaceAmount - @NeedFaceAmount
						UPDATE #AcctTbl SET IsProcessed = 1 WHERE Acctnbr = @Acctnbr  AND secID = @SecId

						INSERT INTO #AcctTbl (AcctId,secID,AcctNbr,BrkNbr,FaceAmountFromAlloc,FaceAmountActual,AvailRestOverriden,IsProcessed)
						VALUES (@AcctId,@SecId,@Acctnbr,@BrkNbr,@TempFaceAmountFromAlloc,@RemFaceAmount,@TempAvailRestOverriden,0)
					END
					ELSE
					BEGIN
						INSERT INTO #TempAcctTbl (AcctId,secID,AcctNbr,BrkNbr,FaceAmountFromAlloc,FaceAmountActual,AvailRestOverriden,LoanNbr,IsProcessed)
						VALUES (@AcctId,@SecId,@Acctnbr,@BrkNbr,@TempFaceAmountFromAlloc,@TempFaceAmount,@TempAvailRestOverriden,@RowCount,0)

						UPDATE #AcctTbl SET IsProcessed = 1 WHERE Acctnbr = @Acctnbr  AND secID = @SecId
						SET @RemFaceAmount = 0
					END
				END -- END OF IF(@TempFaceAmount > @MaxLoanAmount AND ISNULL(@AcctFaceAmountSum,0) = 0)

				SELECT 
					@AcctFaceAmountSum = SUM(FaceAmountActual) 
				FROM 
					#TempAcctTbl 
				WHERE 
					LoanNbr = @RowCount  AND 
					secID = @SecId

				SET @NeedFaceAmount = 
							CASE WHEN (@NeedFaceAmount - ISNULL(@AcctFaceAmountSum,0)) > 0 THEN (@NeedFaceAmount - ISNULL(@AcctFaceAmountSum,0) )
								ELSE ( CASE WHEN (ISNULL(@AcctFaceAmountSum,0) - @NeedFaceAmount) = 0 THEN @MaxLoanAmount - @NeedFaceAmount ELSE   (ISNULL(@AcctFaceAmountSum,0) - @NeedFaceAmount) END)
							END

				SELECT TOP 1 
						@Acctnbr = Acctnbr ,
						@TempFaceAmount = FaceAmountActual,
						@TempFaceAmountFromAlloc = FaceAmountFromAlloc, 
						@TempAvailRestOverriden = AvailRestOverriden
				FROM 
					#AcctTbl 
				WHERE  
					IsProcessed = 0  AND 
						secID = @SecId AND 
						FaceAmountActual > 0 
				ORDER BY 
					Acctnbr

			END  -- END of WHILE (@NeedFaceAmount > 0  AND ISNULL(@AcctFaceAmountSum,0) < @MaxLoanAmount AND ((SELECT COUNT(*) FROM #AcctTbl WHERE IsProcessed = 0 AND secID = @SecId) > 0))
			SET @RowCount = @RowCount + 1

				SELECT @AcctCount = MIN(rowid) FROM #AcctTbl WHERE IsProcessed = 0  AND secID = @SecId AND FaceAmountActual > 0 --@AcctCount + 1
		END  --END of WHILE (@AcctCount <= @TotalAcctCount OR ((SELECT COUNT(*) FROM #AcctTbl WHERE IsProcessed = 0  AND secID = @SecId) > 0))

	END -- END of IF (@IsLoanBreak = 1)
	ELSE
	BEGIN

--		TRUNCATE TABLE #TempAcctTbl

		INSERT INTO #TempAcctTbl 
		(
			secID,				
			AcctId,
			AcctNbr,
			BrkNbr,
			FaceAmountFromAlloc,
			FaceAmountActual,
			AvailRestOverriden,
			LoanNbr,
			IsProcessed 
		)
		SELECT 
			@SecId,
			AcctId,
			AcctNbr,
			BrkNbr,
			FaceAmountFromAlloc,
			FaceAmountActual,
			AvailRestOverriden,
			1, --LoanNbr default to 1 becasue only one loan per req
			0-- IsProcessed 
		FROM 
			#AcctTbl 
		WHERE 
			secID = @SecId
		ORDER BY 
			FaceAmountActual DESC
	END 
	  
	 --SELECT * FROM #AllocationTbl  
	 /***** 1st step : Insert into dbo.ETITranUploadHistLog table ***/   
	 SET @Ret = 1  
	  
	 SET @FileName = 'Book Collateral (GPL) from LAVA'  	  
	  
	 /* Make only one entry for CA for TOE for multiple loans with different brokers  
	 */  
	 IF   
