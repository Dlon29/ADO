				@BrkCrGrpID,
				@BrkGrpID,
				@BrkID,--b.BrkId,
				@RecordTypeID,
				@FileName,
				@BatchDate,
				@Ret,
				@ModifiedBy,
				@ModifiedDate
		  
		  
		  SET @SourceID = @@IDENTITY  
		  SET @ERROR_NO = @@ERROR   		  
		  
		  /* Insert SourceId for selected broker in temp HistLogTbl for further processing*/  
		  INSERT INTO @HistLogTbl   
		  (  
			   SourceId,  
			   BrkCrGrpId,  
			   BrkId,  
			   RecordTypeID  
		  )  
		  SELECT DISTINCT  
			   @SourceID,  
			   @BrkCrGrpID,  
			   @BrkID,  
			   @RecordTypeID  
			    
	 END  
	 ELSE    
	 BEGIN 
		  SET @SourceId = NULL  
		  
		  SELECT   
		   @SourceId = SourceId   
		  FROM   
		   @HistLogTbl   
		  WHERE  
		   BrkID = @BrkID AND       
		   RecordTypeID = @RecordTypeID 
	 END  
	  
	  
	 /***** 2nd step : Insert into dbo.ETIRawData table ****/  
	 IF (@SourceId IS NOT NULL)  
	 BEGIN   
		IF (@IsLoanBreak = 0) -- do not break in multiple loans
		BEGIN 
	   
			 /***** 2nd step : Insert into dbo.ETIRawData table ****/  
			  INSERT INTO dbo.ETIRawData  
			  (  
				   [SourceID],  
				   [EqlEquiLendID],
				   [SecID],  
				   [BrkID],  
				   [TxnRefNbr],    
				   [RecordTypeID],  
				   [SecLocID],  
				   [SecLocCode],  
				   [SecCode],  
				   [FaceAmount],  
				   [Price],  
				   [PriceOverride],  
