CREATE PROCEDURE [dbo].[p_GetData_ETI_CloseRebookLoansandCollaterals]
(		
	@TxnRefNbr					VARCHAR(MAX) = '',	
	@BrkCrGrpId					INT = 0,
	@BrkGrpId					INT = 0,
	@BrkNbr						VARCHAR(6) = '',	
	@SecCode					VARCHAR(12) = '',
	@BasketIdentifier			VARCHAR(2) = '',
	@BussLineInd				VARCHAR(2) ='',	
	@FinderNbr					VARCHAR(10) = '',
	@ProductCategory			VARCHAR(3) = '',
	@DisplayTermLoan			VARCHAR(1) = '',	
	@DisplaySTTEndDateLoan		VARCHAR(1) = '',
	@DisplayScripEndDateLoan	VARCHAR(1) = '',
	@TransmitFlag				VARCHAR(1) = ''
)
AS
BEGIN
	
	SET NOCOUNT ON;

	DECLARE @ERROR_NO INT, @BussDate DATETIME , @RecordTypeID INT
	
	IF @BussDate IS NULL OR @BussDate = ''
	BEGIN
		SET @BussDate = (SELECT CurrentBatchDate FROM GLOBALONE.dbo.vw_G1_System)
	END

	SET @RecordTypeID = 13

	SELECT * INTO #TempGCIErrorLog FROM dbo.f_GetG1ErrorMessage (0,0,'')
	
	/* This will be called from first screen for Adjsut loans rateon click of 'Existing Loans' button*/				
	-- Obtain details for loans and collaterals that exist in GlobalOne.dbo.Loan table		
	SELECT DISTINCT			
		broker.BrkName,
		broker.BrkNbr,
		Broker.BrkID,
		bkrGrp.BrkGrpCode,
		Loan.TxnRefNbr,
		Loan.SecID,
		Loan.SecCode,
		Sec.BucketSecurityType ,
		CASE Loan.LoanType WHEN 'C' THEN 'ARR' ELSE 'APR' END TOE, --TODO: Need to confirm
		Loan.FaceAmount,
		Loan.TradePrice,
		Loan.Principal,
		CASE Loan.LoanType WHEN 'C' THEN 'C' ELSE 'NC' END LoanType, 
		Loan.CollCCYCode,
		Loan.FinderNbr,
		ISNULL(Loan.AsOfDate,'') AsOfDate,
		ISNULL(CONVERT(VARCHAR(10),Loan.TermDate,101),'') TermDate,
		ISNULL(CONVERT(VARCHAR(10),Loan.SettleDate,101),'') SettleDate,
		Loan.ProductCategory,
		Loan.EqlEquiLendID,
		CASE WHEN ISNULL(Loan.EqlEquiLendID,0) > 0 THEN 'Y' ELSE 'N' END AS IsEqlLoan,
		ISNULL(CONVERT(VARCHAR(10),Loan.STTEndDate,101),'') STTEndDate,
		ISNULL(CONVERT(VARCHAR(10),Loan.ScripEndDate,101),'') ScripEndDate,
		Loan.LoanStatus ,
		loan.BGNREF	,
		loan.GPTransmit,
		Loan.IsPrePay,
		Loan.TPUID		
	INTO 
		#TempLoanDetails
	FROM
		GLOBALONE.dbo.Loan Loan
	INNER JOIN
		REFERENCE.dbo.Security Sec 
	ON 
		Sec.SecID = Loan.SecID AND
		Loan.IsStreetSide = 1 AND
		--Loan.TxnType = 'L' AND
		Loan.LoanType <> 'C' AND -- SecLending loans only
		Loan.IsFuture = 0 AND
		--(Loan.Loanstatus = 9 OR		-- not verified loans
		--	(Loan.Loanstatus = 1 AND --verified & unsettled loans only
		--	 Loan.IsConfirmed = 0
		--	)
		--)
		Loan.LoanStatus = 1 AND --verified loans only
		Loan.IsConfirmed = 2 AND --settled loans only
		Loan.IsLoanedSecuritiesService = 0 AND--excluding LSS loans
		Loan.IsFICCMatched = 0 --excluding FICC loans
	INNER JOIN 
		Mobetter.dbo.Broker broker 
	ON 
		Loan.BrkNbr = broker.BrkNbr AND 
		(@BussDate BETWEEN broker.EffectiveDateBegin AND broker.EffectiveDateEnd) AND
		ISNULL(broker.IsDeleted,0) = 0 
	INNER JOIN 
		Mobetter.dbo.BrokerGroup bkrGrp 
	ON 
		broker.BrkGrpID = bkrGrp.BrkGrpID AND 
		(@BussDate BETWEEN bkrGrp.EffectiveDateBegin AND bkrGrp.EffectiveDateEnd) AND
		ISNULL(bkrGrp.IsDeleted,0) = 0
	INNER JOIN 
		Mobetter.dbo.BrokerCreditGroup brkCrGrp 
	ON 
		bkrGrp.BrkCrGrpID = brkCrGrp.BrkCrGrpID AND 
		(@BussDate BETWEEN brkCrGrp.EffectiveDateBegin AND brkCrGrp.EffectiveDateEnd) AND
		ISNULL(brkCrGrp.IsDeleted,0) = 0 
	LEFT JOIN
		dbo.LoanBasketSetup LoanBask
	ON
		LoanBask.BrkNbr = broker.BrkNbr AND	
		ISNULL(LoanBask.IsDeleted,0) = 0
	LEFT JOIN 
		LAVA.dbo.DXSecTransactions DxSecTran
	ON 
		Loan.SecID = DxSecTran.SecID
	WHERE 			
		(
			@TxnRefNbr = '' 
			OR Loan.TxnRefNbr IN (SELECT Items FROM dbo.f_Split(@TxnRefNbr, ','))
		) AND			
		(
			@SecCode IS NULL OR 
			@SecCode = '' 
			OR Sec.SecCode = @SecCode 
			OR Sec.CUSIP = @SecCode 
			OR Sec.ISIN = @SecCode 
			OR Sec.SEDOL = @SecCode 
			OR Sec.TickSymb LIKE @SecCode +'%'
		) AND			
		(
			@BrkCrGrpID = 0 
			OR brkCrGrp.BrkCrGrpID = @BrkCrGrpID
		) AND
		(
			@BrkGrpID = 0 
			OR bkrGrp.BrkGrpID = @BrkGrpID
		) AND
		(
			@BrkNbr = '0' 
			OR broker.BrkNbr = @BrkNbr
		) AND		 
		(
			@BussLineInd = ''
			OR @BussLineInd = '0'
			OR Sec.BucketSecurityType = @BussLineInd
		)AND		 
		(
			@ProductCategory = ''
			OR @ProductCategory = '0'
			OR Loan.ProductCategory = @ProductCategory
		)AND
		(
			@FinderNbr = '0' -- for all loans
			OR (@FinderNbr = '' AND ISNULL(Loan.FinderNbr,'') != '000LDN' )-- for US Loans
			OR Loan.FinderNbr = @FinderNbr -- for London loans
		)AND		 
		(
			@BasketIdentifier = ''
			OR @BasketIdentifier = '0'
			OR LoanBask.BasketIdentifier = @BasketIdentifier
		)
		AND
		(
			/*Term loans will not be displayed by default; the user will have to check off the "Display Term " box for them to appear*/
			(@DisplayTermLoan = '1'
			OR (ISNULL(TermDate,'') = CASE @DisplayTermLoan WHEN '' THEN ''  WHEN '0' THEN '' END))
		)AND
		(
			/*STT loans will not be displayed by default; the user will have to check off the "Display STT" box for them to appear*/
			(@DisplaySTTEndDateLoan = '1'
			OR (ISNULL(STTEndDate,'') = CASE @DisplaySTTEndDateLoan WHEN '' THEN ''  WHEN '0' THEN '' END))
		)AND 
		(
			/*Scrip loans will not be displayed by default; the user will have to check off the "Display Scrip Loan" box for them to appear*/
			@DisplayScripEndDateLoan = '1'
			OR (ISNULL(ScripEndDate,'') = CASE @DisplayScripEndDateLoan WHEN '' THEN ''  WHEN '0' THEN '' END)
		)
		AND
		(
			(@TransmitFlag = ''
			OR ISNULL(Transmit,'') = @TransmitFlag)
		)
		AND ISNULL(Loan.RRLinkRefNbr, '') = '' -- exclude Rev Repo Loans		
		

	-- delete settled return trades from temp table if it is successfully returned & settled.
	DELETE 
		#TempLoanDetails
	FROM 
		#TempLoanDetails LoanDtl
	INNER JOIN 
		dbo.ETIDetailRecord Dtl 
	ON 
		Dtl.TxnRefNbr = LoanDtl.TxnRefNbr AND
		LoanDtl.TxnRefNbr > 0 AND
		--Dtl.RecordTypeId = 13 AND
		Dtl.RecordTypeId IN (12,4) AND  -- PSL & RSL
		Dtl.StatusId = 140
	INNER JOIN 
		#TempGCIErrorLog ErrMsg
	ON
		Dtl.RawDataId = ErrMsg.RawDataId AND
		ErrMsg.MessageCategory = 1 -- only success

	SELECT * FROM #TempLoanDetails
	DROP TABLE #TempGCIErrorLog
	
	SET @ERROR_NO = @@ERROR	
--	DROP TABLE #TempLoanTable

	IF @ERROR_NO <> 0 
		RAISERROR ( 'Error raised in p_GetData_ETI_CloseRebookLoansandCollaterals', 16, 1 )
END
