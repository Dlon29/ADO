CREATE PROCEDURE [dbo].[p_BaNCS_BookCALoans]
(	
	@CAPayoutMapID INT = 0,--In case of 0 loan booking will be done for all the Corp Actions. 
	@ModifiedBy VARCHAR(50) = NULL,
	@BookingXML XML = NULL
)
AS
BEGIN

	DECLARE @xml XML,
			@CAPSLReturnLoanXML VARCHAR(MAX),
			@CARSLReturnLoanXML VARCHAR(MAX),
			@CAAdjustAvailabilityXML VARCHAR(MAX),
			@CANewLoanXML VARCHAR(MAX),
			@CACategoryType INT,
			@CATOE VARCHAR(15),
			@PSLRowID INT = 0,
			@RSLRowID INT = 0,
			@ASERowID INT = 0,
			@TSLRowID INT = 0,
			@RowNbr INT = 0,
			@RecordTypeIDPSL INT = 11,
			@RecordTypeIDRSL INT = 3,
			@RecordTypeIDASE INT = 18,
			@RecordTypeIDTSL INT = 1,
			@BatchDate DATETIME,
			@BookingType CHAR(1)

	DECLARE @Identifier VARCHAR(50),
			@ClaimsStatusForLoanBooking VARCHAR(50),
			@ClaimsStatusForLoanReBooking VARCHAR(50)

	SELECT @Identifier = 'CA_CLAIMPROCEEDS_CONFIG'
    SELECT @ClaimsStatusForLoanBooking = ISNULL(dbo.f_GetDomainLookupValue(@Identifier, 'ClaimsStatusForLoanBooking'),'10,110,120')
	SELECT @ClaimsStatusForLoanReBooking = ISNULL(dbo.f_GetDomainLookupValue(@Identifier, 'ClaimsStatusForLoanReBooking'),'200')


	--IF OBJECT_ID('tempdb..#TMP_ETIAllocation') IS NOT NULL 
	--	TRUNCATE TABLE #TMP_ETIAllocation

	IF OBJECT_ID('tempdb..#TMP_ETIAllocation','U') IS NULL			
	BEGIN
		SELECT * ,CONVERT(INT,NULL) SecID
		INTO #TMP_ETIAllocation
		FROM LAVA.dbo.f_CreateETIAllocationSchema() 
	END

	--IF OBJECT_ID('tempdb..#TMP_CAWLBookingPreview') IS NOT NULL 
	--	TRUNCATE TABLE #TMP_CAWLBookingPreview

	--#TMP_CAWLBookingPreview
	IF OBJECT_ID('tempdb..#TMP_CAWLBookingPreview','U') IS NULL			
	BEGIN
		SELECT * 
		INTO #TMP_CAWLBookingPreview
		FROM LAVA.dbo.f_CreateCAWLBookingPreviewSchema() 
	END
	IF NOT EXISTS (SELECT 1 FROM tempdb.sys.columns WHERE object_id = OBJECT_ID('tempdb..#TMP_CAWLBookingPreview') AND name ='StatusCode')
	BEGIN
		ALTER TABLE #TMP_CAWLBookingPreview ADD StatusCode VARCHAR(25) NOT NULL DEFAULT ('')
	END
	IF NOT EXISTS (SELECT 1 FROM tempdb.sys.columns WHERE object_id = OBJECT_ID('tempdb..#TMP_CAWLBookingPreview') AND name ='ErrorInfo')
	BEGIN
		ALTER TABLE #TMP_CAWLBookingPreview ADD ErrorInfo VARCHAR(1000) NULL
	END
	IF NOT EXISTS (SELECT 1 FROM tempdb.sys.columns WHERE object_id = OBJECT_ID('tempdb..#TMP_CAWLBookingPreview') AND name ='IsXMLPrepared')
	BEGIN
		ALTER TABLE #TMP_CAWLBookingPreview ADD IsXMLPrepared BIT NOT NULL DEFAULT (0)
	END
	


	--GET RECORDS FOR LOAN BOOKING--------------------------------------------------------------------------------------------------
	DECLARE @ProcessStatus_0_ToBeProcessed INT = 0,
			@ProcessStatus_1_Processed INT = 1,
			@ProcessStatus_2_VerifyError INT = 2,
			@ProcessStatus_3_ErrorBooking INT = 3
			
	
	
	SELECT 
		ROW_NUMBER() OVER (ORDER BY CAPayoutMapID) AS RowID, 
		CAPayoutMapID,
		ClaimProceedsFileID,
		BaNCSInternalEventID,
		CONVERT(SMALLINT,@ProcessStatus_0_ToBeProcessed) AS IsProcessed,  --0: Yet To Processed 1: Processed 2: Verification Error 3: Error ProcessIng
		CASE WHEN CPH.SLStatusID IN (SELECT Item FROM LAVA.DBO.SplitString(@ClaimsStatusForLoanrEBooking,',')) 
				THEN 'R'
			 ELSE 'B' END AS BookingType,
		CONVERT(VARCHAR(5000),NULL) AS ErrorInfo,
		CONVERT(SMALLINT,0) AS IsMailSent
	INTO
		#TMP_CAToProcess
	FROM 
		LAVA.DBO.CAPayoutMapHeader CPH
	WHERE 
		(
			CPH.SLStatusID IN (SELECT Item FROM LAVA.DBO.SplitString(@ClaimsStatusForLoanBooking,','))
			OR
			CPH.SLStatusID IN (SELECT Item FROM LAVA.DBO.SplitString(@ClaimsStatusForLoanrEBooking,','))
		) AND
		CPH.CAPayoutMapID = CASE WHEN @CAPayoutMapID !=0 
								THEN @CAPayoutMapID 
							 ELSE 
								CPH.CAPayoutMapID 
						END

	/** Get Globalone batch date **/
	SELECT 
		@BatchDate = CurrentBatchDate 
	FROM 
		GLOBALONE.dbo.vw_G1_System	



	-----------------------------------------------------------------------------------------------------------------------------

	--LOOP THROUGH THE INDIVIDUAL CORP ACTION (CAPayoutMapID)--------------------------------------------------------------------
	WHILE EXISTS ( SELECT TOP 1 * FROM #TMP_CAToProcess WHERE IsProcessed = @ProcessStatus_0_ToBeProcessed ORDER BY RowID) 
	BEGIN
		SET @RowNbr = 0
		SET @PSLRowID = 0
		SET @RSLRowID = 0
		SET @ASERowID = 0
		SET @TSLRowID = 0


		--PRICESSING PAYOUT
		SELECT TOP 1 
			@CAPayoutMapID = CAPayoutMapID ,
			@BookingType = BookingType
		FROM 
			#TMP_CAToProcess 
		WHERE 
			IsProcessed = @ProcessStatus_0_ToBeProcessed  
		ORDER BY RowID

		BEGIN TRY
			
			--IF ACTION IS BOOK (B) FOLLOW THE BELOW PROCESS. 
			--IF ACTION IS ReBook (R) CALL THE SP WHICH WILL REBOOK FAILED LOANS FOR THE GIVEN CAPAYOUT MAP ID. 
			IF(@BookingType = 'B')
			BEGIN
				TRUNCATE TABLE #TMP_CAWLBookingPreview
				--GET PREVIEW DATA---------------------------------------------------------------------------------------------------
				IF NOT EXISTS (SELECT 1 FROM #TMP_CAWLBookingPreview)  
				BEGIN
					IF @BookingXML IS NULL --AUTO
					BEGIN
						EXEC LAVA.dbo.p_BaNCS_GetDataCABookingPreview 
						@CAPayoutMapID=@CAPayoutMapID,
						@ViewType=1,
						@ETILoanDetails=0,
						@IsDisplayResults=0
					END
					ELSE--MANUAL
					BEGIN
					
						--#TMP_CAWLBookingPreview load @BookingXML to #TMP_CAWLBookingPreview

						DECLARE @hdoc INT
						EXEC SP_XML_PREPAREDOCUMENT @hdoc output, @BookingXML	

						/** Insert data into temp table for processing **/
						INSERT INTO #TMP_CAWLBookingPreview
						(
							RowID				,
							BrkGrpCode			,
							BrkGrpName			,
							BrkNbr				,
							TxnRefNbr			,
							AcctNbr				,
							TOEDesc				,
							CACategoryType		,
							SecCode				,
							SecID				,
							SecurityDesc		,
							CurrLoanQty			,
							UnitsExisting		,
							UnitsNew			,
							LevelNbr			,
							WLDepository		,
							SettlementDate		,
							TermDate			,
							CCYCode				,
							TradePrice			,
							TOEQuantity			,
							Principal			,
							CollCCYCode			,
							RebateRate			,
							SecLocCode			,
							AsOfDate			,
							CollateralDate		,
							GoodFundsDate		,
							FinderNbr			,
							EqlEquiLendID		,
							PoolNbr				,
							Comments			,
							SettlementInstr		,
							SettlementCCY		,
							CleanUpFlg			,
							TransmitFlg			,
							DisclosureType		,
							TriPartyGrpID		,
							CollSchedID			,
							ProductCategory		,
							LowDivRate			,
							STTLevel			,
							STTEndDate			,
							STTDivRate			,
							SMode				,
							CAPayoutMapID		,
							BaNCSInternalEventId,
							ClaimProceedsFileID	,
							SLStatusID			,
							TOEType				
						)
						SELECT
							RowID = item.row.value('RowID[1]','INT'),		
							BrkGrpCode				= item.row.value('BrkGrpCode[1]','VARCHAR(3)'),
							BrkGrpName				= item.row.value('BrkGrpName[1]','VARCHAR(100)'),
							BrkNbr					= item.row.value('BrkNbr[1]','VARCHAR(6)'),
							TxnRefNbr				= item.row.value('TxnRefNbr[1]','INT'),
							AcctNbr					= item.row.value('AcctNbr[1]','VARCHAR(12)'),
							TOEDesc					= item.row.value('TOEDesc[1]','VARCHAR(7)'),
							--G1TOECode				= item.row.value('G1TOECode[1]','VARCHAR(15)'),
							CACategoryType			= item.row.value('CACategoryType[1]','INT'),
							SecCode					= item.row.value('SecCode[1]','VARCHAR(12)	'),
							SecID					= NULLIF(item.row.value('SecID[1]','INT'),0),
							SecurityDesc			= item.row.value('SecurityDesc[1]','VARCHAR(40)	'),
							CurrLoanQty				= NULLIF(item.row.value('CurrLoanQty[1]','NUMERIC(13,0)'),0),
							UnitsExisting			= NULLIF(item.row.value('UnitsExisting[1]','NUMERIC(20,4)'),0),
							UnitsNew				= NULLIF(item.row.value('UnitsNew[1]','NUMERIC(20,4)'),0),
							LevelNbr				= item.row.value('LevelNbr[1]','INT'),
							WLDepository			= item.row.value('WLDepository[1]','VARCHAR(6)'),
							SettlementDate			= NULLIF(item.row.value('SettlementDate[1]','DATETIME'),'01/01/1900'),
							TermDate				= NULLIF(item.row.value('TermDate[1]','DATETIME'),'01/01/1900'),
							CCYCode					= item.row.value('CCYCode[1]','VARCHAR(3)'),
							TradePrice				= NULLIF(item.row.value('TradePrice[1]','DECIMAL(13, 6)'),0),
							TOEQuantity				= NULLIF(item.row.value('TOEQuantity[1]','NUMERIC(13,0)'),0),
							Principal				= NULLIF(item.row.value('Principal[1]','DECIMAL(17, 2)'),0),
							CollCCYCode				= item.row.value('CollCCYCode[1]','VARCHAR(3)'),
							RebateRate				= NULLIF(item.row.value('RebateRate[1]','DECIMAL(9, 6)'),0),
							SecLocCode				= item.row.value('SecLocCode[1]','VARCHAR(2)'),
							AsOfDate				= NULLIF(item.row.value('AsOfDate[1]','DATETIME'),'01/01/1900'),
							CollateralDate			= NULLIF(item.row.value('CollateralDate[1]','DATETIME'),'01/01/1900'),
							GoodFundsDate			= NULLIF(item.row.value('GoodFundsDate[1]','DATETIME'),'01/01/1900'),
							FinderNbr				= item.row.value('FinderNbr[1]','VARCHAR(6)'),
							EqlEquiLendID			= NULLIF(item.row.value('EqlEquiLendID[1]','BIGINT'),0),
							PoolNbr					= NULLIF(item.row.value('PoolNbr[1]','VARCHAR(3)'),''),
							Comments				= NULLIF(item.row.value('Comments[1]','VARCHAR(20)'),''),
							SettlementInstr			= NULLIF(item.row.value('SettlementInstr[1]','VARCHAR(30)'),''),
							SettlementCCY			= NULLIF(item.row.value('SettlementCCY[1]','VARCHAR(6)'),''),
							CleanUpFlg				= item.row.value('CleanUpFlg[1]','VARCHAR(1)'),
							TransmitFlg				= item.row.value('TransmitFlg[1]','VARCHAR(1)'),
							DisclosureType			= item.row.value('DisclosureType[1]','VARCHAR(1)'),
							TriPartyGrpID			= NULLIF(item.row.value('TriPartyGrpID[1]','INT'),0),
							CollSchedID				= NULLIF(item.row.value('CollSchedID[1]','INT'),0),
							ProductCategory			= item.row.value('ProductCategory[1]','VARCHAR(3)'),
							LowDivRate				= item.row.value('LowDivRate[1]','BIT'),
							STTLevel				= NULLIF(item.row.value('STTLevel[1]','VARCHAR(30)'),''),
							STTEndDate				= NULLIF(item.row.value('STTEndDate[1]','DATETIME'),'01/01/1900'),
							STTDivRate				= NULLIF(item.row.value('STTDivRate[1]','VARCHAR(30)'),''),
							SMODE					= item.row.value('SMODE[1]','VARCHAR(6)'),
							CAPayoutMapID			= item.row.value('CAPayoutMapID[1]','INT'),
							BaNCSInternalEventId	= item.row.value('BaNCSInternalEventId[1]','VARCHAR(10)'),
							ClaimProceedsFileID		= item.row.value('ClaimProceedsFileID[1]','INT'),
							SLStatusID				= item.row.value('SLStatusID[1]','INT'),
							TOEType					= item.row.value('TOEType[1]','VARCHAR(2)')
						FROM 
							@BookingXML.nodes('root/G1BookingDtls') item(row)

						IF EXISTS (SELECT 1 FROM #TMP_CAWLBookingPreview WHERE RowID IS NULL)
						BEGIN
							;WITH CTE_ID_CAWLBP
							AS
							(
								SELECT RowID = ROW_NUMBER() OVER(ORDER BY BrkGrpCode,TxnRefNbr,LevelNbr,TOEType DESC ), 
										BrkGrpCode,TxnRefNbr,LevelNbr,TOEType 
								FROM 
									#TMP_CAWLBookingPreview
							)
							UPDATE 
								TCAWLBP
							SET
								TCAWLBP.RowID = CAWLBP.RowID
							FROM #TMP_CAWLBookingPreview TCAWLBP
								INNER JOIN CTE_ID_CAWLBP CAWLBP
							ON
								TCAWLBP.BrkGrpCode = CAWLBP.BrkGrpCode AND
								TCAWLBP.TxnRefNbr = CAWLBP.TxnRefNbr AND
								TCAWLBP.LevelNbr = CAWLBP.LevelNbr AND
								TCAWLBP.TOEType = CAWLBP.TOEType
						END 

					END
				END
			


				SELECT 
					@CACategoryType  = CACategoryType 
				FROM 
					#TMP_CAWLBookingPreview 
				WHERE 
					CAPayoutMapID = @CAPayoutMapID

			
				--VERIFY CORP ACTION DATA--------------------------------------------------------------------------------------------
				EXEC LAVA.dbo.p_BaNCS_VerifyAndCheckCAData 
						@CAPayoutMapID=@CAPayoutMapID,
						@ModifiedBy=@ModifiedBy,
						@BookingXML = @BookingXML
			
				--BOOK CORP ACTION LOANS---------------------------------------------------------------------------------------------
				
				IF NOT EXISTS (SELECT 1 FROM #TMP_CAWLBookingPreview WHERE ISNULL(ErrorInfo,'') != '')
				BEGIN
					--LOOP THROUGH THE INDIVIDUAL RECORD OF THE CORP ACTION--------------------------------------------------------------
					WHILE EXISTS (SELECT TOP 1 * FROM #TMP_CAWLBookingPreview WHERE IsXMLPrepared = 0 ORDER BY RowID )
					BEGIN
						--Get Toe
						SELECT TOP 1 
							@CATOE = TOEDesc, 
							@RowNbr = RowID 
						FROM 
							#TMP_CAWLBookingPreview 
						WHERE 
							IsXMLPrepared = 0 
						ORDER BY 
							RowID

						--Prepare XML's based on TOE.
				
						IF @CATOE LIKE '%PSL%'
						BEGIN
							SET @xml = NULL
							SET @PSLRowID = @PSLRowID + 1
							SET @xml = (
											SELECT 
												RowId = @PSLRowID,
												TxnRefNbr =CONVERT(INT, TCBP.TxnRefNbr),
												AsOfDate = CONVERT(VARCHAR , ISNULL(TCBP.AsOfDate,@BatchDate), 101) ,	
												SettlementDate = TCBP.SettlementDate,
												SecCode = TRIM(TCBP.SecCode),
												SecType = 'EQ',
												BrkCrGroupId = '0',
												BrkGroupId =  '0',
												BrokerId = '0', 
												BrkNbr= TCBP.BrkNbr,
												AcctNbr = '', 
												ReturnQty =  ABS(ISNULL(TCBP.TOEQuantity,0)),
												TradePrice,
												RecordTypeID = @RecordTypeIDPSL,
												BatchDate =  CONVERT(VARCHAR , @BatchDate, 101) ,
												TransmitFlg = TCBP.TransmitFlg,
												EqlCtpyOrgId='' ,
												LegalEntityId='',
												EqlEquilendId='',
												EqlEquiLendReturnID='' ,
												EqlReturnType='' ,
												EqlSTBUSAOrgId='',
												EqlSTBUSALegalEntityID='' ,
												EqlEquiLendReturnSeqNbr='' ,
												EqlInternalRefID='' ,
												EqlUpdateReasonCode='' ,
												EqlNarrative='' ,
												/*----- Not there in CAPS Corp action code.*/
												EqlBorrSettlementInstrID='' ,
												EqlSTBUSASubAcctID='' ,
												EqlCtpySubAcctID='' ,
												EqlEquiLendRecallID='' ,
												RecordCreatedBy='' ,
												RecordReceivedDate='' ,
												------------------------------------------------
												ModifiedBy=@ModifiedBy ,
												TOE='PSL' ,
												/*----- Not there in CAPS Corp action code.*/
												SourceId='' ,
												IsDTC='',
												SendToWL='' ,
												------------------------------------------------
												TxnRefNbrCA=CONVERT(INT, TxnRefNbr) ,
												/*----- Not there in CAPS Corp action code. BUT AVAILABE IN NEW RETURN FILE*/
												RecallID=0 ,
												IsFullReturn= 0,
												IsCollateral='' ,
												BgnRef = '',
												Depository=TCBP.WLDepository,
												GPTransmit = 'Y' ,
												IsPSLRSLReq='0' ,
												IsSuppressed='' ,
												OverrideSwitchRules=''
											FROM 
												#TMP_CAWLBookingPreview TCBP
											WHERE 
												RowId =@RowNbr
											FOR XML RAW('FieldName')
										)

							SET @CAPSLReturnLoanXML  = CONCAT(@CAPSLReturnLoanXML , CAST(@xml AS VARCHAR(MAX)))
						END
			
						IF @CATOE LIKE '%RSL%'
						BEGIN
							SET @xml = NULL
							SET @RSLRowID = @RSLRowID + 1
							SET @xml = (
											SELECT 
												RowIIID = @RSLRowID,
												TxnRefNbr =CONVERT(INT, TCBP.TxnRefNbr),
												AsOfDate = CONVERT(VARCHAR , ISNULL(TCBP.AsOfDate,@BatchDate), 101) ,	
												SettlementDate = TCBP.SettlementDate,
												SecCode = TRIM(TCBP.SecCode),
												SecType = 'EQ',
												BrkCrGroupId = '0',
												BrkGroupId =  '0',
												BrokerId = '0', 
												BrkNbr= TCBP.BrkNbr,
												AcctNbr = '', 
												ReturnQty =  ABS(ISNULL(TCBP.TOEQuantity,0)),
												TradePrice,
												RecordTypeID = @RecordTypeIDRSL,
												BatchDate =  CONVERT(VARCHAR , @BatchDate, 101) ,
												TransmitFlg = TCBP.TransmitFlg,
												EqlCtpyOrgId='' ,
												LegalEntityId='',
												EqlEquilendId='',
												EqlEquiLendReturnID='' ,
												EqlReturnType='' ,
												EqlSTBUSAOrgId='',
												EqlSTBUSALegalEntityID='' ,
												EqlEquiLendReturnSeqNbr='' ,
												EqlInternalRefID='' ,
												EqlUpdateReasonCode='' ,
												EqlNarrative='' ,
												/*----- Not there in CAPS Corp action code*/
												EqlBorrSettlementInstrID='' ,
												EqlSTBUSASubAcctID='' ,
												EqlCtpySubAcctID='' ,
												EqlEquiLendRecallID='' ,
												RecordCreatedBy='' ,
												RecordReceivedDate='' ,
												------------------------------------------------
												ModifiedBy=@ModifiedBy ,
												TOE='RSL' ,
												/*----- Not there in CAPS Corp action code*/
												SourceId='' ,
												IsDTC='',
												SendToWL='' ,
												-----------------------------------------------
												TxnRefNbrCA=CONVERT(INT, TxnRefNbr) ,
												/*----- Not there in CAPS Corp action code. BUT AVAILABE IN NEW RETURN FILE*/
												RecallID=0 ,
												IsFullReturn= 0,
												IsCollateral='' ,
												BgnRef = '',
												Depository=TCBP.WLDepository,
												GPTransmit = 'Y' ,
												IsPSLRSLReq='0' ,
												IsSuppressed='' ,
												OverrideSwitchRules=''
										FROM 
											#TMP_CAWLBookingPreview TCBP
										WHERE 
											RowId =@RowNbr
										FOR XML RAW('FieldName')
									)

							SET @CARSLReturnLoanXML  = CONCAT(@CARSLReturnLoanXML , CAST(@xml AS VARCHAR(MAX)))
						END
			
						IF @CATOE LIKE '%ASE%'
						BEGIN
							SET @xml = NULL
							SET @ASERowID = @ASERowID + 1
							SET @xml = (
											SELECT 
												RowId = @ASERowID,
												TxnRefNbr =CONVERT(INT, TCBP.TxnRefNbr),
												AsOfDate = CONVERT(VARCHAR , ISNULL(TCBP.AsOfDate,@BatchDate), 101) ,	
												SettlementDate = TCBP.SettlementDate,
												SecCode = TRIM(TCBP.SecCode),
												SecType = 'EQ',
												WLDepository=TCBP.WLDepository,
												BrkCrGroupId = '0',
												BrkGroupId =  '0',
												BrokerId = '0', 
												BrkNbr= TCBP.BrkNbr,
												FaceAmount = ABS(TCBP.TOEQuantity),
												AcctId = '',
												AcctNbr = '', 
												--TradePrice=0,	--GCR: For ASE and TSL Trade price will be zero 
												TradePrice=TradePrice,	--GCR: 0424 Reverting change as Trade Price to remain
												CollCCY = '',
												RecordTypeID = @RecordTypeIDASE,
												BatchDate =  CONVERT(VARCHAR , @BatchDate, 101) ,
												TransmitFlg = TCBP.TransmitFlg,
												LegalEntityId='',
												EqlEquilendId='',
												ModifiedBy=@ModifiedBy ,
												TOE='ASE' ,
												SourceId='' ,
												TxnRefNbrCA=CONVERT(INT, TxnRefNbr) ,
												FaceAmountActual = ABS(TCBP.TOEQuantity),
												EqlCtpyOrgId='' ,
												EqlReturnType='' ,
												EqlSTBUSAOrgId='',
												EqlSTBUSALegalEntityID='' ,
												EqlEquiLendReturnSeqNbr='' ,
												EqlInternalRefID='' ,
												EqlUpdateReasonCode='' ,
												EqlNarrative='' ,
												EqlBorrSettlementInstrID='' ,
												EqlSTBUSASubAcctID='' ,
												EqlCtpySubAcctID='' ,
												EqlEquiLendRecallID='' ,
												RecordCreatedBy='' ,
												RecordReceivedDate='' ,
												IsDTC='',
												SendToWL='' ,
												RecallID=0 ,
												IsFullReturn= 0,
												IsCollateral='' ,
												BgnRef = '',
												GPTransmit = 'Y' ,
												IsPSLRSLReq='0' ,
												IsSuppressed='' ,
												OverrideSwitchRules=''
										FROM 
											#TMP_CAWLBookingPreview TCBP
										WHERE 
											RowId =@RowNbr
										--FOR XML RAW('FieldName'), ROOT('AdjustAvailability')
										FOR XML RAW('FieldName')
									)

							SET @CAAdjustAvailabilityXML  = CONCAT(@CAAdjustAvailabilityXML , CAST(@xml AS VARCHAR(MAX)))
						END

						IF @CATOE LIKE '%TSL%'
						BEGIN
							SET @xml = NULL
							SET @TSLRowID = @TSLRowID + 1
							SET @xml = (
											SELECT 
												RowId = @TSLRowID,
												AsOfDate = CONVERT(VARCHAR , ISNULL(TCBP.AsOfDate,@BatchDate), 101) ,	
												SettlementDate = TCBP.SettlementDate,
												SecCode = TRIM(TCBP.SecCode),
												SecID ='',
												BucketSecType = 'EQ',
												WLDepository=TCBP.WLDepository,
												IsIndemnified= '',
												UnitsAllocated = '',
												MaxLimit = '',
												MinLimit ='',
												Incr = '',
												BrkID = '0', 
												BrkNbr= TCBP.BrkNbr,
												AcctId ='',
												AcctNbr = '', 
												--FaceAmount = ABS(TCBP.TOEQuantity),
												Quantity = ABS(ISNULL(TCBP.TOEQuantity,0)),
												FaceAmountFromAlloc ='',
												FaceAmountActual = '',
												--Price = 0,--GCR: For ASE and TSL trade price should be zero
												Price=ISNULL(TradePrice,0),	--GCR: 0424 Reverting change as Trade Price to remain
												PriceCurr = CCYCode, 
