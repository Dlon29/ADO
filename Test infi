	BEGIN
		DECLARE @CAStatusXML XML

		SELECT @CAStatusXML =
			(
				SELECT DISTINCT
					   CAPayoutMapID AS [record/@CAPayoutMapID],
					   '' AS [record/@BaNCSInternalEventId],
					   '' AS [record/@ClaimProceedsFileID],
					   '' AS [record/@BrkGrpCode],
					   '' AS [record/@DebitSecID],
					   '' AS [record/@DebitWLSecCode],
					   '' AS [record/@CreditSecID],
					   '' AS [record/@CreditWLSecCode],
					   '' AS [record/@TxnRefNbr],
					   '' AS [record/@SLStatusID],
					   CASE IsProcessed 
						WHEN @ProcessStatus_3_ErrorBooking 
							THEN 'Error Sending Loan to G1: '+ErrorInfo 
						WHEN @ProcessStatus_2_VerifyError 
							THEN ErrorInfo
						ELSE 'Could not Send Loan to G1.' 
					   END AS [record/@ErrorInfo],
					   @ModifiedBy AS [record/@ModifiedBy]
				FROM #TMP_CAToProcess
				WHERE
					IsProcessed IN (@ProcessStatus_3_ErrorBooking)	 AND
					BookingType = 'B'
				ORDER BY CAPayoutMapID
				FOR XML PATH(''), ROOT('ROOT')
			)

		--Updating status for failed payout Map
		EXEC LAVA.dbo.p_BaNCS_UpdateCAStatus  
					@Action='SENTTOG1ERROR', 
					@CAStatusXML=@CAStatusXML, 
					@ModifiedBy = @ModifiedBy

		/* Iterate through records and send email
		--Sent To G1 Failed Error Email, Success Email, LAVa Error Email and Secuerit Error if nedeed
		*/

		WHILE EXISTS (SELECT TOP 1 * 
					  FROM #TMP_CAToProcess 
					  WHERE IsMailSent = 0 AND IsProcessed IN (@ProcessStatus_3_ErrorBooking,@ProcessStatus_2_VerifyError) 
					  ORDER BY RowID)
		BEGIN
			SELECT TOP 1 @CAPayoutMapID = CAPayoutMapID FROM #TMP_CAToProcess 
														WHERE IsMailSent = 0 AND IsProcessed IN (@ProcessStatus_3_ErrorBooking,@ProcessStatus_2_VerifyError) 
														ORDER BY RowID
			
			BEGIN TRY
				EXEC LAVA.dbo.p_BaNCS_CAUserNotification @CAPayoutMapID = @CAPayoutMapID , @User = @ModifiedBy

				UPDATE #TMP_CAToProcess
				SET 
					IsMailSent = 1
				WHERE 
					CAPayoutMapID = @CAPayoutMapID

			END TRY
			BEGIN CATCH
				UPDATE #TMP_CAToProcess
				SET 
					IsMailSent = 2
				WHERE 
					CAPayoutMapID = @CAPayoutMapID
			END CATCH
		END

		
		DECLARE @Errors VARCHAR(MAX)
		
		IF @CAPayoutMapID IS NULL
		BEGIN
			SELECT 
				@Errors = STRING_AGG('CAPayoutMapID:'+CONVERT(VARCHAR,CAPayoutMapID) +'-'+ErrorInfo,', ')  
			FROM 
				#TMP_CAToProcess
			SET @Errors = 'Could not process all the Corp Actions. Error sending and booking CA to GlobalOne(G1).'+ CHAR(10) + @Errors
		END
		ELSE
		BEGIN
			SELECT 
				@Errors = 'CAPayoutMapID:'+CONVERT(VARCHAR,@CAPayoutMapID) +'-'+ErrorInfo  
			FROM 
				#TMP_CAToProcess
			SET @Errors = 'Error sending and booking CA to GlobalOne(G1).'+ CHAR(10) + @Errors
		END
		
		SET @Errors = 'p_BaNCS_BookCALoans SP Failed :' + @Errors
		RAISERROR(@Errors,16,1)
	END
